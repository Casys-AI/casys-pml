{
  "tasks": {
    "dev": "deno run -A npm:vite",
    "build": "deno run -A npm:vite build",
    "preview": "deno run -A npm:vite preview",
    "check": "deno check src/**/*.ts src/**/*.tsx",
    "tauri": "cargo tauri"
  },
  "imports": {
    "preact": "npm:preact@^10.25.1",
    "preact/hooks": "npm:preact@^10.25.1/hooks",
    "preact/jsx-runtime": "npm:preact@^10.25.1/jsx-runtime",
    "preact/": "npm:preact@^10.25.1/",
    "@preact/signals": "npm:@preact/signals@^1.3.1",
    "@tauri-apps/api": "npm:@tauri-apps/api@^2",
    "@tauri-apps/plugin-opener": "npm:@tauri-apps/plugin-opener@^2",
    "vite": "npm:vite@^6.0.3",
    "@preact/preset-vite": "npm:@preact/preset-vite@^2.9.3",
    "pixi.js": "npm:pixi.js@^8",
    "@xterm/xterm": "npm:@xterm/xterm@^5.5.0",
    "@xterm/addon-fit": "npm:@xterm/addon-fit@^0.10.0"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "nodeModulesDir": "auto"
}
