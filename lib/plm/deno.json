{
  "name": "@casys/mcp-plm",
  "version": "0.1.0",
  "nodeModulesDir": "auto",
  "tasks": {
    "serve": "deno run --allow-all server.ts --http --port=3010",
    "test": "deno test --allow-all tests/",
    "build:ui": "cd src/ui && npm run build"
  },
  "exports": {
    ".": "./mod.ts",
    "./server": "./server.ts"
  },
  "imports": {
    "@casys/mcp-server": "../server/mod.ts",
    "@casys/mcp-syson": "../syson/mod.ts",
    "@casys/mcp-syson/src/api/queries.ts": "../syson/src/api/queries.ts",
    "@modelcontextprotocol/sdk": "npm:@modelcontextprotocol/sdk@^1.15.1",
    "@modelcontextprotocol/sdk/types.js": "npm:@modelcontextprotocol/sdk@^1.15.1/types.js",
    "ajv": "npm:ajv@^8.17.1",
    "hono": "npm:hono@^4",
    "hono/cors": "npm:hono@^4/cors",
    "jose": "npm:jose@^6.0.0",
    "@opentelemetry/api": "npm:@opentelemetry/api@^1.9.0",
    "@std/yaml": "jsr:@std/yaml@^1",
    "@std/assert": "jsr:@std/assert@1"
  }
}
