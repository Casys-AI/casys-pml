{
  "name": "@casys/mcp-erpnext",
  "version": "0.1.0",
  "nodeModulesDir": "auto",
  "tasks": {
    "serve": "deno run --allow-all server.ts --http --port=3012",
    "compile": "deno compile -A --output mcp-erpnext server.ts",
    "test": "deno test --allow-all tests/",
    "ui:build": "cd src/ui && node build-all.mjs"
  },
  "exports": {
    ".": "./mod.ts",
    "./server": "./server.ts"
  },
  "publish": {
    "include": [
      "mod.ts",
      "server.ts",
      "src/**/*.ts",
      "README.md",
      "LICENSE"
    ],
    "exclude": [
      "**/*_test.ts",
      "**/*.test.ts",
      "**/*.bench.ts"
    ]
  },
  "imports": {
    "@casys/mcp-server": "jsr:@casys/mcp-server"
  }
}
