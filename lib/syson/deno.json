{
  "name": "@casys/mcp-syson",
  "version": "0.1.0",
  "nodeModulesDir": "auto",
  "tasks": {
    "serve": "deno run --allow-all server.ts --http --port=3009",
    "compile": "deno compile -A --output mcp-syson server.ts",
    "test": "deno test --allow-all tests/"
  },
  "exports": {
    ".": "./mod.ts",
    "./server": "./server.ts"
  },
  "publish": {
    "include": [
      "mod.ts",
      "server.ts",
      "src/**/*.ts",
      "README.md",
      "LICENSE"
    ],
    "exclude": [
      "**/*_test.ts",
      "**/*.test.ts",
      "**/*.bench.ts"
    ]
  },
  "imports": {
    "@casys/mcp-server": "../server/mod.ts"
  }
}
