{
  "name": "@casys/infrastructure",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "pnpm run watch",
    "watch": "tsup --watch",
    "lint": "pnpm run lint:full",
    "lint:fast": "eslint . --ext .ts,.tsx --report-unused-disable-directives --cache --cache-location .eslintcache --cache-strategy content",
    "lint:full": "pnpm run lint:fast && pnpm run type-check",
    "type-check": "tsc --noEmit",
    "test": "vitest run --reporter=dot --silent --exclude \"**/*.int.test.ts\"",
    "test:debug": "vitest run src/persistence/repositories/__tests__/mdx-article-structure.repository.debug.test.ts --reporter=basic",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:int:infra": "RUN_INTEGRATION=1 vitest run --coverage=false --reporter=dot --silent --include \"**/*.int.test.ts\" --run",
    "test:int:newsapi": "RUN_INTEGRATION=1 vitest run --coverage=false --reporter=dot --silent src/adapters/test/news/newsapi-request-structure.integration.test.ts src/adapters/test/news/newsapi-real.integration.test.ts --run",
    "test:int:newsdata": "RUN_INTEGRATION=1 vitest run --coverage=false --reporter=dot --silent src/adapters/test/news/newsdata-request-structure.integration.test.ts src/adapters/test/news/newsdata-real.integration.test.ts --run",
    "test:int:worldnews": "RUN_INTEGRATION=1 vitest run --coverage=false --reporter=dot --silent src/adapters/test/news/worldnews-request-structure.integration.test.ts src/adapters/test/news/worldnews-real.integration.test.ts --run",
    "test:int:news": "pnpm run -C . test:int:newsapi && pnpm run -C . test:int:newsdata && pnpm run -C . test:int:worldnews",
    "validate-queries": "tsx scripts/validate-kuzu-queries.ts",
    "test:kuzu": "vitest run src/persistence/graph/__tests__/kuzu-query-validator.test.ts",
    "postinstall": "node scripts/install-kuzu-extensions.cjs"
  },
  "dependencies": {
    "@agentic/jina": "^7.6.9",
    "@casys/application": "workspace:*",
    "@casys/core": "workspace:*",
    "@casys/shared": "workspace:*",
    "@langchain/community": "^0.3.53",
    "@langchain/core": "^0.3.61",
    "@langchain/langgraph": "^0.2.36",
    "@langchain/openai": "^0.5.13",
    "@langchain/tavily": "^0.1.5",
    "@mozilla/readability": "^0.6.0",
    "@octokit/core": "^5.2.2",
    "axios": "^1.10.0",
    "canvas": "^3.2.0",
    "cheerio": "^1.1.2",
    "compromise": "^14.14.4",
    "dataforseo-client": "^2.0.7",
    "dependency-graph": "^1.0.0",
    "dotenv": "^16.5.0",
    "franc-min": "^6.2.0",
    "fuzzball": "^2.2.3",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "jsdom": "^26.1.0",
    "kuzu": "0.11.1",
    "neo4j-driver": "^6.0.0",
    "openai": "^4.0.0",
    "pino": "^9.9.0",
    "rss-parser": "^3.13.0",
    "sitemapper": "^4.0.2",
    "typescript": "^5.5.4",
    "uuid": "^13.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/glob": "^9.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^21.1.7",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "glob": "^11.0.3",
    "nock": "^14.0.5",
    "tsx": "^4.20.3",
    "vitest": "^3.2.4"
  }
}
