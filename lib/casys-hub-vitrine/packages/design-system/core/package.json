{
  "name": "@casys/core",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "pnpm run watch",
    "watch": "tsup --watch",
    "lint": "pnpm run lint:full",
    "lint:fast": "eslint . --ext .ts,.tsx --report-unused-disable-directives --cache --cache-location .eslintcache --cache-strategy content",
    "lint:full": "pnpm run lint:fast && pnpm run type-check",
    "type-check": "tsc --noEmit",
    "test": "vitest run --reporter=dot --silent"
  },
  "dependencies": {
    "@casys/shared": "workspace:*"
  }
}
