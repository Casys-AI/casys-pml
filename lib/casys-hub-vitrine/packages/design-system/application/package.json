{
  "name": "@casys/application",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "pnpm run watch",
    "watch": "tsup --watch",
    "lint": "pnpm run lint:full",
    "lint:fast": "eslint . --ext .ts,.tsx --report-unused-disable-directives --cache --cache-location .eslintcache --cache-strategy content",
    "lint:full": "pnpm run lint:fast && pnpm run type-check",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:smoke": "vitest run -i src/**/*.smoke.test.ts"
  },
  "dependencies": {
    "@casys/core": "workspace:*",
    "@casys/shared": "workspace:*",
    "@langchain/core": "^0.3.61",
    "fuzzball": "^2.2.3",
    "jsonrepair": "^3.6.0",
    "langchain": "^0.3.28",
    "pomljs": "^0.0.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@casys/core": "workspace:*",
    "@casys/shared": "workspace:*",
    "@types/node": "^22.0.0",
    "vitest": "^3.2.4"
  }
}
