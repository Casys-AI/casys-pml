  }

  .roi-card.animate-in {
    opacity: 1;
    transform: translateY(0);
    transition: all 400ms var(--md-sys-motion-easing-emphasized);
  }

  .roi-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    background: var(--md-sys-color-primary-container);
    color: var(--md-sys-color-primary);
    border-radius: 12px;
  }

  .roi-icon .material-symbols-rounded {
    font-size: 20px;
  }

  .roi-content {
    flex: 1;
  }

  .roi-label {
    font-size: var(--md-sys-typescale-label-medium-size);
    color: var(--md-sys-color-on-surface-variant);
