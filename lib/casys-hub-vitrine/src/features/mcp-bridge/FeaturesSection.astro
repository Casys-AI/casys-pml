---
import { useTranslations } from '../../i18n';
const locale = (Astro as any).currentLocale ?? 'en';
const t = useTranslations(locale).mcpBridgeFeatures;
---

<section id="features">
  <div class="container">
    <div class="section-header">
      <h2>{t.title} <span class="accent-text">{t.titleAccent}</span></h2>
      <p class="section-subtitle">{t.subtitle}</p>
    </div>
    <ul class="features-list">
      {t.features.map((f) => (
        <li class="feature-item">
          <span class="material-symbols-rounded feature-icon">{f.icon}</span>
          <span class="feature-name">{f.name}</span>
          <span class="feature-desc">{f.desc}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  #features {
    position: relative;
    padding: 56px 0 64px;
    overflow: hidden;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 48px;
  }

  .section-header {
    margin-bottom: 28px;
    max-width: 600px;
  }

  .section-header h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 600;
    font-optical-sizing: auto;
    color: var(--md-sys-color-on-surface);
    margin: 0 0 12px;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
    line-height: 1.6;
  }

  .features-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--md-sys-color-outline-variant);
    border: 1px solid var(--md-sys-color-outline-variant);
    border-radius: 12px;
    overflow: hidden;
  }

  .feature-item {
    display: grid;
    grid-template-columns: 32px 1fr;
    grid-template-rows: auto auto;
    column-gap: 12px;
    row-gap: 2px;
    padding: 16px 20px;
    background: var(--md-sys-color-surface-container-lowest);
    transition: background 150ms ease-out;
  }

  .feature-item:hover {
    background: var(--md-sys-color-surface-container);
  }

  .feature-icon {
    grid-row: 1 / 3;
    align-self: center;
    font-size: 22px;
    color: var(--md-sys-color-primary);
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .feature-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--md-sys-color-on-surface);
    line-height: 1.3;
  }

  .feature-desc {
    font-size: 0.75rem;
    color: var(--md-sys-color-on-surface-variant);
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    #features { padding: 48px 0; }
    .container { padding: 0 20px; }
    .features-list { grid-template-columns: 1fr; }
  }

  @media (max-width: 380px) {
    .container { padding: 0 14px; }
  }
</style>

<style is:global>
  #features { background: var(--md-sys-color-surface); }
  html[data-theme="dark"] #features { background: #0d0c0a; }

  html[data-theme="dark"] #features .section-header h2 { color: #f5f0ea; }
  html[data-theme="dark"] #features .section-subtitle { color: #d5c3b5; }

  html[data-theme="dark"] #features .features-list {
    background: rgba(255, 184, 111, 0.06);
    border-color: rgba(255, 184, 111, 0.08);
  }

  html[data-theme="dark"] #features .feature-item {
    background: #0d0c0a;
  }

  html[data-theme="dark"] #features .feature-item:hover {
    background: #1a1815;
  }

  html[data-theme="dark"] #features .feature-icon { color: #FFB86F; }
  html[data-theme="dark"] #features .feature-name { color: #f5f0ea; }
  html[data-theme="dark"] #features .feature-desc { color: #a89a8c; }
</style>
