---
import SubsiteHero from '../../components/SubsiteHero.astro';
import { useTranslations } from '../../i18n';

const locale = (Astro as any).currentLocale ?? 'en';
const t = useTranslations(locale).mcpBridgeHero;

const jsrSvg = '<svg width="16" height="16" viewBox="0 -3 64 64" fill="none" aria-hidden="true" style="border-radius:3px"><path d="M 0,21.846 H 9.846 V 12 h 34.462 v 4.923 H 64 V 36.616 H 54.155 V 46.462 H 19.693 V 41.539 H 0" fill="#083344"/><g fill="#f7df1e" transform="matrix(4.923,0,0,4.923,0,12)"><path d="M 1,3 H 2 V 4 H 3 V 1 H 4 V 5 H 1"/><path d="M 5,1 H 8 V 2 H 6 V 3 H 8 V 6 H 5 V 5 H 7 V 4 H 5"/><path d="m 9,2 h 3 V 4 H 11 V 3 H 10 V 6 H 9"/></g></svg>';

const terminalLines = `<code><span class="t-prompt">$</span> deno run --allow-net bridge.ts</code>
<code class="t-dim" style="margin-top:4px">  @casys/mcp-bridge v0.1.0</code>
<code class="t-dim">&nbsp;</code>
<code class="t-check"><span class="t-ok">\u2713</span> <span class="t-key">Platform</span>   Telegram Mini App</code>
<code class="t-check"><span class="t-ok">\u2713</span> <span class="t-key">Transport</span>  WebSocket on :4000</code>
<code class="t-check"><span class="t-ok">\u2713</span> <span class="t-key">Auth</span>       HMAC-SHA256 (initData)</code>
<code class="t-check"><span class="t-ok">\u2713</span> <span class="t-key">CSP</span>        Strict (default-src 'none')</code>
<code class="t-check"><span class="t-ok">\u2713</span> <span class="t-key">MCP Server</span> Connected (5 tools)</code>
<code class="t-dim">&nbsp;</code>
<code class="t-ready"><span class="t-ok">\u25CF</span> Bridge ready in <span class="t-accent">18ms</span></code>`;
---

<SubsiteHero
  sectionId="mcp-bridge-hero"
  tagline={t.tagline}
  title={{ line1: t.heroTitle1, line2: t.heroTitle2 }}
  subtitle={t.heroSubtitle}
  ctas={[
    { text: t.ctaPrimary, href: '#quickstart', icon: 'rocket_launch', variant: 'primary' },
    { text: t.ctaDocs, href: '/docs/mcp-bridge/introduction/', icon: 'description', variant: 'secondary' },
    { text: t.ctaSecondary, href: 'https://jsr.io/@casys/mcp-bridge', icon: jsrSvg, variant: 'secondary' },
  ]}
  stats={[
    { value: '107', label: t.statTests },
    { value: '1', label: t.statPlatforms },
    { value: 'v0.1', label: t.statRelease },
  ]}
  terminalTitle="mcp-bridge"
  terminalContent={terminalLines}
/>
