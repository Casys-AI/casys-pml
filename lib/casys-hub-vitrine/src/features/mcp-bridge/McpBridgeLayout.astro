---
import SubsiteLayout from '../../components/SubsiteLayout.astro';
import McpBridgeHeader from './McpBridgeHeader.astro';

export interface Props {
  title: string;
}

const { title } = Astro.props;
const locale = (Astro as any).currentLocale ?? 'en';

const metaDescriptions: Record<string, string> = {
  en: 'Bridge MCP Apps to Telegram Mini Apps. Zero code changes, production-ready security, extensible platform adapters.',
  fr: 'Pont entre MCP Apps et Telegram Mini Apps. Zéro changement de code, sécurité production, adaptateurs extensibles.',
  zh: '将 MCP Apps 桥接到 Telegram Mini Apps。零代码改动，生产级安全，可扩展平台适配器。',
};
const metaDescription = metaDescriptions[locale] ?? metaDescriptions.en;
---

<SubsiteLayout title={title} metaDescription={metaDescription}>
  <McpBridgeHeader slot="header" />
  <slot />
</SubsiteLayout>
