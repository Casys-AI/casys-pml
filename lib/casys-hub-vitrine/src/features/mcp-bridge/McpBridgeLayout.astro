---
import SubsiteLayout from '../../components/SubsiteLayout.astro';
import McpBridgeHeader from './McpBridgeHeader.astro';

export interface Props {
  title: string;
}

const { title } = Astro.props;
const locale = (Astro as any).currentLocale ?? 'en';

const metaDescriptions: Record<string, string> = {
  en: 'Bridge MCP Apps to Telegram Mini Apps. Zero code changes, production-ready security, extensible platform adapters.',
  fr: 'Pont entre MCP Apps et Telegram Mini Apps. Zéro changement de code, sécurité production, adaptateurs extensibles.',
  zh: '将 MCP Apps 桥接到 Telegram Mini Apps。零代码改动，生产级安全，可扩展平台适配器。',
};
const metaDescription = metaDescriptions[locale] ?? metaDescriptions.en;
---

<SubsiteLayout title={title} metaDescription={metaDescription} jsonLd={{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "@casys/mcp-bridge",
  "description": metaDescription,
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Cross-platform",
  "url": "https://mcp-bridge.casys.ai",
  "softwareVersion": "0.2.0",
  "author": { "@type": "Organization", "name": "Casys AI", "url": "https://casys.ai" },
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "license": "https://opensource.org/licenses/MIT",
  "programmingLanguage": "TypeScript",
  "codeRepository": "https://github.com/Casys-AI/mcp-bridge",
  "downloadUrl": "https://jsr.io/@casys/mcp-bridge"
}}>
  <McpBridgeHeader slot="header" />
  <slot />
</SubsiteLayout>
