---
import { useTranslations } from '../../i18n';
const locale = (Astro as any).currentLocale ?? 'en';
const t = useTranslations(locale).pmlBetaSignup;
---

<section id="beta">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">{t.eyebrow}</span>
      <h2>{t.title}</h2>
      <p class="section-desc">{t.description}</p>
    </div>

    <form
      id="beta-form"
      class="beta-form"
      action="https://formspree.io/f/movnynen"
      method="POST"
    >
      <input type="hidden" name="_subject" value={t.hiddenSubject} />

      <div class="form-row">
        <div class="form-group">
          <label for="beta-name">{t.labelName}</label>
          <input
            id="beta-name"
            type="text"
            name="name"
            placeholder={t.placeholderName}
            required
            autocomplete="name"
          />
        </div>

        <div class="form-group">
          <label for="beta-email">{t.labelEmail}</label>
          <input
            id="beta-email"
            type="email"
            name="email"
            placeholder={t.placeholderEmail}
            required
            autocomplete="email"
          />
        </div>
      </div>

      <div class="form-group">
        <label for="beta-usecase">{t.labelUseCase}</label>
        <textarea
          id="beta-usecase"
          name="message"
          placeholder={t.placeholderUseCase}
          rows="4"
        ></textarea>
      </div>

      <button type="submit" class="submit-btn">
        <span class="btn-text">{t.submit}</span>
        <span class="btn-loading">{t.sending}</span>
        <svg class="arrow-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <p id="beta-feedback" class="feedback" role="status" aria-live="polite"></p>
    </form>
  </div>
</section>

<style>
  /* ========================================
     BETA SIGNUP - Light mode (scoped)
     Fonts: Instrument Serif headings,
            JetBrains Mono eyebrow, Inter body
     ======================================== */

  section {
    padding: 100px 0;
    background: var(--md-sys-color-surface-container-low);
  }

  .container {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ---- Header ---- */
  .section-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .eyebrow {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--md-sys-color-primary);
    margin-bottom: 12px;
  }

  h2 {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 400;
    color: var(--md-sys-color-on-surface);
    margin: 0 0 12px;
    letter-spacing: -0.02em;
  }

  .section-desc {
    font-family: 'Inter', sans-serif;
    font-size: 1.1rem;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
    line-height: 1.6;
  }

  /* ---- Form ---- */
  .beta-form {
    background: var(--md-sys-color-surface-container-lowest);
    border: 1px solid var(--md-sys-color-outline-variant);
    border-radius: 16px;
    padding: 40px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 20px;
  }

  .form-row .form-group {
    margin-bottom: 0;
  }

  label {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--md-sys-color-on-surface);
  }

  input,
  textarea {
    width: 100%;
    padding: 12px 16px;
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    color: var(--md-sys-color-on-surface);
    background: var(--md-sys-color-surface-container-high);
    border: 1px solid var(--md-sys-color-outline-variant);
    border-radius: 10px;
    outline: none;
    transition: border-color 200ms ease-out, box-shadow 200ms ease-out;
  }

  input:focus,
  textarea:focus {
    border-color: var(--md-sys-color-primary);
    box-shadow: 0 0 0 3px rgba(255, 153, 0, 0.1);
  }

  input::placeholder,
  textarea::placeholder {
    color: var(--md-sys-color-on-surface-variant);
    opacity: 0.5;
  }

  textarea {
    resize: vertical;
    min-height: 100px;
  }

  /* ---- Submit button ---- */
  .submit-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 14px 28px;
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--md-sys-color-on-primary);
    background: var(--md-sys-color-primary);
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: background 200ms ease-out;
  }

  .submit-btn:hover:not(:disabled) {
    background: var(--md-sys-color-primary-container);
    color: var(--md-sys-color-on-primary-container);
  }

  .submit-btn:focus-visible {
    outline: 3px solid var(--md-sys-color-primary);
    outline-offset: 4px;
  }

  .submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .btn-loading {
    display: none;
  }

  .submit-btn.loading .btn-text {
    display: none;
  }

  .submit-btn.loading .btn-loading {
    display: inline;
  }

  .submit-btn.loading .arrow-icon {
    display: none;
  }

  /* ---- Feedback ---- */
  .feedback {
    margin-top: 16px;
    padding: 12px 16px;
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    text-align: center;
    border-radius: 8px;
    opacity: 0;
    transition: opacity 200ms ease-out;
  }

  .feedback.visible {
    opacity: 1;
  }

  .feedback.success {
    color: #047857;
    background: rgba(4, 120, 87, 0.08);
    border: 1px solid rgba(4, 120, 87, 0.2);
  }

  .feedback.error {
    color: #dc2626;
    background: rgba(220, 38, 38, 0.08);
    border: 1px solid rgba(220, 38, 38, 0.2);
  }

  /* ---- Responsive ---- */
  @media (max-width: 640px) {
    section {
      padding: 60px 0;
    }

    .beta-form {
      padding: 24px;
    }

    .form-row {
      grid-template-columns: 1fr;
    }

    h2 {
      font-size: 2rem;
    }
  }
</style>

<style is:global>
  /* ========================================
     BETA SIGNUP - Dark mode
     Warm orange palette (#FFB86F)
     ======================================== */

  html[data-theme="dark"] #beta {
    background: #0c0b09;
  }

  html[data-theme="dark"] #beta .eyebrow {
    color: #FFB86F;
  }

  html[data-theme="dark"] #beta h2 {
    color: #f5f0ea;
  }

  html[data-theme="dark"] #beta .section-desc {
    color: #d5c3b5;
  }

  /* Form card */
  html[data-theme="dark"] #beta .beta-form {
    background: #1a1815;
    border-color: rgba(255, 184, 111, 0.1);
  }

  html[data-theme="dark"] #beta label {
    color: #f5f0ea;
  }

  /* Inputs */
  html[data-theme="dark"] #beta input,
  html[data-theme="dark"] #beta textarea {
    background: rgba(255, 184, 111, 0.04);
    border-color: rgba(255, 184, 111, 0.12);
    color: #f5f0ea;
  }

  html[data-theme="dark"] #beta input:focus,
  html[data-theme="dark"] #beta textarea:focus {
    border-color: #FFB86F;
    box-shadow: 0 0 0 3px rgba(255, 184, 111, 0.1);
  }

  html[data-theme="dark"] #beta input::placeholder,
  html[data-theme="dark"] #beta textarea::placeholder {
    color: #a89a8c;
  }

  /* Submit */
  html[data-theme="dark"] #beta .submit-btn {
    background: #FFB86F;
    color: #1a1815;
  }

  html[data-theme="dark"] #beta .submit-btn:hover:not(:disabled) {
    background: #D4A574;
  }

  /* Feedback */
  html[data-theme="dark"] #beta .feedback.success {
    color: #6ee7b7;
    background: rgba(110, 231, 183, 0.08);
    border-color: rgba(110, 231, 183, 0.2);
  }

  html[data-theme="dark"] #beta .feedback.error {
    color: #fca5a5;
    background: rgba(252, 165, 165, 0.08);
    border-color: rgba(252, 165, 165, 0.2);
  }
</style>

<script>
  const betaForm = document.getElementById('beta-form') as HTMLFormElement | null;
  const betaFeedback = document.getElementById('beta-feedback') as HTMLParagraphElement | null;

  betaForm?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!betaForm || !betaFeedback) return;

    const formData = new FormData(betaForm);
    const name = formData.get('name') as string;
    const email = formData.get('email') as string;
    const message = formData.get('message') as string;
    const subject = formData.get('_subject') as string;

    if (!name || !email) return;

    const submitBtn = betaForm.querySelector('.submit-btn') as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.classList.add('loading');

    betaFeedback.classList.remove('visible', 'success', 'error');
    const lang = document.documentElement.lang;

    try {
      const response = await fetch('https://formspree.io/f/movnynen', {
        method: 'POST',
        body: JSON.stringify({ name, email, message, _subject: subject }),
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json',
        },
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.error || 'Submission failed');
      }

      betaFeedback.textContent = lang === 'fr'
        ? 'Vous etes sur la liste ! Nous vous contacterons bientot.'
        : lang === 'zh'
        ? '您已在列表中！我们会尽快联系您。'
        : 'You\'re on the list! We\'ll reach out soon.';
      betaFeedback.classList.add('visible', 'success');

      betaForm.reset();

      setTimeout(() => {
        betaFeedback.classList.remove('visible');
      }, 5000);
    } catch {
      betaFeedback.textContent = lang === 'fr'
        ? 'Une erreur est survenue. Veuillez reessayer.'
        : lang === 'zh'
        ? '出错了，请重试。'
        : 'Something went wrong. Please try again.';
      betaFeedback.classList.add('visible', 'error');

      setTimeout(() => {
        betaFeedback.classList.remove('visible');
      }, 5000);
    } finally {
      submitBtn.disabled = false;
      submitBtn.classList.remove('loading');
    }
  });
</script>
