/**
 * Intelligence Section - Collective Intelligence visualization
 *
 * Ported from Fresh IntelligenceSection.tsx + HyperGraphViz.tsx
 * 2-column grid: left content, right isometric 3D knowledge graph SVG
 *
 * @module features/pml-landing/Intelligence
 */

const locale = (Astro as any).currentLocale ?? 'en';

/* ------------------------------------------------------------------ */
/*  i18n                                                               */
/* ------------------------------------------------------------------ */

