---

<section class="py-32 bg-surface-container">
  <div class="max-w-6xl mx-auto px-4 md:px-6">
    <!-- Section Header -->
    <div class="text-center mb-20">
      <h2 class="text-headline-large text-on-surface mb-4" data-pricing-title>{t.title}</h2>
      <p class="text-title-medium text-on-surface-variant max-w-2xl mx-auto" data-pricing-subtitle>{t.subtitle}</p>
    </div>

    <!-- 2-Column Layout -->
    <div class="grid grid-cols-[400px_1fr] gap-10 md:grid-cols-1 md:gap-6">
      <!-- Left Column (Sticky) - Price & CTA -->
      <div class="pricing-sticky sticky top-[100px] h-fit">
        <div class="bg-surface-container-high rounded-3xl p-8 border-2 border-primary shadow-xs relative overflow-hidden">
          <!-- Gradient Top Border -->
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-primary via-secondary to-tertiary"></div>

          <!-- Beta Badge & Price -->
          <div class="text-center mb-10">
            <div class="inline-flex items-center gap-1.5 bg-primary text-on-primary px-4 py-2 rounded-full text-label-large font-medium mb-6">
              <span class="material-symbols-rounded text-[18px]">rocket_launch</span>
              {t.betaBadge}
            </div>
            <div class="flex items-baseline justify-center gap-2">
              <span class="text-[4rem] font-bold text-primary leading-none" data-pricing-price>{t.betaPrice}</span>
              <span class="text-title-large text-on-surface-variant">{t.perMonth}</span>
            </div>
          </div>

          <!-- Package Selection -->
          <div class="mb-8">
            <h3 class="flex items-center gap-2 text-title-large text-on-surface m-0 mb-4 font-semibold">
              <span class="material-symbols-rounded text-[24px] text-primary">category</span>
              {t.packagesTitle}
            </h3>
            <div class="flex flex-col gap-2">
              {t.packages.map((pkg, index) => (
                <label
                  class={`package-option flex items-center p-4 bg-surface border-2 rounded-2xl cursor-pointer transition-all duration-300 ${index === 0 ? 'selected border-primary bg-primary-container' : 'border-outline hover:border-primary hover:bg-primary-container'}`}
                  data-package={pkg.id}
                >
                  <input
                    type="radio"
                    name="package"
                    value={pkg.id}
                    checked={index === 0}
                    class="absolute opacity-0 pointer-events-none"
                  />
                  <div class="flex items-center gap-3 w-full">
                    <span class="material-symbols-rounded text-[24px] text-primary">{pkg.icon}</span>
                    <div class="flex-1">
                      <div class="text-body-large font-medium text-on-surface mb-0.5">{pkg.label}</div>
                      <div class="text-body-small text-on-surface-variant">{pkg.desc}</div>
                    </div>
                  </div>
                </label>
              ))}
            </div>
          </div>

          <!-- CTA Button -->
          <button class="w-full flex items-center justify-center gap-2 px-8 py-5 rounded-2xl text-title-medium font-medium cursor-pointer transition-all duration-300 mb-8 cta-button">
            <span class="material-symbols-rounded text-[20px]">stars</span>
            {t.ctaButton}
          </button>

          <!-- Trust Badges -->
          <div class="flex flex-col gap-3 md:flex-row md:justify-around md:flex-wrap">
            {t.trustBadges.map((badge) => (
              <div class="flex items-center gap-1.5 text-body-small text-on-surface-variant">
                <span class="material-symbols-rounded text-[16px] text-tertiary">{badge.icon}</span>
                <span>{badge.text}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Right Column (Scrollable) - Details -->
      <div class="bg-surface-container-high rounded-3xl p-8 border border-outline-variant shadow-xs">
        <!-- Features Section -->
        <div class="mb-8">
          <h3 class="flex items-center gap-2 text-title-large text-on-surface m-0 mb-4 font-semibold">
            <span class="material-symbols-rounded text-[24px] text-primary">check_circle</span>
            {t.includedTitle}
          </h3>
          <ul class="list-none p-0 m-0 flex flex-col gap-3 transition-all duration-300" data-features-list>
            {t.packageFeatures.marketing.map((feature, index) => (
              <li class="feature-item flex items-start gap-3 p-3 bg-surface rounded-2xl text-body-large text-on-surface opacity-0 transform -translate-x-2.5" style={`animation-delay: ${index * 50}ms`}>
                <span class="material-symbols-rounded text-[20px] text-primary flex-shrink-0 mt-0.5">check</span>
                <span>{feature}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Coming Soon Section -->
        <div class="mb-8">
          <h3 class="flex items-center gap-2 text-title-large text-on-surface m-0 mb-4 font-semibold">
            <span class="material-symbols-rounded text-[24px] text-secondary">upcoming</span>
            {t.comingSoonTitle}
          </h3>
          <ul class="list-none p-0 m-0 flex flex-col gap-3 transition-all duration-300">
            {t.comingSoonFeatures.map((feature, index) => (
              <li class="coming-soon-item flex items-start gap-3 p-3 bg-surface rounded-2xl text-body-large text-on-surface opacity-0 transform -translate-x-2.5" style={`animation-delay: ${index * 50}ms`}>
                <span class="material-symbols-rounded text-[20px] text-secondary flex-shrink-0 mt-0.5">schedule</span>
                <span>{feature}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Future Pricing Comparison -->
        <div class="bg-surface-variant rounded-2xl p-6 mb-8">
          <h4 class="text-title-medium text-on-surface m-0 mb-4 text-center font-semibold">{t.futurePricingTitle}</h4>
          <div class="flex flex-col gap-3">
            {t.futurePricing.map((item) => (
              <div class="flex justify-between items-center md:flex-col md:items-start md:gap-2 py-2">
                <span class="text-body-large text-on-surface">{item.name}</span>
                <div class="flex items-center gap-2 md:w-full md:justify-between">
                  <span class="text-body-medium text-on-surface-variant line-through">{item.future}</span>
                  <span class="text-on-surface-variant">→</span>
                  <span class="text-body-large font-semibold text-primary">{item.current}</span>
                  <span class="bg-tertiary-container text-on-tertiary-container px-2 py-1 rounded-full text-body-small font-medium">{locale === 'fr' ? 'Économisez' : 'Save'} {item.save}/mo</span>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- ROI Breakdown -->
        <div class="mt-8 pt-8 border-t border-outline-variant">
          <h3 class="flex items-center gap-2 text-title-large text-on-surface m-0 mb-4 font-semibold">
            <span class="material-symbols-rounded text-[24px] text-primary">trending_up</span>
            {t.roiTitle}
          </h3>
          <div class="grid grid-cols-1 md:grid-cols-[repeat(auto-fit,minmax(200px,1fr))] gap-4" data-roi-container>
            {t.roiItems.map((item, index) => (
              <div class="roi-card flex gap-3 p-4 bg-surface rounded-2xl opacity-0 transform translate-y-2.5" style={`animation-delay: ${index * 100}ms`}>
                <div class="flex items-center justify-center w-10 h-10 flex-shrink-0 bg-primary-container text-primary rounded-2xl">
                  <span class="material-symbols-rounded text-[20px]">{item.icon}</span>
                </div>
                <div class="flex-1">
                  <div class="text-label-medium text-on-surface-variant uppercase tracking-wider font-semibold mb-1">{item.label}</div>
                  <div class="text-headline-small text-primary font-semibold mb-1">{item.value}</div>
                  <div class="text-body-small text-on-surface-variant leading-relaxed">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Animation states for scroll-triggered animations */
  .feature-item,
  .coming-soon-item {
    opacity: 0;
    transform: translateX(-10px);
  }

  .feature-item.animate-in,
  .coming-soon-item.animate-in {
    opacity: 1;
    transform: translateX(0);
    transition: all 400ms var(--md-sys-motion-easing-emphasized);
  }

  .roi-card {
    opacity: 0;
    transform: translateY(10px);
  }

  .roi-card.animate-in {
    opacity: 1;
    transform: translateY(0);
    transition: all 400ms var(--md-sys-motion-easing-emphasized);
  }

  /* Package selection states */
  .package-option.selected {
    border-color: var(--md-sys-color-primary) !important;
    background-color: var(--md-sys-color-primary-container) !important;
  }
</style>

