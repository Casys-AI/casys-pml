        'Strategic Linking - Auto-links API docs to tutorials and learning paths',
        'Gap Detection - Identifies gaps in documentation coverage',
        'Learning Paths - Creates interconnected learning journeys',
        'Help Center - Knowledge base that stays current with product',
        'Ticket Reduction - Cuts support requests by 35%',
        'Your docs stay under your control',
        'Priority support <24h'
      ]
    }
  };

  // Package selection functionality
  function initPricing() {
    const packageOptions = document.querySelectorAll('.package-option');
    const featuresList = document.querySelector('[data-features-list]') as HTMLElement | null;
    const locale = document.documentElement.lang === 'fr' ? 'fr' : 'en';
    
    function updateFeatures(packageId: string) {
      if (!featuresList) return;
      
      const features = packageFeaturesData[locale][packageId as keyof typeof packageFeaturesData['en']];
      if (!features) return;

      // Fade out
      featuresList.style.opacity = '0';
      featuresList.style.transform = 'translateY(10px)';

      setTimeout(() => {
        // Update content
        featuresList.innerHTML = features.map((feature, index) => `
          <li class="feature-item animate-in" style="animation-delay: ${index * 50}ms">
            <span class="material-symbols-rounded">check</span>
            <span>${feature}</span>
          </li>
        `).join('');

        // Fade in
        setTimeout(() => {
          featuresList.style.opacity = '1';
          featuresList.style.transform = 'translateY(0)';
        }, 50);
      }, 300);
    }

    packageOptions.forEach((option) => {
      option.addEventListener('click', () => {
        // Remove selected from all
        packageOptions.forEach(opt => opt.classList.remove('selected'));
        // Add selected to clicked
        option.classList.add('selected');
        // Update radio
        const radio = option.querySelector('input[type="radio"]') as HTMLInputElement | null;
        if (radio) radio.checked = true;
        
        // Update features
        const packageId = option.getAttribute('data-package');
        if (packageId) {
          updateFeatures(packageId);
        }
      });
    });

    // Intersection Observer for animations
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const featureItems = entry.target.querySelectorAll('.feature-item');
            const comingSoonItems = entry.target.querySelectorAll('.coming-soon-item');
            const roiCards = entry.target.querySelectorAll('.roi-card');

            // Animate features
            featureItems.forEach((item, index) => {
              setTimeout(() => {
                item.classList.add('animate-in');
              }, index * 100);
            });

            // Animate coming soon items
            comingSoonItems.forEach((item, index) => {
              setTimeout(() => {
                item.classList.add('animate-in');
              }, index * 100 + 500);
            });

            // Animate ROI cards
            roiCards.forEach((card, index) => {
              setTimeout(() => {
                card.classList.add('animate-in');
              }, index * 100 + 1000);
            });

            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2, rootMargin: '-50px' }
    );

    // Observe the right column for animations
    const pricingSection = document.querySelector('section');
    if (pricingSection) {
      observer.observe(pricingSection);
    }
  }

  // Listen for segment changes
  function updatePricingForSegment(segment: string) {
    const locale = document.documentElement.lang === 'fr' ? 'fr' : 'en';
    const segmentData = segmentPricingData[segment as keyof typeof segmentPricingData];

    if (!segmentData) return;

    const data = segmentData[locale as keyof typeof segmentData];
    const priceElement = document.querySelector('[data-pricing-price]');
    const titleElement = document.querySelector('[data-pricing-title]');
    const subtitleElement = document.querySelector('[data-pricing-subtitle]');
    const roiCardsContainer = document.querySelector('[data-roi-container]');

    if (priceElement) priceElement.textContent = data.price;
    if (titleElement) titleElement.textContent = data.title;
    if (subtitleElement) subtitleElement.textContent = data.subtitle;

    if (roiCardsContainer) {
      roiCardsContainer.innerHTML = data.roiItems.map((item, index) => `
        <div class="roi-card animate-in" style="animation-delay: ${index * 100}ms">
          <div class="flex items-center justify-center w-10 h-10 flex-shrink-0 bg-primary-container text-primary rounded-2xl">
            <span class="material-symbols-rounded text-[20px]">${item.icon}</span>
          </div>
          <div class="flex-1">
            <div class="text-label-medium text-on-surface-variant uppercase tracking-wider font-semibold mb-1">${item.label}</div>
            <div class="text-headline-small text-primary font-semibold mb-1">${item.value}</div>
            <div class="text-body-small text-on-surface-variant leading-relaxed">${item.desc}</div>
          </div>
        </div>
      `).join('');
    }
  }

  // Listen for segment changes from SegmentSelector
  window.addEventListener('segment-changed', (event: any) => {
    updatePricingForSegment(event.detail.segment);
  });

  // Initialize on DOMContentLoaded
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPricing);
  } else {
    initPricing();
  }
</script>
