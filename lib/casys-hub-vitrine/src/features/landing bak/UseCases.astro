---
// i18n support
const locale = (Astro as any).currentLocale ?? 'en';

// Package data structure with Material icons
const packages = locale === 'fr'
  ? {
      marketing: {
        id: 'marketing',
        icon: 'campaign',
        title: 'Équipes Marketing',
        audience: 'CMOs, Growth Marketers, Agences de Contenu',
        features: [
          'Génère 20 articles/mois avec stratégie pilier/cluster',
          'Relie automatiquement à 3-5 articles existants par pièce',
          'Crée linking strategy qui renforce autorité Google',
          'Synchronise multicanal (WordPress, Medium, LinkedIn, Substack)'
        ],
        platforms: ['WordPress', 'Medium', 'Substack', 'LinkedIn'],
        perfectFor: [
          'Équipes qui lient manuellement 40 heures/mois',
          'CMOs qui cherchent +40-80% de trafic interne',
          'Équipes qui doivent prouver topical authority',
          'Agences qui veulent ajouter une différenciation unique'
        ],
        successMetric: 'Trafic interne: +40-80% | Temps économisé: 20h/semaine | Linking: automatisé',
        cta: 'Essayer pour Marketing'
      },
      product: {
        id: 'product',
        icon: 'shopping_cart',
        title: 'Équipes Product/E-commerce',
        audience: 'E-commerce Managers, Product Marketers, Marketplace Owners',
        features: [
          'Génère 100+ descriptions produits avec linking interne',
          'Crée pages catégories qui se relient entre elles',
          'Guide d\'achat comparatifs avec linking produit',
          'Détecte produits orphelins ou mal-liés'
        ],
        platforms: ['Shopify', 'WooCommerce', 'Webflow'],
        perfectFor: [
          'E-commerce avec 50+ produits difficiles à lier',
          'Marketplaces cherchant à réduire création contenu de 60%',
          'Teams cherchant +25-45% de trafic produit',
          'Propriétaires catalogues complexes avec gaps'
        ],
        successMetric: 'Trafic produit: +25-45% | Création contenu: -60% | Temps: réduit de 70%',
        cta: 'Essayer pour Product'
      },
      docs: {
        id: 'docs',
        icon: 'code',
        title: 'Équipes SaaS/DevRel',
        audience: 'Heads of Product, Équipes DevRel, Technical Writers',
        features: [
          'Génère guides liés à partir de vos examples de code',
          'Relie automatiquement API docs aux tutoriels',
          'Détecte gaps dans documentation',
          'Crée learning paths interconnectées'
        ],
        platforms: ['GitHub', 'GitBook', 'Confluence', 'ReadMe'],
        perfectFor: [
          'Équipes support surchargées (35%+ des tickets)',
          'DevRel qui prépare docs 70% plus lentement qu\'idéal',
          'Produits avec API changeant rapidement',
          'Équipes documentant code sans linking strategy'
        ],
        successMetric: 'Support tickets: -35% | Docs launch: 70% plus vite | Linking: stratégique',
        cta: 'Essayer pour Docs'
      }
    }
  : {
      marketing: {
        id: 'marketing',
        icon: 'campaign',
        title: 'Marketing Teams',
        audience: 'CMOs, Growth Marketers, Content Agencies',
        features: [
          'Generates 20 articles/month with pillar/cluster strategy',
          'Auto-links to 3-5 most relevant existing pieces per article',
          'Creates linking strategy that strengthens Google authority',
          'Syncs across channels (WordPress, Medium, LinkedIn, Substack)'
        ],
        platforms: ['WordPress', 'Medium', 'Substack', 'LinkedIn'],
        perfectFor: [
          'Teams manually linking 40 hours/month',
          'CMOs looking for +40-80% internal traffic',
          'Teams proving topical authority to competitors',
          'Agencies wanting to add unique differentiation'
        ],
        successMetric: 'Internal traffic: +40-80% | Time saved: 20h/week | Linking: fully automated',
        cta: 'Try for Marketing'
      },
      product: {
        id: 'product',
        icon: 'shopping_cart',
        title: 'Product/E-commerce Teams',
        audience: 'E-commerce Managers, Product Marketers, Marketplace Owners',
        features: [
          'Generates 100+ product descriptions with internal linking',
          'Creates category pages that link to each other',
          'Comparative buying guides with product linking',
          'Detects orphaned or poorly-linked products'
        ],
        platforms: ['Shopify', 'WooCommerce', 'Webflow'],
        perfectFor: [
          'E-commerce with 50+ products hard to interconnect',
          'Marketplaces cutting content creation 60%',
          'Teams looking for +25-45% product page traffic',
          'Catalog owners with complex gaps'
        ],
        successMetric: 'Product traffic: +25-45% | Content creation: -60% | Time: reduced 70%',
        cta: 'Try for Product'
      },
      docs: {
        id: 'docs',
        icon: 'code',
        title: 'SaaS/DevRel Teams',
        audience: 'Heads of Product, DevRel Teams, Technical Writers',
        features: [
          'Generates linked guides from your code examples',
          'Auto-links API docs to tutorials and learning paths',
          'Detects gaps in documentation',
          'Creates interconnected learning journeys'
        ],
        platforms: ['GitHub', 'GitBook', 'Confluence', 'ReadMe'],
        perfectFor: [
          'Support teams drowning in tickets (35%+ of load)',
          'DevRel preparing docs 70% slower than needed',
          'Products with rapidly changing APIs',
          'Teams documenting code without linking strategy'
        ],
        successMetric: 'Support tickets: -35% | Docs launch: 70% faster | Linking: fully strategic',
        cta: 'Try for Docs'
      }
    };

const sectionTitle = locale === 'fr' ? 'Cas d\'Usage' : 'Use Cases';
const sectionSubtitle = locale === 'fr'
  ? 'Chaque équipe bénéficie de l\'automatisation de linking et de stratégie'
  : 'Every team benefits from automated linking and strategy execution';
---

<section class="py-32 bg-surface-container">
  <div class="max-w-6xl mx-auto px-4 md:px-6">
    <!-- Section Header -->
    <div class="text-center mb-20">
      <h2 class="text-headline-large text-on-surface mb-4">{sectionTitle}</h2>
      <p class="text-title-medium text-on-surface-variant max-w-2xl mx-auto">{sectionSubtitle}</p>
    </div>

    <!-- Material Tabs -->
    <div class="sticky top-5 z-10 mb-10 md:mb-12 transition-all duration-300">
      <div class="flex bg-surface-container-high rounded-3xl p-1 relative shadow-sm">
        {Object.values(packages).map((pkg, index) => (
          <button
            class={`tab-button flex flex-1 items-center justify-center gap-2 px-4 md:px-6 py-4 rounded-2xl cursor-pointer transition-all duration-300 text-label-large font-medium ${index === 0 ? 'active bg-primary text-on-primary' : 'text-on-surface-variant'}`}
            data-tab={pkg.id}
          >
            <span class="material-symbols-rounded text-[20px]">{pkg.icon}</span>
            <span class="hidden sm:inline">{pkg.title.split(' ')[1]}</span>
          </button>
        ))}
      </div>
    </div>

    <!-- Content Cards -->
    <div class="content-container relative min-h-96 md:min-h-[600px]">
      {Object.values(packages).map((pkg, index) => (
        <div
          class={`package-card bg-surface-container-high rounded-3xl p-6 md:p-10 shadow-xs absolute top-0 left-0 w-full opacity-0 transform translate-y-5 transition-all duration-400 ${index === 0 ? 'active opacity-100 translate-y-0 relative' : ''}`}
          data-package={pkg.id}
        >
          <!-- Card Header -->
          <div class="flex items-center gap-5 md:gap-6 mb-8">
            <div class="flex items-center justify-center w-16 h-16 flex-shrink-0 bg-primary-container text-primary rounded-2xl">
              <span class="material-symbols-rounded text-[32px]">{pkg.icon}</span>
            </div>
            <div class="flex-1">
              <h3 class="text-headline-medium text-on-surface m-0 mb-2">{pkg.title}</h3>
              <p class="text-body-large text-on-surface-variant m-0">{pkg.audience}</p>
            </div>
          </div>

          <!-- Features Section -->
          <div class="mb-8">
            <h4 class="flex items-center gap-3 text-title-large text-on-surface m-0 mb-4 font-semibold">
              <span class="material-symbols-rounded text-[24px] text-primary">check_circle</span>
              {locale === 'fr' ? 'Fonctionnalités' : 'Features'}
            </h4>
            <ul class="list-none p-0 m-0 flex flex-col gap-3">
              {pkg.features.map((feature) => (
                <li class="flex items-start gap-3 p-3 bg-surface rounded-2xl text-body-large text-on-surface">
                  <span class="material-symbols-rounded text-[20px] text-primary flex-shrink-0 mt-0.5">check</span>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Platforms Section -->
          <div class="mb-8">
            <h4 class="flex items-center gap-3 text-title-large text-on-surface m-0 mb-4 font-semibold">
              <span class="material-symbols-rounded text-[24px] text-primary">cloud_upload</span>
              {locale === 'fr' ? 'Plateformes' : 'Platforms'}
            </h4>
            <div class="flex flex-wrap gap-2">
              {pkg.platforms.map((platform) => (
                <span class="inline-flex items-center px-4 py-2 bg-tertiary-container text-on-tertiary-container rounded-full text-label-large font-medium">
                  {platform}
                </span>
              ))}
            </div>
          </div>

          <!-- Perfect For Section -->
          <div class="mb-8">
            <h4 class="flex items-center gap-3 text-title-large text-on-surface m-0 mb-4 font-semibold">
              <span class="material-symbols-rounded text-[24px] text-primary">groups</span>
              {locale === 'fr' ? 'Parfait pour' : 'Perfect For'}
            </h4>
            <ul class="list-none p-0 m-0 flex flex-col gap-3">
              {pkg.perfectFor.map((item) => (
                <li class="flex items-start gap-3 p-3 bg-surface rounded-2xl text-body-large text-on-surface">
                  <span class="material-symbols-rounded text-[20px] text-primary flex-shrink-0 mt-0.5">person</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Success Metrics -->
          <div class="bg-surface rounded-2xl p-6 mb-8 border border-outline-variant">
            <div class="flex items-center gap-3 mb-3">
              <span class="material-symbols-rounded text-[24px] text-tertiary">trending_up</span>
              <h4 class="text-title-large text-on-surface m-0 font-semibold">{locale === 'fr' ? 'Résultats Typiques' : 'Typical Results'}</h4>
            </div>
            <p class="text-body-large text-on-surface-variant m-0 leading-relaxed">{pkg.successMetric}</p>
          </div>

          <!-- CTA Button -->
          <div class="text-center">
            <button class="inline-flex items-center gap-2 px-8 py-4 rounded-full text-label-large font-medium cursor-pointer transition-all duration-300 cta-button">
              <span class="material-symbols-rounded text-[20px]">rocket_launch</span>
              {pkg.cta}
            </button>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Tab switching animation states */
  .package-card {
    opacity: 0;
    transform: translateY(20px);
  }

  .package-card.active {
    opacity: 1;
    transform: translateY(0);
    position: relative;
  }

  /* Tab button active state (for JS-managed switching) */
  .tab-button {
    background: transparent;
    border: none;
  }

  .tab-button.active {
    background: var(--md-sys-color-primary) !important;
    color: var(--md-sys-color-on-primary) !important;
  }
</style>

<script>
  // Tab functionality
  function initUseCasesTabs() {
    const tabButtons = document.querySelectorAll('.tab-button');
    const packageCards = document.querySelectorAll('.package-card');

    if (!tabButtons.length || !packageCards.length) {
      return;
    }

    // Tab switching logic
    tabButtons.forEach((button, index) => {
      button.addEventListener('click', () => {
        const targetTab = button.getAttribute('data-tab');

        // Update tab states
        tabButtons.forEach(btn => btn.classList.remove('active'));
        button.classList.add('active');

        // Update card states
        packageCards.forEach(card => card.classList.remove('active'));

        const targetCard = document.querySelector(`[data-package="${targetTab}"]`);
        if (targetCard) {
          targetCard.classList.add('active');
        }
      });
    });
  }

  // Initialize on DOMContentLoaded
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initUseCasesTabs);
  } else {
    initUseCasesTabs();
  }
</script>
