---
const locale = (Astro as any).currentLocale ?? 'en';

// Segment-specific hero messaging
const heroContent = {
  teams: {
    fr: {
      title: 'Votre Équipe Crée Plus Vite',
      titleHighlight: 'Que Jamais',
      subtitle: 'Linking automatisé. 20 heures/mois économisées par personne. Collaboration fluide.',
      trustBadge: 'Analyse Gratuite · Pas de Carte Bancaire · Résultats Immédiats',
      formPlaceholder: 'Entrez votre domaine (ex: stripe.com)',
      formButton: 'Voir Mon Écosystème',
      previewTitle: 'Vous découvrirez:',
      previewItems: [
        '20 heures/semaine économisées (zéro linking manuel)',
        'Collaboration simplifiée entre équipes',
        '+40-80% trafic interne automatique'
      ]
    },
    en: {
      title: 'Your Team Creates Better',
      titleHighlight: 'Than Ever',
      subtitle: 'Automatic linking. 20 hours/person/month saved. Seamless collaboration.',
      trustBadge: 'Free Analysis · No Credit Card · Instant Results',
      formPlaceholder: 'Enter your domain (e.g. stripe.com)',
      formButton: 'See My Ecosystem',
      previewTitle: 'You\'ll discover:',
      previewItems: [
        '20 hours/week saved (zero manual linking)',
        'Simplified team collaboration',
        '+40-80% automatic internal traffic'
      ]
    }
  },
  agencies: {
    fr: {
      title: 'Livrez Plus de Projets',
      titleHighlight: 'Sans Plus de Coûts',
      subtitle: 'Facturez $700-1300/mois par client. Un seul prix pour clients illimités.',
      trustBadge: 'Clients Illimités · 30-40% Marge · Marque Blanche Bientôt',
      formPlaceholder: 'Entrez votre domaine agence (ex: agency.com)',
      formButton: 'Estimer Mon Revenu',
      previewTitle: 'Vous économiserez:',
      previewItems: [
        '40+ heures/projet de travail manuel',
        'Marge 30-40% par client',
        'Infinite scaling (clients illimités, prix fixe)'
      ]
    },
    en: {
      title: 'Deliver More Projects',
      titleHighlight: 'At Fixed Cost',
      subtitle: 'Bill clients $700-$1,300/month. One fixed price for unlimited clients.',
      trustBadge: 'Unlimited Clients · 30-40% Margin · White-Label Coming',
      formPlaceholder: 'Enter your agency domain (e.g. agency.com)',
      formButton: 'Estimate My Revenue',
      previewTitle: 'You\'ll save:',
      previewItems: [
        '40+ manual hours per project',
        '30-40% margin per client',
        'Infinite scaling (unlimited clients, fixed price)'
      ]
    }
  }
};

const t = locale === 'fr'
  ? heroContent.teams.fr
  : heroContent.teams.en;
---

<section class="hero-section relative overflow-hidden bg-surface">
  <!-- Background pattern -->
  <div class="bg-pattern absolute inset-0 z-0 opacity-5 pointer-events-none" aria-hidden="true"></div>

  <div class="max-w-5xl mx-auto px-6 relative z-10 py-20 min-h-screen flex flex-col justify-center gap-16">
    <!-- Hero Content -->
    <div class="text-center space-y-6">
      <!-- Title -->
      <h1 class="hero-title font-black text-on-surface">
        {t.title}
        <br />
        <span class="gradient-text inline-block">{t.titleHighlight}</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-lg text-on-surface-variant max-w-2xl mx-auto leading-relaxed">
        {t.subtitle}
      </p>
    </div>

    <!-- Form Container -->
    <div class="bg-surface-container-high rounded-3xl p-10 sm:p-12 shadow-elevation-1">
      <form id="hero-form" class="space-y-6">
        <div class="hero-form-group">
          <input
            id="domain-input"
            type="text"
            placeholder={t.formPlaceholder}
            aria-label="Domain"
          />
          <button type="submit" class="submit-btn">
            <span class="btn-text">{t.formButton}</span>
            <span class="btn-loading hidden">⏳</span>
            <svg class="w-5 h-5" viewBox="0 0 20 20" fill="none">
              <path d="M7 10h10M14 7l3 3-3 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>

        <p id="feedback" class="min-h-6 text-center text-sm text-on-surface-variant"></p>
      </form>
    </div>

    <!-- Preview Section -->
    <div class="space-y-10">
      <div class="text-center">
        <h3 class="text-2xl font-bold text-on-surface">
          {t.previewTitle}
        </h3>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {t.previewItems.map((item, index) => (
          <div
            class="preview-item flex flex-col gap-4 p-8 rounded-2xl bg-surface-container shadow-elevation-0 hover:shadow-elevation-1 transition-shadow"
            style={{
              animationDelay: `${index * 150}ms`,
            }}
          >
            <span class="flex items-center justify-center w-12 h-12 rounded-lg bg-primary-container text-primary flex-shrink-0">
              <svg width="24" height="24" viewBox="0 0 20 20" fill="none">
                <path d="M8 10l2 2 4-4" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span class="text-base text-on-surface font-medium">
              {item}
            </span>
          </div>
        ))}
      </div>

      <!-- Trust Badge -->
      <div class="flex justify-center pt-4">
        <div class="flex items-center gap-4 px-8 py-4 rounded-full bg-primary-container text-on-primary-container text-sm font-semibold shadow-elevation-1">
          <div class="flex items-center justify-center w-6 h-6 rounded-full bg-primary text-on-primary">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M13.5 4L6 11.5L2.5 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <span>{t.trustBadge}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Segment-specific content for dynamic updates
  const heroSegmentContent = {
    teams: {
      fr: {
        title: 'Votre Équipe Crée Plus Vite',
        titleHighlight: 'Que Jamais',
        subtitle: 'Linking automatisé. 20 heures/mois économisées par personne. Collaboration fluide.',
        formPlaceholder: 'Entrez votre domaine (ex: stripe.com)',
        formButton: 'Voir Mon Écosystème',
        previewTitle: 'Vous découvrirez:',
        previewItems: [
          '20 heures/semaine économisées (zéro linking manuel)',
          'Collaboration simplifiée entre équipes',
          '+40-80% trafic interne automatique'
        ],
        trustBadge: 'Analyse Gratuite · Pas de Carte Bancaire · Résultats Immédiats'
      },
      en: {
        title: 'Your Team Creates Better',
        titleHighlight: 'Than Ever',
        subtitle: 'Automatic linking. 20 hours/person/month saved. Seamless collaboration.',
        formPlaceholder: 'Enter your domain (e.g. stripe.com)',
        formButton: 'See My Ecosystem',
        previewTitle: 'You\'ll discover:',
        previewItems: [
          '20 hours/week saved (zero manual linking)',
          'Simplified team collaboration',
          '+40-80% automatic internal traffic'
        ],
        trustBadge: 'Free Analysis · No Credit Card · Instant Results'
      }
    },
    agencies: {
      fr: {
        title: 'Livrez Plus de Projets',
        titleHighlight: 'Sans Plus de Coûts',
        subtitle: 'Facturez $700-1300/mois par client. Un seul prix pour clients illimités.',
        formPlaceholder: 'Entrez votre domaine agence (ex: agency.com)',
        formButton: 'Estimer Mon Revenu',
        previewTitle: 'Vous économiserez:',
        previewItems: [
          '40+ heures/projet de travail manuel',
          'Marge 30-40% par client',
          'Infinite scaling (clients illimités, prix fixe)'
        ],
        trustBadge: 'Clients Illimités · 30-40% Marge · Marque Blanche Bientôt'
      },
      en: {
        title: 'Deliver More Projects',
        titleHighlight: 'At Fixed Cost',
        subtitle: 'Bill clients $700-$1,300/month. One fixed price for unlimited clients.',
        formPlaceholder: 'Enter your agency domain (e.g. agency.com)',
        formButton: 'Estimate My Revenue',
        previewTitle: 'You\'ll save:',
        previewItems: [
          '40+ manual hours per project',
          '30-40% margin per client',
          'Infinite scaling (unlimited clients, fixed price)'
        ],
        trustBadge: 'Unlimited Clients · 30-40% Margin · White-Label Coming'
      }
    }
  };

  // Update Hero content for segment
  function updateHeroForSegment(segment: string) {
    const locale = document.documentElement.lang === 'fr' ? 'fr' : 'en';
    const segmentData = heroSegmentContent[segment as keyof typeof heroSegmentContent];

    if (!segmentData) return;

    const data = segmentData[locale as keyof typeof segmentData];
    const titleEl = document.querySelector('h1');
    const titleHighlightEl = document.querySelector('h1 .gradient-text');
    const subtitleEl = document.querySelector('.text-headline-small');
    const formInput = document.getElementById('domain-input') as HTMLInputElement | null;
    const formButton = document.querySelector('.submit-btn .btn-text');
    const previewTitle = document.querySelector('.preview-section h3');
    const previewItems = document.querySelectorAll('.preview-item');
    const trustBadge = document.querySelector('.inline-flex.items-center.gap-3');

    // Update text content with fade effect
    if (titleEl && titleHighlightEl) {
      titleEl.style.opacity = '0';
      setTimeout(() => {
        const titleText = titleEl.textContent || '';
        const titleParts = titleText.split(titleHighlightEl.textContent || '');
        titleEl.innerHTML = `${titleParts[0]}<br /><span class="gradient-text inline-block">${data.titleHighlight}</span>`;
        titleEl.style.opacity = '1';
      }, 300);
    }

    if (subtitleEl) {
      subtitleEl.style.opacity = '0';
      setTimeout(() => {
        subtitleEl.textContent = data.subtitle;
        subtitleEl.style.opacity = '1';
      }, 300);
    }

    if (formInput) formInput.placeholder = data.formPlaceholder;
    if (formButton) formButton.textContent = data.formButton;
    if (previewTitle) previewTitle.textContent = data.previewTitle;

    // Update preview items
    if (previewItems.length > 0) {
      previewItems.forEach((item, index) => {
        const span = item.querySelector('.text-body-medium');
        if (span && data.previewItems[index]) {
          span.textContent = data.previewItems[index];
        }
      });
    }

    if (trustBadge) {
      const badgeText = trustBadge.querySelector('span');
      if (badgeText) badgeText.textContent = data.trustBadge;
    }
  }

  // Listen for segment changes
  window.addEventListener('segment-changed', (event: any) => {
    updateHeroForSegment(event.detail.segment);
  });

  // Animate preview items on page load
  function initPreviewAnimation() {
    const previewItems = document.querySelectorAll('.preview-item');

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            previewItems.forEach((item, index) => {
              setTimeout(() => {
                item.classList.add('animate-in');
              }, index * 150);
            });
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.3 }
    );

    const section = document.querySelector('.preview-section');
    if (section) {
      observer.observe(section);
    }
  }

  // Form submission logic
  const form = document.getElementById('hero-form') as HTMLFormElement | null;
  const input = document.getElementById('domain-input') as HTMLInputElement | null;
  const feedback = document.getElementById('feedback') as HTMLParagraphElement | null;

  form?.addEventListener('submit', async (e) => {
    if (!input || !feedback) return;
    e.preventDefault();

    const domain = input.value.trim().toLowerCase().replace(/^(https?:\/\/)?(www\.)?/, '');

    if (!domain || !domain.includes('.')) {
      feedback.setAttribute('data-state', 'error');
      feedback.textContent = 'Please enter a valid domain';
      return;
    }

    input.disabled = true;
    const btn = form.querySelector('button.submit-btn') as HTMLButtonElement | null;
    if (!btn) return;

    // Simple DOM manipulation to toggle loading state
    const btnText = btn.querySelector('.btn-text') as HTMLElement | null;
    const btnLoading = btn.querySelector('.btn-loading') as HTMLElement | null;
    const btnIcon = btn.querySelector('svg') as SVGElement | null;

    if (btnText) btnText.style.display = 'none';
    if (btnLoading) btnLoading.style.display = 'inline';
    if (btnIcon) btnIcon.style.display = 'none';
    btn.disabled = true;

    feedback.setAttribute('data-state', 'loading');
    feedback.textContent = 'Analyzing your site...';

    try {
      const response = await fetch('/api/lead/start', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ domain })
      });

      const data = await response.json();

      if (!response.ok || !data.success) {
        throw new Error(data.error || 'Analysis failed');
      }

      feedback.setAttribute('data-state', 'success');
      feedback.textContent = 'Analysis complete! Redirecting...';

      setTimeout(() => {
        window.location.href = data.redirectUrl;
      }, 800);

    } catch (error) {
      input.disabled = false;
      btn.disabled = false;
      if (btnText) btnText.style.display = 'inline';
      if (btnLoading) btnLoading.style.display = 'none';
      if (btnIcon) btnIcon.style.display = 'inline';

      feedback.setAttribute('data-state', 'error');
      feedback.textContent = (error as Error).message || 'Failed to start analysis';
    }
  });

  // Initialize animations
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPreviewAnimation);
  } else {
    initPreviewAnimation();
  }
</script>
