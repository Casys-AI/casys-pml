---
// Segment selector for Teams vs Agencies messaging
export interface Props {
  defaultSegment?: 'teams' | 'agencies';
}

const { defaultSegment = 'teams' } = Astro.props;
---

<div class="segment-selector-wrapper bg-surface border-b border-outline-variant/20">
  <!-- Segment Toggle Slider Ribbon - Full Width -->
  <div class="segment-toggle-container w-full h-full">
    <div class="segment-slider relative bg-surface-container p-1 shadow-elevation-1 flex w-full h-full">
      <!-- Animated Background Indicator -->
      <div
        class="segment-indicator absolute top-1 bottom-1 shadow-elevation-1 transition-all duration-500 ease-out rounded-xl"
        data-segment={defaultSegment}
        style={defaultSegment === 'teams'
          ? { left: '0.25rem', right: '50%' }
          : { left: '50%', right: '0.25rem' }
        }
      ></div>

      <!-- Toggle Buttons -->
      <div class="relative flex z-10 w-full">
        <button
          class="segment-button segment-button-teams flex-1 flex items-center justify-center gap-2 font-semibold transition-colors duration-300 py-3"
          data-segment="teams"
          style={{
            color: defaultSegment === 'teams'
              ? '#ffffff'
              : 'var(--md-sys-color-outline)'
          }}
        >
          <span class="text-lg">📊</span>
          <span class="hidden sm:inline text-sm">Teams</span>
        </button>

        <button
          class="segment-button segment-button-agencies flex-1 flex items-center justify-center gap-2 font-semibold transition-colors duration-300 py-3"
          data-segment="agencies"
          style={{
            color: defaultSegment === 'agencies'
              ? '#ffffff'
              : 'var(--md-sys-color-outline)'
          }}
        >
          <span class="text-lg">🏢</span>
          <span class="hidden sm:inline text-sm">Agencies</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Hidden segment display showing current selection -->
  <div class="hidden" id="current-segment" data-segment={defaultSegment}></div>
</div>

<script>
  // Segment selection logic
  const selector = document.getElementById('current-segment');
  const buttons = document.querySelectorAll('.segment-button');
  const indicator = document.querySelector('.segment-indicator');
  const slider = document.querySelector('.segment-slider');

  if (selector && buttons && indicator) {
    let currentSegment = selector.getAttribute('data-segment') || 'teams';
    let isDragging = false;
    let dragStart = 0;

    // Store segment in session storage
    sessionStorage.setItem('casys-segment', currentSegment);

    const updateSegment = (segment: string) => {
      currentSegment = segment;
      sessionStorage.setItem('casys-segment', segment);

      // Update indicator position with animation
      if (segment === 'teams') {
        indicator.style.left = '0.25rem';
        indicator.style.right = '50%';
      } else {
        indicator.style.left = '50%';
        indicator.style.right = '0.25rem';
      }
      indicator.setAttribute('data-segment', segment);

      // Update button text colors
      buttons.forEach(btn => {
        const isActive = btn.getAttribute('data-segment') === segment;

        if (isActive) {
          btn.style.color = '#ffffff';
        } else {
          btn.style.color = 'var(--md-sys-color-outline)';
        }
      });

      // Dispatch custom event for listening components
      window.dispatchEvent(new CustomEvent('segment-changed', { detail: { segment } }));

      // Scroll to relevant section
      const pricingSection = document.getElementById('pricing-section');
      if (pricingSection) {
        pricingSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    };

    // Click handlers
    buttons.forEach(button => {
      button.addEventListener('click', () => {
        const segment = button.getAttribute('data-segment');
        if (segment) {
          updateSegment(segment);
        }
      });
    });

    // Drag handlers for swipe interaction
    slider?.addEventListener('mousedown', (e) => {
      isDragging = true;
      dragStart = (e as MouseEvent).clientX;
    });

    slider?.addEventListener('touchstart', (e) => {
      isDragging = true;
      dragStart = (e as TouchEvent).touches[0].clientX;
    });

    document.addEventListener('mouseup', (e) => {
      if (!isDragging || !slider) return;
      isDragging = false;

      const dragEnd = (e as MouseEvent).clientX;
      const dragDistance = dragEnd - dragStart;
      const sliderWidth = slider.offsetWidth;

      // Swipe left (more than 30px) = switch to agencies
      if (dragDistance < -30 && currentSegment === 'teams') {
        updateSegment('agencies');
      }
      // Swipe right (more than 30px) = switch to teams
      else if (dragDistance > 30 && currentSegment === 'agencies') {
        updateSegment('teams');
      }
    });

    document.addEventListener('touchend', (e) => {
      if (!isDragging || !slider) return;
      isDragging = false;

      const dragEnd = (e as TouchEvent).changedTouches[0].clientX;
      const dragDistance = dragEnd - dragStart;

      // Swipe left = switch to agencies
      if (dragDistance < -30 && currentSegment === 'teams') {
        updateSegment('agencies');
      }
      // Swipe right = switch to teams
      else if (dragDistance > 30 && currentSegment === 'agencies') {
        updateSegment('teams');
      }
    });
  }
</script>

