---

<section class="py-32 bg-surface">
  <div class="max-w-4xl mx-auto px-4 md:px-6">
    <!-- Section Header -->
    <div class="text-center mb-20">
      <h2 class="text-headline-large text-on-surface mb-4">{t.title}</h2>
      <p class="text-title-medium text-on-surface-variant max-w-2xl mx-auto">{t.subtitle}</p>
    </div>

    <!-- FAQ Accordion -->
    <div class="flex flex-col gap-3 md:gap-4">
      {faqs.map((faq, index) => (
        <div
          class={`faq-item bg-surface-container-high rounded-2xl overflow-hidden transition-all duration-300 opacity-0 transform translate-y-5 hover:shadow-md cursor-pointer ${index === 0 ? 'expanded' : ''}`}
          data-index={index}
          style={`animation-delay: ${index * 100}ms`}
        >
          <!-- Question Header -->
          <button class="question-header flex items-center justify-between w-full px-5 md:px-6 py-5 md:py-6 bg-transparent border-0 cursor-pointer text-left transition-all duration-300 hover:bg-surface-variant">
            <span class="question-text text-body-large md:text-title-medium text-on-surface flex-1 pr-3 md:pr-4">{faq.question}</span>
            <span class="expand-icon flex items-center justify-center w-8 h-8 bg-secondary-container text-on-secondary-container rounded-full transition-all duration-300 flex-shrink-0">
              <span class="material-symbols-rounded text-[20px]">expand_more</span>
            </span>
          </button>

          <!-- Answer Content -->
          <div class="answer-content max-h-0 overflow-hidden transition-all duration-400">
            <p class="text-body-medium md:text-body-large text-on-surface-variant leading-normal px-5 md:px-6 pb-5 md:pb-6">{faq.answer}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Expanded state styles */
  .faq-item.expanded {
    background: var(--md-sys-color-primary-container);
  }

  .faq-item.expanded .question-header:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .faq-item.expanded .question-text {
    color: var(--md-sys-color-on-primary-container);
    font-weight: 600;
  }

  .faq-item.expanded .expand-icon {
    background: var(--md-sys-color-on-primary-container);
    color: var(--md-sys-color-primary-container);
    transform: rotate(180deg);
  }

  .faq-item.expanded .answer-content {
    max-height: 500px;
  }

  .faq-item.expanded .answer-content p {
    color: var(--md-sys-color-on-primary-container);
  }
</style>

<script>
  function initFAQ() {
    const faqItems = document.querySelectorAll('.faq-item');
    
    // Intersection Observer for animations
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('animate-in');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2, rootMargin: '-50px' }
    );

    // Observe each FAQ item
    faqItems.forEach(item => observer.observe(item));

    // Click handlers for accordion behavior
    faqItems.forEach((item) => {
      const header = item.querySelector('.question-header');
      
      header?.addEventListener('click', () => {
        const isExpanded = item.classList.contains('expanded');

        // Close all other items (accordion behavior)
        faqItems.forEach((otherItem) => {
          if (otherItem !== item) {
            otherItem.classList.remove('expanded');
          }
        });

        // Toggle current item
        if (isExpanded) {
          item.classList.remove('expanded');
        } else {
          item.classList.add('expanded');

          // Smooth scroll to item if needed
          setTimeout(() => {
            const itemTop = item.getBoundingClientRect().top + window.scrollY;
            const offset = 100;
            if (window.scrollY > itemTop - offset) {
              window.scrollTo({
                top: itemTop - offset,
                behavior: 'smooth'
              });
            }
          }, 300);
        }
      });
    });
  }

  // Initialize on DOMContentLoaded
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFAQ);
  } else {
    initFAQ();
  }
</script>
