---
const locale = (Astro as any).currentLocale ?? 'en';

const translations = {
  en: {
    title: 'Part of the',
    titleAccent: 'PML Ecosystem',
    subtitle: 'The engine runs inside PML. Self-hosted, open source, no external API calls.',
    jsrLabel: 'JSR',
    githubLabel: 'GitHub',
    docsLabel: 'Docs',
    pmlLabel: 'PML',
    builtWith: 'Built with',
  },
  fr: {
    title: 'Partie de',
    titleAccent: 'l\'Ecosysteme PML',
    subtitle: 'Le moteur tourne dans PML. Auto-heberge, open source, aucun appel API externe.',
    jsrLabel: 'JSR',
    githubLabel: 'GitHub',
    docsLabel: 'Docs',
    pmlLabel: 'PML',
    builtWith: 'Construit avec',
  },
  zh: {
    title: 'Part of the',
    titleAccent: 'PML Ecosystem',
    subtitle: 'The engine runs inside PML. Self-hosted, open source, no external API calls.',
    jsrLabel: 'JSR',
    githubLabel: 'GitHub',
    docsLabel: 'Docs',
    pmlLabel: 'PML',
    builtWith: 'Built with',
  },
} as const;
const t = translations[locale as keyof typeof translations] ?? translations.en;
---

<section id="links">
  <div class="container">
    <div class="links-content">
      <h2>{t.title} <span class="accent-text">{t.titleAccent}</span></h2>
      <p class="section-subtitle">{t.subtitle}</p>

      <div class="links-commands">
        <div class="links-row">
          <span class="links-runtime">Deno</span>
          <div class="links-cmd">
            <code>deno add jsr:@casys/shgat</code>
            <button class="copy-btn" aria-label="Copy Deno install command" data-copy="deno add jsr:@casys/shgat">
              <span class="material-symbols-rounded">content_copy</span>
            </button>
          </div>
        </div>
        <div class="links-row">
          <span class="links-runtime">npm</span>
          <div class="links-cmd">
            <code>npx jsr add @casys/shgat</code>
            <button class="copy-btn" aria-label="Copy npm install command" data-copy="npx jsr add @casys/shgat">
              <span class="material-symbols-rounded">content_copy</span>
            </button>
          </div>
        </div>
      </div>

      <div class="links-buttons">
        <a href="https://jsr.io/@casys/shgat" class="links-link" target="_blank" rel="noopener noreferrer">
          <span class="material-symbols-rounded">package_2</span>
          <span>{t.jsrLabel}</span>
          <span class="material-symbols-rounded link-arrow">arrow_outward</span>
        </a>
        <a href="https://github.com/Casys-AI/shgat" class="links-link" target="_blank" rel="noopener noreferrer">
          <span class="material-symbols-rounded">code</span>
          <span>{t.githubLabel}</span>
          <span class="material-symbols-rounded link-arrow">arrow_outward</span>
        </a>
        <a href="/docs/shgat/introduction/" class="links-link">
          <span class="material-symbols-rounded">menu_book</span>
          <span>{t.docsLabel}</span>
          <span class="material-symbols-rounded link-arrow">arrow_outward</span>
        </a>
        <a href="/pml" class="links-link">
          <span class="material-symbols-rounded">description</span>
          <span>{t.pmlLabel}</span>
          <span class="material-symbols-rounded link-arrow">arrow_outward</span>
        </a>
      </div>

      <div class="built-with">
        <span class="built-label">{t.builtWith}</span>
        <a href="https://deno.land" class="tech-badge" target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 512 512" fill="currentColor" aria-hidden="true">
            <path d="M256 0C114.6 0 0 114.6 0 256s114.6 256 256 256 256-114.6 256-256S397.4 0 256 0zm-52.7 394.3c-14.3 0-27.3-5.8-36.7-15.2-9.4-9.4-15.2-22.4-15.2-36.7 0-28.6 23.2-51.9 51.9-51.9 28.6 0 51.9 23.2 51.9 51.9 0 28.7-23.2 51.9-51.9 51.9zM361 316.8c-5.3 8.1-14.4 13.5-24.8 13.5-16.3 0-29.6-13.3-29.6-29.6 0-10.3 5.3-19.4 13.3-24.7l89.2-140.2c2.2-3.5 6-5.8 10.3-5.8 6.7 0 12.2 5.4 12.2 12.2 0 2.2-.6 4.2-1.6 6L361 316.8z"/>
          </svg>
          <span>Deno</span>
        </a>
        <span class="separator" aria-hidden="true">/</span>
        <a href="https://www.tensorflow.org/js" class="tech-badge" target="_blank" rel="noopener noreferrer">
          <span class="tf-text">TensorFlow</span>
        </a>
        <span class="separator" aria-hidden="true">/</span>
        <a href="https://jsr.io" class="tech-badge" target="_blank" rel="noopener noreferrer">
          <span class="jsr-text">JSR</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  #links {
    position: relative;
    padding: 56px 0 72px;
    overflow: hidden;
  }

  .container { max-width: 1200px; margin: 0 auto; padding: 0 48px; }
  .section-subtitle { font-size: 1.1rem; color: var(--md-sys-color-on-surface-variant); margin: 0; line-height: 1.6; }

  .links-content { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 24px; }

  .links-content h2 { font-family: 'Fraunces', Georgia, serif; font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 600; color: var(--md-sys-color-on-surface); margin: 0; letter-spacing: -0.02em; }
  .links-content .section-subtitle { max-width: 500px; }

  .links-commands { display: flex; flex-direction: column; gap: 12px; width: 100%; max-width: 560px; margin-top: 8px; }

  .links-row { display: flex; align-items: center; gap: 12px; }

  .links-runtime { font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--md-sys-color-on-surface-variant); width: 48px; text-align: right; flex-shrink: 0; }

  .links-cmd { flex: 1; display: flex; align-items: center; gap: 8px; padding: 12px 16px; background: var(--md-sys-color-surface-container-lowest); border: 1px solid var(--md-sys-color-outline-variant); border-radius: 10px; transition: border-color 200ms ease-out; }
  .links-cmd:hover { border-color: var(--md-sys-color-primary); }

  .links-cmd code { flex: 1; font-family: 'JetBrains Mono', monospace; font-size: 0.8125rem; color: var(--md-sys-color-on-surface); user-select: all; }

  .copy-btn { display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; border: none; background: transparent; border-radius: 6px; cursor: pointer; color: var(--md-sys-color-on-surface-variant); transition: background 150ms ease-out, color 150ms ease-out; flex-shrink: 0; }
  .copy-btn:hover { background: var(--md-sys-color-surface-container-high); color: var(--md-sys-color-primary); }
  .copy-btn:focus-visible { outline: 3px solid var(--md-sys-color-primary); outline-offset: 2px; }
  .copy-btn .material-symbols-rounded { font-size: 18px; }

  .links-buttons { display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; margin-top: 8px; }

  .links-link { display: flex; align-items: center; gap: 8px; padding: 10px 20px; background: transparent; color: var(--md-sys-color-on-surface); border: 1px solid var(--md-sys-color-outline-variant); border-radius: 8px; font-size: 0.875rem; font-weight: 500; text-decoration: none; transition: background 200ms ease-out, border-color 200ms ease-out; }
  .links-link:hover { background: var(--md-sys-color-surface-container); border-color: var(--md-sys-color-primary); }
  .links-link:focus-visible { outline: 3px solid var(--md-sys-color-primary); outline-offset: 4px; }
  .links-link .material-symbols-rounded { font-size: 18px; color: var(--md-sys-color-on-surface-variant); }
  .links-link .link-arrow { font-size: 16px; opacity: 0; transition: opacity 150ms ease-out; }
  .links-link:hover .link-arrow { opacity: 1; }

  .built-with { display: flex; align-items: center; gap: 12px; margin-top: 16px; font-size: 0.8125rem; flex-wrap: wrap; justify-content: center; }
  .built-label { color: var(--md-sys-color-on-surface-variant); font-weight: 500; }

  .tech-badge { display: flex; align-items: center; gap: 6px; color: var(--md-sys-color-on-surface); text-decoration: none; font-weight: 600; padding: 4px 10px; border-radius: 6px; transition: background 150ms ease-out; }
  .tech-badge:hover { background: var(--md-sys-color-surface-container-high); }
  .tech-badge svg { width: 18px; height: 18px; }
  .tf-text { font-family: 'JetBrains Mono', monospace; font-weight: 700; font-size: 0.8125rem; letter-spacing: 0.02em; }
  .jsr-text { font-family: 'JetBrains Mono', monospace; font-weight: 700; font-size: 0.8125rem; letter-spacing: 0.04em; }
  .separator { color: var(--md-sys-color-outline-variant); }

  @media (max-width: 1024px) { .container { padding: 0 32px; } }
  @media (max-width: 768px) {
    #links { padding: 60px 0 80px; }
    .container { padding: 0 20px; }
    .links-row { flex-direction: column; align-items: stretch; gap: 6px; }
    .links-runtime { text-align: left; width: auto; }
    .links-buttons { flex-direction: column; align-items: center; }
    .links-link { width: 100%; justify-content: center; max-width: 300px; }
  }
  @media (max-width: 380px) { .container { padding: 0 14px; } }
</style>

<style is:global>
  #links { background: var(--md-sys-color-surface); }
  html[data-theme="dark"] #links { background: #0a0908; }
  html[data-theme="dark"] #links .links-content h2 { color: #f5f0ea; }
  html[data-theme="dark"] #links .section-subtitle { color: #d5c3b5; }
  html[data-theme="dark"] #links .links-runtime { color: #a89a8c; }
  html[data-theme="dark"] #links .links-cmd { background: #111110; border-color: rgba(255, 184, 111, 0.1); }
  html[data-theme="dark"] #links .links-cmd:hover { border-color: rgba(255, 184, 111, 0.3); }
  html[data-theme="dark"] #links .links-cmd code { color: #f5f0ea; }
  html[data-theme="dark"] #links .copy-btn { color: #a89a8c; }
  html[data-theme="dark"] #links .copy-btn:hover { background: rgba(255, 184, 111, 0.1); color: #FFB86F; }
  html[data-theme="dark"] #links .links-link { color: #d5c3b5; border-color: rgba(255, 184, 111, 0.12); }
  html[data-theme="dark"] #links .links-link:hover { background: rgba(255, 184, 111, 0.08); border-color: rgba(255, 184, 111, 0.3); color: #f5f0ea; }
  html[data-theme="dark"] #links .links-link .material-symbols-rounded { color: #a89a8c; }
  html[data-theme="dark"] #links .links-link:hover .material-symbols-rounded { color: #FFB86F; }
  html[data-theme="dark"] #links .built-label { color: #a89a8c; }
  html[data-theme="dark"] #links .tech-badge { color: #d5c3b5; }
  html[data-theme="dark"] #links .tech-badge:hover { background: rgba(255, 184, 111, 0.08); color: #FFB86F; }
  html[data-theme="dark"] #links .separator { color: rgba(255, 184, 111, 0.15); }
</style>

<script is:inline>
  // Copy to clipboard
  document.querySelectorAll('#links .copy-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var text = btn.dataset.copy;
      if (!text) return;
      navigator.clipboard.writeText(text).then(function() {
        var icon = btn.querySelector('.material-symbols-rounded');
        if (icon) {
          var original = icon.textContent;
          icon.textContent = 'check';
          btn.style.color = '#6ee7b7';
          setTimeout(function() { icon.textContent = original; btn.style.color = ''; }, 2000);
        }
      }).catch(function() {});
    });
  });

  // Smooth scroll for all anchor links (respects reduced motion)
  var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  document.querySelectorAll('#links a[href^="#"]').forEach(function(link) {
    link.addEventListener('click', function(e) {
      var targetId = link.getAttribute('href');
      if (!targetId || targetId === '#') return;
      var target = document.querySelector(targetId);
      if (!target) return;
      e.preventDefault();
      target.scrollIntoView({ behavior: prefersReducedMotion ? 'auto' : 'smooth', block: 'start' });
      history.pushState(null, '', targetId);
    });
  });
</script>
