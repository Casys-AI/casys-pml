     ======================================== */

  /* Node backgrounds: light pastel fills for white bg */
  #shgat .shgat-node-root > rect:nth-child(2) { fill: #ecfeff; }
  #shgat .shgat-node-composite > rect:first-child { fill: #f3f0ff; }
  #shgat .shgat-node-leaf > rect:first-child { fill: #fef9ee; }
