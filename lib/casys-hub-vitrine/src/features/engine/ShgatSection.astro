    opacity: 1;
  }

  /* SVG dark mode: upward arrows brighter */
  html[data-theme="dark"] #shgat .shgat-arrow-up {
    opacity: 0.8;
  }

  /* SVG dark mode: downward arrows brighter */
  html[data-theme="dark"] #shgat .shgat-arrow-down {
    opacity: 0.8;
  }

  /* SVG dark mode: node fills (restore dark fills over light defaults) */
  html[data-theme="dark"] #shgat .shgat-node-root > rect:nth-child(2) { fill: #0e1820; }
  html[data-theme="dark"] #shgat .shgat-node-composite > rect:first-child { fill: #1a1228; }
  html[data-theme="dark"] #shgat .shgat-node-leaf > rect:first-child { fill: #1c1508; }
  html[data-theme="dark"] #shgat .shgat-score-output > rect:nth-of-type(1) { fill: #1c1508; }

  /* SVG dark mode: node labels (bright on dark) */
  html[data-theme="dark"] #shgat .shgat-node-root .shgat-node-label { fill: #67e8f9; }
  html[data-theme="dark"] #shgat .shgat-node-composite .shgat-node-label { fill: #c4b5fd; }
  html[data-theme="dark"] #shgat .shgat-node-leaf .shgat-node-label { fill: #fcd34d; }

  /* SVG dark mode: score output text */
