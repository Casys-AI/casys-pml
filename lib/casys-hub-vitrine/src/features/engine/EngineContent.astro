    color: var(--e-accent);
    margin-bottom: 32px;
    opacity: 0.8;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 300;
    line-height: 1.1;
    margin: 0 0 24px;
    letter-spacing: -0.03em;
  }

  .hero-title-main {
    display: block;
    font-family: 'Fraunces', Georgia, serif;
    color: var(--e-text);
    font-optical-sizing: auto;
  }

  .hero-title-accent {
    display: block;
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    color: var(--e-accent);
    font-weight: 400;
  }

  .hero-subtitle {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.7;
    color: var(--e-text-secondary);
    max-width: 520px;
    margin: 0 auto 40px;
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 48px;
    margin-bottom: 32px;
  }

  .hero-stat {
    text-align: center;
  }

  .hero-stat-value {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--e-accent);
    letter-spacing: -0.02em;
  }

  .hero-stat-label {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--e-text-dim);
    margin-top: 4px;
  }

  .hero-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--e-text-dim);
    opacity: 0.6;
  }

  /* ── ACT (section wrapper) ─────────────── */

  .act {
    position: relative;
    padding: 80px 32px;
    border-top: 1px solid var(--e-border);
    background: var(--md-sys-color-surface-container-lowest, #faf8f5);
    overflow: hidden;
  }

  .act-marker {
    position: absolute;
    top: 40px;
    right: 32px;
    pointer-events: none;
  }

  .act-number-bg {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(6rem, 12vw, 10rem);
    font-weight: 200;
    color: var(--e-accent);
    opacity: 0.04;
    line-height: 1;
    user-select: none;
  }

  .act-header {
    display: flex;
    align-items: center;
    gap: 16px;
    max-width: 720px;
    margin: 0 auto 48px;
  }

  .act-number {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--e-accent);
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .act-divider {
    flex: 0 0 32px;
    height: 1px;
    background: var(--e-accent);
    opacity: 0.3;
  }

  .act-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--e-text-dim);
  }

  /* ── Prose ──────────────────────────────── */

  .act-prose {
    max-width: 680px;
    margin: 0 auto;
  }

  .act-prose h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    color: var(--e-text);
    line-height: 1.2;
    margin: 0 0 20px;
    letter-spacing: -0.02em;
  }

  .act-prose h3 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--e-text);
    margin: 40px 0 12px;
    letter-spacing: -0.01em;
  }

  .act-prose p {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 1.0625rem;
    line-height: 1.85;
    color: var(--e-text-secondary);
    margin: 0 0 20px;
  }

  .act-prose strong {
    font-weight: 700;
    color: var(--e-text);
  }

  .act-prose code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9em;
    background: var(--e-surface);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--e-accent);
  }

  .act-prose blockquote {
    margin: 32px 0;
    padding: 20px 24px;
    border-left: 3px solid var(--e-accent);
    background: var(--e-accent-glow);
    border-radius: 0 8px 8px 0;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 1.0625rem;
    line-height: 1.8;
    font-style: italic;
    color: var(--e-text-secondary);
  }

  .act-prose ol,
  .act-prose ul {
    padding-left: 24px;
    margin: 0 0 20px;
  }

  .act-prose li {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 1rem;
    line-height: 1.75;
    color: var(--e-text-secondary);
    margin-bottom: 8px;
  }

  .act-prose li::marker {
    color: var(--e-accent);
  }

  .dim {
    color: var(--e-text-dim);
    font-size: 0.9em;
  }

  .training-note {
    font-family: 'JetBrains Mono', monospace !important;
    font-size: 0.8rem !important;
    color: var(--e-text-dim) !important;
    border-top: 1px solid var(--e-border);
    padding-top: 20px;
    margin-top: 32px !important;
  }

  /* ── Cinema (image container) ──────────── */

  .cinema {
    max-width: 960px;
    margin: 40px auto;
    background: var(--e-cinema-bg);
    border-radius: 12px;
    border: 1px solid var(--e-cinema-border);
    overflow: hidden;
  }

  .cinema img {
    display: block;
    width: 100%;
    height: auto;
  }

  .cinema figcaption {
    padding: 14px 20px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    line-height: 1.6;
    color: #a89a8c;
  }

  .cinema figcaption strong {
    color: #d5c3b5;
    font-weight: 600;
  }

  .cinema-glow {
    box-shadow:
      0 0 0 1px rgba(245, 173, 254, 0.15),
      0 0 40px rgba(245, 173, 254, 0.06),
      0 0 80px rgba(245, 173, 254, 0.03);
  }

  .cinema-compact {
    margin: 0;
  }

  /* ── Graph SVG wrapper (section 01) ─────── */

  .graph-svg-wrapper {
    max-width: 640px;
    margin: 48px auto;
    padding: 32px;
    background: var(--e-surface);
    border: 1px solid var(--e-border);
    border-radius: 16px;
  }

  .shgat-svg {
    display: block;
    width: 100%;
    height: auto;
  }

  /* SVG animation keyframes */
  @keyframes shgatFlowUp {
    0% { stroke-dashoffset: 18; }
    100% { stroke-dashoffset: 0; }
  }

  @keyframes shgatFlowDown {
    0% { stroke-dashoffset: 18; }
    100% { stroke-dashoffset: 0; }
  }

  @keyframes shgatRootPulse {
    0%, 100% { opacity: 0.06; }
    50% { opacity: 0.12; }
  }

  @keyframes shgatIntentFlow {
    0% { stroke-dashoffset: 16; }
    100% { stroke-dashoffset: 0; }
  }

  .shgat-arrow-up {
    animation: shgatFlowUp 1.8s linear infinite;
  }
  .shgat-up-1 { animation-delay: 0s; }
  .shgat-up-2 { animation-delay: 0.2s; }
  .shgat-up-3 { animation-delay: 0.4s; }
  .shgat-up-4 { animation-delay: 0.8s; }
  .shgat-up-5 { animation-delay: 1.0s; }

  .shgat-arrow-down {
    animation: shgatFlowDown 1.8s linear infinite;
  }
  .shgat-down-1 { animation-delay: 1.4s; }
  .shgat-down-2 { animation-delay: 1.6s; }
  .shgat-down-3 { animation-delay: 2.0s; }
  .shgat-down-4 { animation-delay: 2.2s; }
  .shgat-down-5 { animation-delay: 2.4s; }

  .shgat-node-root rect:first-child {
    animation: shgatRootPulse 3s ease-in-out infinite;
  }

  .shgat-intent-arrow {
    animation: shgatIntentFlow 2s linear infinite;
  }

  /* ── Level strip ───────────────────────── */

  .level-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    max-width: 560px;
    margin: 32px auto;
  }

  .level-card {
    flex: 1;
    text-align: center;
    padding: 20px 16px;
    background: var(--e-surface);
    border: 1px solid var(--e-border);
  }

  .level-card:first-child {
    border-radius: 10px 0 0 10px;
  }

  .level-card:last-child {
    border-radius: 0 10px 10px 0;
  }

  .level-connector {
    width: 24px;
    height: 1px;
    background: var(--e-accent);
    opacity: 0.3;
    flex-shrink: 0;
    margin: 0 -1px;
    z-index: 1;
  }

  .level-tag {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--e-accent);
    letter-spacing: 0.1em;
    margin-bottom: 4px;
  }

  .level-name {
    display: block;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--e-text);
    margin-bottom: 2px;
  }

  .level-count {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--e-text-dim);
  }

  /* ── Formula block ─────────────────────── */

  .formula-block {
    max-width: 600px;
    margin: 32px auto;
    text-align: center;
    padding: 28px 32px;
    background: var(--e-surface);
    border: 1px solid var(--e-border);
    border-radius: 10px;
  }

  .formula-content {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: center;
  }

  .formula-main {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--e-text);
    letter-spacing: 0.02em;
  }

  .formula-main sub {
    font-size: 0.7em;
  }

  .formula-where {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--e-text-secondary);
  }

  .formula-note {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.75rem;
    color: var(--e-text-dim);
    font-style: italic;
  }

  /* ── Stat Punch ────────────────────────── */

  .stat-punch {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    max-width: 700px;
    margin: 48px auto;
    padding: 40px 32px;
    background:
      linear-gradient(135deg, var(--e-accent-glow) 0%, transparent 50%),
      var(--e-surface);
    border: 1px solid var(--e-border);
    border-radius: 12px;
    flex-wrap: wrap;
  }

  .stat-punch-item {
    text-align: center;
  }

  .stat-punch-value {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .stat-punch-pct {
    font-size: 0.6em;
    font-weight: 500;
    opacity: 0.7;
  }

  .stat-punch-before {
    color: var(--e-text-dim);
  }

  .stat-punch-after {
    color: var(--e-accent);
  }

  .stat-punch-label {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--e-text-dim);
    margin-top: 8px;
  }

  .stat-punch-arrow {
    color: var(--e-accent);
    opacity: 0.5;
    flex-shrink: 0;
  }

  .stat-punch-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    font-weight: 700;
    color: #16a34a;
    background: rgba(22, 163, 74, 0.08);
    border: 1px solid rgba(22, 163, 74, 0.2);
    padding: 6px 14px;
    border-radius: 100px;
  }

  /* ── Evidence Grid ─────────────────────── */

  .evidence-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    max-width: 960px;
    margin: 40px auto;
  }

  /* ── Comparison Grid (GRU vs LLM) ──────── */

  .comparison-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    max-width: 720px;
    margin: 24px auto 40px;
  }

  .comparison-card {
    background: var(--e-surface);
    border: 1px solid var(--e-border);
    border-radius: 10px;
    overflow: hidden;
  }

  .comparison-header {
    padding: 10px 12px 8px;
    border-bottom: 1px solid var(--e-border);
  }

  .comparison-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--e-text-dim);
  }

  .comparison-body {
    padding: 10px 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .comparison-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .comparison-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--e-text-dim);
    width: 28px;
    flex-shrink: 0;
  }

  .comparison-val {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--e-text-secondary);
  }

  .comparison-winner .comparison-tag {
    color: var(--e-accent);
  }

  .comparison-winner .comparison-val {
    font-weight: 600;
    color: var(--e-text);
  }

  /* ── Metric Strip ──────────────────────── */

  .metric-strip {
    display: flex;
    justify-content: center;
    gap: 20px;
    max-width: 600px;
    margin: 24px auto 40px;
  }

  .metric-card {
    flex: 1;
    text-align: center;
    padding: 24px 16px;
    background: var(--e-surface);
    border: 1px solid var(--e-border);
    border-radius: 10px;
  }

  .metric-highlight {
    background: var(--e-accent-glow);
    border-color: rgba(131, 70, 143, 0.2);
  }

  .metric-value {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--e-accent);
    letter-spacing: -0.02em;
  }

  .metric-label {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--e-text-dim);
    margin-top: 6px;
  }

  /* ── Results Table ─────────────────────── */

  .table-wrapper {
    max-width: 680px;
    margin: 32px auto;
  }

  .results-table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.95rem;
  }

  .results-table th {
    text-align: left;
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--e-text-dim);
    padding: 12px 16px;
    border-bottom: 2px solid var(--e-border);
    font-family: 'JetBrains Mono', monospace;
  }

  .results-table td {
    padding: 14px 16px;
    border-bottom: 1px solid var(--e-border);
    color: var(--e-text-secondary);
  }

  .results-table .mono {
    font-family: 'JetBrains Mono', monospace;
  }

  .row-highlight {
    background: var(--e-accent-glow);
  }

  .row-highlight td {
    border-bottom-color: rgba(131, 70, 143, 0.15);
  }

  .highlight-val {
    font-weight: 700;
    color: var(--e-accent) !important;
    font-size: 1.1em;
  }

  .delta-neutral {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--e-text-dim);
  }

  .delta-positive {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    font-weight: 700;
    color: #16a34a;
  }

  /* ── Punchline ─────────────────────────── */

  .punchline {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 40px;
    align-items: center;
    max-width: 720px;
    margin: 48px auto;
    padding: 40px;
    background:
      linear-gradient(135deg, var(--e-accent-glow) 0%, transparent 60%),
      var(--e-surface);
    border: 1px solid rgba(131, 70, 143, 0.15);
    border-radius: 12px;
  }

  .punchline-number {
    text-align: center;
  }

  .punchline-value {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(3rem, 6vw, 4rem);
    font-weight: 700;
    color: var(--e-accent);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .punchline-pct {
    font-size: 0.5em;
    font-weight: 500;
    opacity: 0.7;
  }

  .punchline-label {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--e-text-dim);
    margin-top: 8px;
  }

  .punchline-context p {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--e-text-secondary);
    margin: 0 0 12px;
  }

  .punchline-context p:last-child {
    margin-bottom: 0;
  }

  /* ── Bench Grid ────────────────────────── */

  .bench-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    max-width: 760px;
    margin: 40px auto;
  }

  .bench-card {
    padding: 24px 20px;
    background: var(--e-surface);
    border: 1px solid var(--e-border);
    border-radius: 10px;
    text-align: center;
  }

  .bench-card-accent {
    background: var(--e-accent-glow);
    border-color: rgba(131, 70, 143, 0.2);
  }

  .bench-model {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--e-accent);
    margin-bottom: 8px;
  }

  .bench-metric {
    display: block;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.75rem;
    color: var(--e-text-dim);
    margin-bottom: 4px;
  }

  .bench-value {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--e-text);
    margin-bottom: 8px;
  }

  .bench-detail {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: var(--e-text-dim);
  }

  /* ── Deep Dives ────────────────────────── */

  /* ── Section dive teaser ────────────────── */

  .section-dive {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 960px;
    margin: 0 auto;
    padding: 20px 32px;
    border-top: 1px solid var(--e-border);
    text-decoration: none;
    color: inherit;
    transition: background 0.15s ease;
    gap: 16px;
  }

  .section-dive:hover {
    background: var(--e-accent-glow);
  }

  .section-dive-inner {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .section-dive-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--e-accent);
    opacity: 0.7;
  }

  .section-dive-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--e-text);
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .section-dive-meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: var(--e-text-dim);
    letter-spacing: 0.03em;
  }

  .section-dive-arrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.1rem;
    color: var(--e-accent);
    opacity: 0.5;
    transition: opacity 0.15s ease, transform 0.15s ease;
    flex-shrink: 0;
  }

  .section-dive:hover .section-dive-arrow {
    opacity: 1;
    transform: translateX(4px);
  }

  /* ── Deep dives grid ────────────────────── */

  .deep-dives-section {
    background: var(--md-sys-color-surface-container-lowest, #faf8f5);
  }

  .deep-dive-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    max-width: 960px;
    margin: 40px auto;
  }

  .deep-dive-card {
    display: block;
    background: var(--e-surface);
    border: 1px solid var(--e-border);
    border-radius: 10px;
    text-decoration: none;
    overflow: hidden;
    transition: border-color 0.2s, background 0.2s, transform 0.2s;
  }

  .deep-dive-card:hover {
    border-color: var(--e-accent);
    transform: translateY(-2px);
  }

  .deep-dive-thumb {
    width: 100%;
    aspect-ratio: 16/7;
    overflow: hidden;
    background: var(--e-cinema-bg, #fff);
  }

  .deep-dive-thumb img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top left;
    transition: transform 0.3s ease;
    filter: saturate(0.9);
  }

  .deep-dive-card:hover .deep-dive-thumb img {
    transform: scale(1.03);
    filter: saturate(1);
  }

  html[data-theme="dark"] .deep-dive-thumb img {
    filter: invert(1) hue-rotate(180deg) saturate(0.9);
  }

  html[data-theme="dark"] .deep-dive-card:hover .deep-dive-thumb img {
    filter: invert(1) hue-rotate(180deg) saturate(1);
  }

  .deep-dive-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 18px 4px;
  }

  .deep-dive-nb {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--e-accent);
    opacity: 0.8;
  }

  .deep-dive-arrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    color: var(--e-text-dim);
    opacity: 0;
    transition: opacity 0.2s, transform 0.2s;
  }

  .deep-dive-card:hover .deep-dive-arrow {
    opacity: 1;
    transform: translateX(3px);
  }

  .deep-dive-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--e-text);
    margin: 0 0 6px;
    padding: 0 18px;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .deep-dive-subtitle {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.78rem;
    color: var(--e-text-dim);
    margin: 0;
    padding: 0 18px 18px;
    font-style: italic;
    line-height: 1.5;
  }

  /* ── Coda ──────────────────────────────── */

  .coda {
    padding: 60px 32px;
    border-top: 1px solid var(--e-border);
    text-align: center;
    background: var(--md-sys-color-surface-container-lowest, #faf8f5);
  }

  .coda-inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .coda-note {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--e-text-dim);
    margin: 0 0 32px;
  }

  .coda-links {
    display: flex;
    justify-content: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .coda-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--e-text-secondary);
    text-decoration: none;
    padding: 10px 20px;
    border: 1px solid var(--e-border);
    border-radius: 8px;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .coda-link:hover {
    color: var(--e-accent);
    border-color: var(--e-accent);
    background: var(--e-accent-glow);
  }

  .coda-link-icon {
    display: flex;
    opacity: 0.6;
  }

  .coda-link:hover .coda-link-icon {
    opacity: 1;
  }

  /* ── Scroll reveal ─────────────────────── */

  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1), transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .revealed {
    opacity: 1;
    transform: none;
  }

  /* ── Responsive ────────────────────────── */

  @media (max-width: 768px) {
    .engine-hero {
      padding: 64px 20px 48px;
    }

    .hero-stats {
      gap: 24px;
    }

    .hero-stat-value {
      font-size: 1.35rem;
    }

    .act {
      padding: 56px 20px;
    }

    .act-marker {
      display: none;
    }

    .cinema {
      margin-left: -20px;
      margin-right: -20px;
      border-radius: 0;
      border-left: none;
      border-right: none;
    }

    .evidence-grid {
      grid-template-columns: 1fr;
    }

    .comparison-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
    }

    .metric-strip {
      flex-direction: column;
      gap: 12px;
    }

    .stat-punch {
      flex-direction: column;
      gap: 16px;
      padding: 28px 24px;
    }

    .stat-punch-arrow {
      transform: rotate(90deg);
    }

    .punchline {
      grid-template-columns: 1fr;
      text-align: center;
      padding: 32px 24px;
    }

    .bench-grid {
      grid-template-columns: 1fr;
    }

    .level-strip {
      flex-direction: column;
      gap: 0;
    }

    .level-card:first-child {
      border-radius: 10px 10px 0 0;
    }

    .level-card:last-child {
      border-radius: 0 0 10px 10px;
    }

    .level-connector {
      width: 1px;
      height: 16px;
    }

    .graph-svg-wrapper {
      padding: 20px 12px;
      margin: 32px auto;
    }

    .deep-dive-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 1024px) {
    .deep-dive-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .hero-title {
      font-size: 2rem;
    }

    .comparison-grid {
      grid-template-columns: 1fr;
    }

    .deep-dive-grid {
      grid-template-columns: 1fr;
    }

    .section-dive {
      padding: 16px 20px;
    }
  }

  /* ── Reduced motion ────────────────────── */

  @media (prefers-reduced-motion: reduce) {
    .reveal-on-scroll {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .shgat-arrow-up,
    .shgat-arrow-down,
    .shgat-intent-arrow,
    .shgat-node-root rect:first-child {
      animation: none;
    }

    .deep-dive-card:hover {
      transform: none;
    }
  }
</style>

