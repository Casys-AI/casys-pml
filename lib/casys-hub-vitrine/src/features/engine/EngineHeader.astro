---
import SubsiteHeader from '../../components/SubsiteHeader.astro';
import { useTranslations } from '../../i18n';

const locale = (Astro as any).currentLocale ?? 'en';
const t = useTranslations(locale).engineHeader;
---

<SubsiteHeader
  logo={{ prefix: 'casys/', name: 'engine', version: 'v0.1' }}
  navLinks={[
    { href: '#graph', label: 'Graph' },
    { href: '#enrichment', label: 'Enrichment' },
    { href: '#residual', label: 'Residual' },
    { href: '#sequence', label: 'Sequence' },
    { href: '#results', label: 'Results' },
    { href: '/docs/shgat/introduction/', label: t.docs, icon: 'description' },
  ]}
  githubUrl="https://github.com/Casys-AI/shgat"
  jsrUrl="https://jsr.io/@casys/shgat"
  consultingLabel={t.workWithUs}
  heroAnchor="#engine-hero"
/>
