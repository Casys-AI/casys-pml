---
import SubsiteLayout from '../../components/SubsiteLayout.astro';
import EngineHeader from './EngineHeader.astro';

export interface Props {
  title: string;
}

const { title } = Astro.props;
const locale = (Astro as any).currentLocale ?? 'en';

const metaDescriptions: Record<string, string> = {
  en: 'ML computation layer for PML. SHGAT-TF attention networks score tool relevance across hypergraph hierarchies. Deterministic, observable, self-hosted.',
  fr: 'Couche de calcul ML pour PML. SHGAT-TF score la pertinence des outils par attention multi-niveaux sur hypergraphe. Deterministe, observable, auto-heberge.',
  zh: 'PML 的 ML 计算层。SHGAT-TF 注意力网络在超图层次结构中评分工具相关性。确定性、可观测、自托管。',
  'zh-TW': 'PML 的 ML 計算層。SHGAT-TF 注意力網路在超圖層次結構中評分工具相關性。確定性、可觀測、自託管。',
};
const metaDescription = metaDescriptions[locale] ?? metaDescriptions.en;
---

<!-- Override SubsiteLayout amber dark bg with engine's purple dark bg -->
<style is:global>
  html[data-theme="dark"] body { background: #1e1a1e !important; }
  :root {
    --md-sys-color-primary: #83468f;
    --md-sys-color-on-primary: #ffffff;
    --md-sys-color-primary-container: rgba(131, 70, 143, 0.1);
  }
</style>

<SubsiteLayout title={title} metaDescription={metaDescription} jsonLd={{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Casys PML",
  "description": metaDescription,
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Cross-platform",
  "url": "https://engine.casys.ai",
  "author": { "@type": "Organization", "name": "Casys AI", "url": "https://casys.ai" },
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "programmingLanguage": "TypeScript",
  "runtimePlatform": "Deno"
}}>
  <EngineHeader slot="header" />
  <slot />
</SubsiteLayout>
