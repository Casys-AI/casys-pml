      subtitle: '进展与社区',
      items: [
        {
          type: 'stat',
          icon: 'code',
          stat: '活跃',
          label: '开发中',
          description: 'Casys PML - 集成 GraphRAG 和 DAG 的 MCP Gateway',
          link: {
            text: '在 GitHub 上关注',
            url: 'https://github.com/Casys-AI/casys-pml'
          }
