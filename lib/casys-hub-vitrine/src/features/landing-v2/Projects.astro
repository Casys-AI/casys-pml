---
import { useTranslations } from '../../i18n';
const locale = (Astro as any).currentLocale ?? 'en';
const content = useTranslations(locale).projects;
---

<section id="projects">
  <div class="container">
    <!-- Header -->
    <div class="section-header">
      <h2>{content.title}</h2>
      <p class="section-subtitle">{content.subtitle}</p>
    </div>

    <!-- Featured Project (PML Gateway) -->
    <div class="featured-card">
      <div class="featured-header">
        <div>
          <h3 class="featured-name">{content.featured.name}</h3>
          <p class="featured-tagline">{content.featured.tagline}</p>
        </div>
        <div class="featured-badges">
          <span class="status-badge active">{content.featured.status}</span>
          <span class="license-badge">{content.featured.license}</span>
        </div>
      </div>

      <!-- Features -->
      <div class="features-grid">
        {content.featured.features.map((feature: { icon: string; name: string; description: string }) => (
          <div class="feature-cell">
            <span class="material-symbols-rounded">{feature.icon}</span>
            <div>
              <div class="feature-name">{feature.name}</div>
              <div class="feature-desc">{feature.description}</div>
            </div>
          </div>
        ))}
      </div>

      <!-- Results Stats -->
      <div class="results-stats">
        {content.featured.results.map((result: { stat: string; label: string }) => (
          <div class="result-stat">
            <div class="stat-value">{result.stat}</div>
            <div class="stat-label">{result.label}</div>
          </div>
        ))}
      </div>

      <!-- Links -->
      <div class="featured-links">
        {content.featured.links.website && (
          <a href={content.featured.links.website} class="project-link primary" target="_blank" rel="noopener noreferrer">
            <span class="material-symbols-rounded">public</span>
            <span>Website</span>
          </a>
        )}
        {content.featured.links.github && (
          <a href={content.featured.links.github} class="project-link" target="_blank" rel="noopener noreferrer">
            <span class="material-symbols-rounded">code</span>
            <span>GitHub</span>
          </a>
        )}
        {content.featured.links.docs && content.featured.links.docs !== '#' && (
          <a href={content.featured.links.docs} class="project-link" target="_blank" rel="noopener noreferrer">
            <span class="material-symbols-rounded">description</span>
            <span>Docs</span>
          </a>
        )}
      </div>
    </div>

    <!-- Categories List -->
    <div class="categories">
      {content.categories.map((category: {
        name: string;
        items: {
          id: string;
          name: string;
          tagline: string;
          status: string;
          tech: string;
          links: { website?: string; github?: string; jsr?: string };
        }[];
      }) => (
        <div class="category">
          <h3 class="category-name">{category.name}</h3>
          <div class="category-items">
            {category.items.map((item, idx) => (
              <div class={`project-row ${idx < category.items.length - 1 ? 'has-border' : ''}`}>
                <div class="row-info">
                  {item.links.website ? (
                    <a href={item.links.website} class="row-name" target="_blank" rel="noopener noreferrer">
                      {item.name}
                    </a>
                  ) : (
                    <span class="row-name">{item.name}</span>
                  )}
                  <span class="row-tagline">{item.tagline}</span>
                </div>
                <div class="row-meta">
                  <span class="pill status-pill">{item.status}</span>
                  <span class="pill tech-pill">{item.tech}</span>
                  <div class="row-links">
                    {item.links.github && (
                      <a href={item.links.github} class="icon-link" target="_blank" rel="noopener noreferrer" aria-label={`${item.name} on GitHub`}>
                        <span class="material-symbols-rounded">code</span>
                      </a>
                    )}
                    {item.links.jsr && (
                      <a href={item.links.jsr} class="icon-link" target="_blank" rel="noopener noreferrer" aria-label={`${item.name} on JSR`}>
                        <svg class="jsr-inline-icon" width="16" height="16" viewBox="0 -3 64 64" fill="none" aria-hidden="true"><path d="M 0,21.846 H 9.846 V 12 h 34.462 v 4.923 H 64 V 36.616 H 54.155 V 46.462 H 19.693 V 41.539 H 0" fill="#083344"/><g fill="#f7df1e" transform="matrix(4.923,0,0,4.923,0,12)"><path d="M 1,3 H 2 V 4 H 3 V 1 H 4 V 5 H 1"/><path d="M 5,1 H 8 V 2 H 6 V 3 H 8 V 6 H 5 V 5 H 7 V 4 H 5"/><path d="m 9,2 h 3 V 4 H 11 V 3 H 10 V 6 H 9"/></g></svg>
                      </a>
                    )}
                    {item.links.website && (
                      <a href={item.links.website} class="icon-link" target="_blank" rel="noopener noreferrer" aria-label={`${item.name} website`}>
                        <span class="material-symbols-rounded">open_in_new</span>
                      </a>
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>


<style>
  section {
    padding: 56px 0;
    background: var(--md-sys-color-surface);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Section Header ── */
  .section-header {
    text-align: left;
    margin-bottom: 48px;
    max-width: 600px;
  }

  h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 2.5rem;
    font-weight: 600;
    font-optical-sizing: auto;
    color: var(--md-sys-color-on-surface);
    margin: 0 0 12px;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
    line-height: 1.6;
  }

  /* ── Featured Card (PML Gateway) ── */
  .featured-card {
    padding: 28px 32px;
    background: var(--md-sys-color-surface-container-lowest);
    border-radius: 16px;
    border: 1px solid var(--md-sys-color-outline-variant);
    border-left: 4px solid var(--md-sys-color-primary);
    display: flex;
    flex-direction: column;
    gap: 20px;
    position: relative;
    overflow: hidden;
    transition: border-color 200ms ease-out, box-shadow 200ms ease-out;
    margin-bottom: 40px;
  }

  .featured-card::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(180, 130, 90, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .featured-card:hover {
    border-color: var(--md-sys-color-primary);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .featured-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 20px;
  }

  .featured-name {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--md-sys-color-on-surface);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .featured-tagline {
    font-size: 0.95rem;
    color: var(--md-sys-color-on-surface-variant);
    margin: 4px 0 0;
    font-weight: 500;
  }

  .featured-badges {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-shrink: 0;
  }

  .status-badge {
    padding: 6px 14px;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .status-badge.active {
    background: var(--md-sys-color-secondary-container);
    color: var(--md-sys-color-on-secondary-container);
  }

  .license-badge {
    padding: 5px 10px;
    background: var(--md-sys-color-primary-container);
    color: var(--md-sys-color-on-primary-container);
    border-radius: 8px;
    font-size: 0.7rem;
    font-weight: 600;
  }

  /* Features Grid */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
  }

  .feature-cell {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 12px 14px;
    background: var(--md-sys-color-surface-container-high);
    border-radius: 10px;
  }

  .feature-cell .material-symbols-rounded {
    font-size: 24px;
    color: var(--md-sys-color-primary);
    flex-shrink: 0;
    line-height: 1;
  }

  .feature-name {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--md-sys-color-on-surface);
    margin-bottom: 1px;
  }

  .feature-desc {
    font-size: 0.75rem;
    color: var(--md-sys-color-on-surface-variant);
    line-height: 1.4;
  }

  /* Results Stats */
  .results-stats {
    display: flex;
    gap: 32px;
    padding-top: 14px;
    border-top: 1px solid var(--md-sys-color-outline-variant);
  }

  .result-stat {
    text-align: left;
  }

  .stat-value {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--md-sys-color-primary);
    line-height: 1;
    margin-bottom: 3px;
  }

  .stat-label {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--md-sys-color-on-surface-variant);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Featured Links */
  .featured-links {
    display: flex;
    gap: 12px;
    margin-top: auto;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 14px;
    background: transparent;
    color: var(--md-sys-color-on-surface);
    border: 1px solid var(--md-sys-color-outline-variant);
    border-radius: 8px;
    font-size: 0.825rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 150ms ease-out, border-color 150ms ease-out;
  }

  .project-link:hover {
    background: var(--md-sys-color-surface-container-high);
    border-color: var(--md-sys-color-outline);
  }

  .project-link .material-symbols-rounded {
    font-size: 16px;
    opacity: 0.7;
  }

  /* ── Categories Section ── */
  .categories {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .category {
    padding-top: 24px;
  }

  .category:first-child {
    padding-top: 0;
  }

  .category-name {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0 0 12px;
    padding-top: 16px;
    border-top: 1px solid var(--md-sys-color-outline-variant);
    letter-spacing: -0.01em;
  }

  .category:first-child .category-name {
    border-top: none;
    padding-top: 0;
  }

  .category-items {
    display: flex;
    flex-direction: column;
  }

  /* ── Project Row ── */
  .project-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 14px 12px;
    min-height: 64px;
    border-radius: 8px;
    transition: background 150ms ease-out;
  }

  .project-row:hover {
    background: var(--md-sys-color-surface-container-high);
  }

  .project-row.has-border {
    border-bottom: 1px solid var(--md-sys-color-outline-variant);
  }

  .project-row.has-border:hover {
    border-bottom-color: transparent;
  }

  /* Row left: name + tagline */
  .row-info {
    display: flex;
    align-items: baseline;
    gap: 12px;
    min-width: 0;
    flex: 1;
  }

  .row-name {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--md-sys-color-on-surface);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }

  a.row-name:hover {
    color: var(--md-sys-color-primary);
  }

  .row-tagline {
    font-size: 0.85rem;
    color: var(--md-sys-color-on-surface-variant);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }

  /* Row right: pills + icon links */
  .row-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .pill {
    padding: 4px 10px;
    border-radius: 100px;
    font-size: 0.7rem;
    font-weight: 600;
    white-space: nowrap;
    line-height: 1.3;
  }

  .status-pill {
    background: var(--md-sys-color-secondary-container);
    color: var(--md-sys-color-on-secondary-container);
  }

  .tech-pill {
    background: var(--md-sys-color-primary-container);
    color: var(--md-sys-color-on-primary-container);
  }

  .row-links {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-left: 4px;
  }

  .icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    color: var(--md-sys-color-on-surface-variant);
    text-decoration: none;
    transition: background 150ms ease-out, color 150ms ease-out;
  }

  .icon-link:hover {
    background: var(--md-sys-color-surface-container-highest);
    color: var(--md-sys-color-on-surface);
  }

  .icon-link .material-symbols-rounded {
    font-size: 18px;
  }

  .icon-link .jsr-inline-icon {
    display: block;
  }

  /* ── Mobile (< 768px) ── */
  @media (max-width: 768px) {
    section {
      padding: 32px 0;
    }

    .section-header {
      margin-bottom: 32px;
    }

    h2 {
      font-size: 2rem;
    }

    /* Featured card mobile */
    .featured-card {
      padding: 20px;
      gap: 16px;
      margin-bottom: 28px;
    }

    .featured-header {
      flex-direction: column;
    }

    .featured-badges {
      align-items: flex-start;
    }

    .features-grid {
      grid-template-columns: 1fr;
    }

    .results-stats {
      flex-wrap: wrap;
      gap: 20px;
    }

    .featured-links {
      flex-wrap: wrap;
    }

    /* Project rows mobile: stack */
    .project-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
      padding: 12px;
      min-height: unset;
    }

    .row-info {
      flex-direction: column;
      gap: 2px;
    }

    .row-tagline {
      white-space: normal;
      overflow: visible;
    }

    .row-meta {
      width: 100%;
      flex-wrap: wrap;
      gap: 6px;
    }

    .row-links {
      margin-left: auto;
    }
  }
</style>

<style is:global>
  /* Projects Section Dark Mode */
  html[data-theme="dark"] #projects {
    background: var(--casys-warm-background);
  }

  html[data-theme="dark"] #projects h2 {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #projects .section-subtitle {
    color: var(--casys-warm-text-secondary);
  }

  /* Featured card dark */
  html[data-theme="dark"] #projects .featured-card {
    background: var(--casys-warm-surface);
    border-color: rgba(255, 184, 111, 0.1);
    border-left-color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #projects .featured-card:hover {
    border-color: var(--casys-warm-border-accent-hover);
    border-left-color: var(--casys-warm-accent);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }

  html[data-theme="dark"] #projects .featured-name {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #projects .featured-tagline {
    color: var(--casys-warm-text-secondary);
  }

  html[data-theme="dark"] #projects .status-badge.active {
    background: rgba(255, 184, 111, 0.15);
    color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #projects .license-badge {
    background: rgba(255, 184, 111, 0.1);
    color: var(--casys-warm-text-secondary);
  }

  html[data-theme="dark"] #projects .feature-cell {
    background: rgba(255, 255, 255, 0.03);
  }

  html[data-theme="dark"] #projects .feature-cell .material-symbols-rounded {
    color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #projects .feature-name {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #projects .feature-desc {
    color: var(--casys-warm-text-muted);
  }

  html[data-theme="dark"] #projects .results-stats {
    border-top-color: rgba(255, 255, 255, 0.08);
  }

  html[data-theme="dark"] #projects .stat-value {
    color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #projects .stat-label {
    color: var(--casys-warm-text-muted);
  }

  html[data-theme="dark"] #projects .project-link {
    color: var(--casys-warm-text-secondary);
    border-color: rgba(255, 255, 255, 0.12);
  }

  html[data-theme="dark"] #projects .project-link:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.2);
  }

  /* Category dark */
  html[data-theme="dark"] #projects .category-name {
    color: var(--casys-warm-text-muted);
    border-top-color: rgba(255, 184, 111, 0.1);
  }

  /* Project row dark */
  html[data-theme="dark"] #projects .project-row:hover {
    background: rgba(255, 255, 255, 0.03);
  }

  html[data-theme="dark"] #projects .project-row.has-border {
    border-bottom-color: rgba(255, 255, 255, 0.06);
  }

  html[data-theme="dark"] #projects .project-row.has-border:hover {
    border-bottom-color: transparent;
  }

  html[data-theme="dark"] #projects .row-name {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #projects a.row-name:hover {
    color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #projects .row-tagline {
    color: var(--casys-warm-text-muted);
  }

  html[data-theme="dark"] #projects .status-pill {
    background: rgba(255, 184, 111, 0.12);
    color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #projects .tech-pill {
    background: rgba(255, 255, 255, 0.06);
    color: var(--casys-warm-text-secondary);
  }

  html[data-theme="dark"] #projects .icon-link {
    color: var(--casys-warm-text-muted);
  }

  html[data-theme="dark"] #projects .icon-link:hover {
    background: rgba(255, 255, 255, 0.06);
    color: var(--casys-warm-text-primary);
  }
</style>
