const content = translations[locale as keyof typeof translations] ?? translations.en;
---

<section id="projects">
  <div class="container">
    <!-- Header -->
    <div class="section-header">
      <h2>{content.title}</h2>
      <p class="section-subtitle">{content.subtitle}</p>
    </div>

    <!-- Bento Grid Layout -->
    <div class="bento-grid">

      <!-- MCP Gateway - FEATURED (Large, Left, 2x height) -->
      <div class="project-card featured mcp-gateway">
        <div class="project-header">
          <div>
            <h3 class="project-name">{content.activeProjects[0].name}</h3>
            <p class="project-tagline">{content.activeProjects[0].tagline}</p>
          </div>
          <div class="project-badges">
            <span class="status-badge active">{content.activeProjects[0].status}</span>
            <span class="license-badge">{content.activeProjects[0].license}</span>
          </div>
        </div>

        <!-- Problem -->
        <div class="problem-section">
          <h4>{content.activeProjects[0].problem.title}</h4>
          <ul class="problem-list">
            {content.activeProjects[0].problem.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>

        <!-- Solution Features -->
        <div class="features-grid">
          {content.activeProjects[0].solution.features.map((feature) => (
            <div class="feature-card">
              <span class="material-symbols-rounded">{feature.icon}</span>
              <div>
                <div class="feature-name">{feature.name}</div>
                <div class="feature-description">{feature.description}</div>
              </div>
            </div>
          ))}
        </div>

        <!-- Results Stats -->
        <div class="results-stats">
          {content.activeProjects[0].results.map((result) => (
            <div class="result-stat">
              <div class="stat-value">{result.stat}</div>
              <div class="stat-label">{result.label}</div>
            </div>
          ))}
        </div>

        <!-- Links -->
        <div class="project-links">
          {content.activeProjects[0].links.website && (
            <a href={content.activeProjects[0].links.website} class="project-link primary" target="_blank" rel="noopener noreferrer">
              <span class="material-symbols-rounded">public</span>
              <span>Website</span>
            </a>
          )}
          {content.activeProjects[0].links.github && (
            <a href={content.activeProjects[0].links.github} class="project-link" target="_blank" rel="noopener noreferrer">
              <span class="material-symbols-rounded">code</span>
              <span>GitHub</span>
            </a>
          )}
          {content.activeProjects[0].links.docs && content.activeProjects[0].links.docs !== '#' && (
            <a href={content.activeProjects[0].links.docs} class="project-link" target="_blank" rel="noopener noreferrer">
              <span class="material-symbols-rounded">description</span>
              <span>Docs</span>
            </a>
          )}
        </div>
      </div>

      <!-- Sub-projects grid (mcp-std, mcp-server, engine, casysdb) -->
      {content.activeProjects.slice(1).map((project) => (
        <div class={`project-card medium ${project.id}`}>
          <div class="project-header-compact">
            <h3 class="project-name">{project.name}</h3>
            <p class="project-tagline">{project.tagline}</p>
          </div>

          <span class="status-badge active">{project.status}</span>

          <div class="features-compact">
            {project.features.map((feature) => (
              <div class="feature-item">
                <span class="material-symbols-rounded">{feature.icon}</span>
                <div>
                  <div class="feature-name">{feature.name}</div>
                  <div class="feature-description">{feature.description}</div>
                </div>
              </div>
            ))}
          </div>

          <div class="project-links compact">
            {project.links.website && (
              <a href={project.links.website} class="project-link" target="_blank" rel="noopener">
                <span class="material-symbols-rounded">public</span>
                <span>Website</span>
              </a>
            )}
            {project.links.github && (
              <a href={project.links.github} class="project-link" target="_blank" rel="noopener">
                <span class="material-symbols-rounded">code</span>
                <span>GitHub</span>
              </a>
            )}
            {project.links.jsr && (
              <a href={project.links.jsr} class="project-link" target="_blank" rel="noopener">
                <span class="material-symbols-rounded">package_2</span>
                <span>JSR</span>
              </a>
            )}
          </div>
        </div>
      ))}

      <!-- Archived Projects - Medium (Bottom Right) -->
      <div class="project-card medium archived">
        <div class="archived-header">
          <span class="material-symbols-rounded">archive</span>
          <h3>{content.archivedProjects.title}</h3>
        </div>
        <p class="archived-description">{content.archivedProjects.description}</p>

        <div class="archived-list">
          {content.archivedProjects.projects.map((project) => (
            <div class="archived-item">
              <div class="archived-name">{project.name}</div>
              <div class="archived-tagline">{project.tagline}</div>
              <div class="archived-desc">{project.description}</div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>


<style>
  section {
    padding: 80px 0;
    background: var(--md-sys-color-surface);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .section-header {
    text-align: left;
    margin-bottom: 48px;
    max-width: 600px;
  }

  h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 2.5rem;
    font-weight: 600;
    font-optical-sizing: auto;
    color: var(--md-sys-color-on-surface);
    margin: 0 0 12px;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
    line-height: 1.6;
  }

  /* BENTO GRID LAYOUT */
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    align-items: start;
  }

  /* Featured Project - Full width */
  .project-card.featured {
    grid-column: 1 / -1;
  }

  /* Archived - Full width */
  .project-card.archived {
    grid-column: 1 / -1;
  }

  /* Base Project Card - Clean, minimal */
  .project-card {
    padding: 32px;
    background: var(--md-sys-color-surface-container-lowest);
    border-radius: 16px;
    transition: border-color 200ms ease-out, box-shadow 200ms ease-out;
    display: flex;
    flex-direction: column;
    gap: 24px;
    border: 1px solid var(--md-sys-color-outline-variant);
    position: relative;
    overflow: hidden;
  }

  .project-card:hover {
    border-color: var(--md-sys-color-primary);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  /* Featured Card (MCP Gateway) - Subtle accent */
  .project-card.featured {
    background: var(--md-sys-color-surface-container-lowest);
    border-left: 4px solid var(--md-sys-color-primary);
  }

  .project-card.featured::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(180, 130, 90, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  /* Project Header */
  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 20px;
  }

  .project-header-compact {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .project-name {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--md-sys-color-on-surface);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .medium .project-name {
    font-size: 1.25rem;
  }

  .project-tagline {
    font-size: 0.95rem;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
    font-weight: 500;
  }

  .medium .project-tagline {
    font-size: 0.875rem;
  }

  .project-badges {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: flex-end;
  }

  .status-badge {
    padding: 8px 16px;
    border-radius: 100px;
    font-size: var(--md-sys-typescale-label-medium-size);
    font-weight: 600;
    white-space: nowrap;
  }

  .status-badge.active {
    background: var(--md-sys-color-secondary-container);
    color: var(--md-sys-color-on-secondary-container);
  }

  .license-badge {
    padding: 6px 12px;
    background: var(--md-sys-color-primary-container);
    color: var(--md-sys-color-on-primary-container);
    border-radius: 8px;
    font-size: var(--md-sys-typescale-label-small-size);
    font-weight: 600;
  }

  /* Problem Section */
  .problem-section h4 {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--md-sys-color-on-surface-variant);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 12px;
  }

  .problem-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .problem-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 8px 0;
    color: var(--md-sys-color-on-surface-variant);
    font-size: 0.875rem;
    border-bottom: 1px solid var(--md-sys-color-outline-variant);
  }

  .problem-list li:last-child {
    border-bottom: none;
  }

  .problem-list li::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--md-sys-color-error);
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 6px;
  }

  /* Features Grid */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
  }

  .feature-card {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 16px;
    background: var(--md-sys-color-surface-container-high);
    border-radius: 12px;
  }

  .feature-card .material-symbols-rounded {
    font-size: 28px;
    color: var(--md-sys-color-primary);
    flex-shrink: 0;
  }

  .feature-name {
    font-size: var(--md-sys-typescale-title-small-size);
    font-weight: 600;
    color: var(--md-sys-color-on-surface);
    margin-bottom: 2px;
  }

  .feature-description {
    font-size: var(--md-sys-typescale-body-small-size);
    color: var(--md-sys-color-on-surface-variant);
  }

  /* Features Compact (for medium cards) */
  .features-compact {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }

  .feature-item .material-symbols-rounded {
    font-size: 20px;
    color: var(--md-sys-color-primary);
    flex-shrink: 0;
  }

  /* Results Stats */
  .results-stats {
    display: flex;
    gap: 32px;
    padding-top: 16px;
    border-top: 1px solid var(--md-sys-color-outline-variant);
  }

  .result-stat {
    text-align: left;
  }

  .stat-value {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 2rem;
    font-weight: 600;
    color: var(--md-sys-color-primary);
    line-height: 1;
    margin-bottom: 4px;
  }

  .stat-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--md-sys-color-on-surface-variant);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Project Links */
  .project-links {
    display: flex;
    gap: 16px;
    margin-top: auto;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background: transparent;
    color: var(--md-sys-color-on-surface);
    border: 1px solid var(--md-sys-color-outline-variant);
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 150ms ease-out, border-color 150ms ease-out;
  }

  .project-link:hover {
    background: var(--md-sys-color-surface-container-high);
    border-color: var(--md-sys-color-outline);
  }

  .project-link .material-symbols-rounded {
    font-size: 16px;
    opacity: 0.7;
  }


  /* Archived Section */
  .archived-header {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .archived-header .material-symbols-rounded {
    font-size: 28px;
    color: var(--md-sys-color-secondary);
  }

  .archived-header h3 {
    font-size: var(--md-sys-typescale-title-large-size);
    font-weight: 600;
    color: var(--md-sys-color-on-surface);
    margin: 0;
  }

  .archived-description {
    font-size: var(--md-sys-typescale-body-medium-size);
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
  }

  .archived-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .archived-item {
    padding: 16px;
    background: var(--md-sys-color-surface-container-high);
    border-radius: 12px;
  }

  .archived-name {
    font-size: var(--md-sys-typescale-title-small-size);
    font-weight: 600;
    color: var(--md-sys-color-on-surface);
    margin-bottom: 4px;
  }

  .archived-tagline {
    font-size: var(--md-sys-typescale-body-small-size);
    color: var(--md-sys-color-secondary);
    margin-bottom: 8px;
  }

  .archived-desc {
    font-size: var(--md-sys-typescale-body-small-size);
    color: var(--md-sys-color-on-surface-variant);
  }

  /* Tablet & Mobile Responsive */
  @media (max-width: 1024px) {
    .bento-grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }

    .project-card.featured,
    .project-card.casysdb,
    .project-card.archived {
      grid-column: 1 / 2;
      grid-row: auto;
    }
  }

  @media (max-width: 768px) {
    section {
      padding: 40px 0;
    }

    .project-card {
      padding: 24px;
      gap: 20px;
    }

    .project-header {
      flex-direction: column;
    }

    .project-badges {
      align-items: flex-start;
    }

    .features-grid {
      grid-template-columns: 1fr;
    }

    .results-stats {
      grid-template-columns: 1fr;
    }

    .project-links {
      flex-direction: column;
    }
  }

</style>

