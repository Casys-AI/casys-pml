---
import { useTranslations } from '../../i18n';
const locale = (Astro as any).currentLocale ?? 'en';
const content = useTranslations(locale).projects;
---

<section id="projects">
  <div class="container">
    <!-- Header -->
    <div class="section-header">
      <h2>{content.title}</h2>
      <p class="section-subtitle">{content.subtitle}</p>
    </div>

    <!-- Bento Grid Layout -->
    <div class="bento-grid">

      <!-- MCP Gateway - FEATURED (Large, Left, 2x height) -->
      <div class="project-card featured mcp-gateway">
        <div class="project-header">
          <div>
            <h3 class="project-name">{content.activeProjects[0].name}</h3>
            <p class="project-tagline">{content.activeProjects[0].tagline}</p>
          </div>
          <div class="project-badges">
            <span class="status-badge active">{content.activeProjects[0].status}</span>
            <span class="license-badge">{content.activeProjects[0].license}</span>
          </div>
        </div>

        <!-- Features -->
        <div class="features-grid">
          {content.activeProjects[0].features.map((feature) => (
            <div class="feature-card">
              <span class="material-symbols-rounded">{feature.icon}</span>
              <div>
                <div class="feature-name">{feature.name}</div>
                <div class="feature-description">{feature.description}</div>
              </div>
            </div>
          ))}
        </div>

        <!-- Results Stats -->
        <div class="results-stats">
          {content.activeProjects[0].results.map((result) => (
            <div class="result-stat">
              <div class="stat-value">{result.stat}</div>
              <div class="stat-label">{result.label}</div>
            </div>
          ))}
        </div>

        <!-- Links -->
        <div class="project-links">
          {content.activeProjects[0].links.website && (
            <a href={content.activeProjects[0].links.website} class="project-link primary" target="_blank" rel="noopener noreferrer">
              <span class="material-symbols-rounded">public</span>
              <span>Website</span>
            </a>
          )}
          {content.activeProjects[0].links.github && (
            <a href={content.activeProjects[0].links.github} class="project-link" target="_blank" rel="noopener noreferrer">
              <span class="material-symbols-rounded">code</span>
              <span>GitHub</span>
            </a>
          )}
          {content.activeProjects[0].links.docs && content.activeProjects[0].links.docs !== '#' && (
            <a href={content.activeProjects[0].links.docs} class="project-link" target="_blank" rel="noopener noreferrer">
              <span class="material-symbols-rounded">description</span>
              <span>Docs</span>
            </a>
          )}
        </div>
      </div>

      <!-- Sub-projects grid (mcp-std, mcp-server, engine) -->
      {content.activeProjects.slice(1).map((project) => (
        <div class={`project-card medium ${project.id}`}>
          <div class="project-header-compact">
            <h3 class="project-name">{project.name}</h3>
            <p class="project-tagline">{project.tagline}</p>
          </div>

          <span class="status-badge active">{project.status}</span>

          <div class="features-compact">
            {project.features.map((feature) => (
              <div class="feature-item">
                <span class="material-symbols-rounded">{feature.icon}</span>
                <div>
                  <div class="feature-name">{feature.name}</div>
                  <div class="feature-description">{feature.description}</div>
                </div>
              </div>
            ))}
          </div>

          <div class="project-links compact">
            {project.links.website && (
              <a href={project.links.website} class="project-link" target="_blank" rel="noopener">
                <span class="material-symbols-rounded">public</span>
                <span>Website</span>
              </a>
            )}
            {project.links.github && (
              <a href={project.links.github} class="project-link" target="_blank" rel="noopener">
                <span class="material-symbols-rounded">code</span>
                <span>GitHub</span>
              </a>
            )}
            {project.links.jsr && (
              <a href={project.links.jsr} class="project-link" target="_blank" rel="noopener">
                <svg class="jsr-inline-icon" width="16" height="16" viewBox="0 -3 64 64" fill="none" aria-hidden="true"><path d="M 0,21.846 H 9.846 V 12 h 34.462 v 4.923 H 64 V 36.616 H 54.155 V 46.462 H 19.693 V 41.539 H 0" fill="#083344"/><g fill="#f7df1e" transform="matrix(4.923,0,0,4.923,0,12)"><path d="M 1,3 H 2 V 4 H 3 V 1 H 4 V 5 H 1"/><path d="M 5,1 H 8 V 2 H 6 V 3 H 8 V 6 H 5 V 5 H 7 V 4 H 5"/><path d="m 9,2 h 3 V 4 H 11 V 3 H 10 V 6 H 9"/></g></svg>
                <span>JSR</span>
              </a>
            )}
          </div>
        </div>
      ))}

    </div>
  </div>
</section>


<style>
  section {
    padding: 80px 0;
    background: var(--md-sys-color-surface);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .section-header {
    text-align: left;
    margin-bottom: 48px;
    max-width: 600px;
  }

  h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 2.5rem;
    font-weight: 600;
    font-optical-sizing: auto;
    color: var(--md-sys-color-on-surface);
    margin: 0 0 12px;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
    line-height: 1.6;
  }

  /* BENTO GRID LAYOUT */
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    align-items: start;
  }

  /* Featured Project - Full width */
  .project-card.featured {
    grid-column: 1 / -1;
  }

  /* Base Project Card - Clean, minimal */
  .project-card {
    padding: 32px;
    background: var(--md-sys-color-surface-container-lowest);
    border-radius: 16px;
    transition: border-color 200ms ease-out, box-shadow 200ms ease-out;
    display: flex;
    flex-direction: column;
    gap: 24px;
    border: 1px solid var(--md-sys-color-outline-variant);
    position: relative;
    overflow: hidden;
  }

  .project-card:hover {
    border-color: var(--md-sys-color-primary);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  /* Featured Card (MCP Gateway) - Subtle accent */
  .project-card.featured {
    background: var(--md-sys-color-surface-container-lowest);
    border-left: 4px solid var(--md-sys-color-primary);
  }

  .project-card.featured::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(180, 130, 90, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  /* Project Header */
  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 20px;
  }

  .project-header-compact {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .project-name {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--md-sys-color-on-surface);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .medium .project-name {
    font-size: 1.25rem;
  }

  .project-tagline {
    font-size: 0.95rem;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
    font-weight: 500;
  }

  .medium .project-tagline {
    font-size: 0.875rem;
  }

  .project-badges {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: flex-end;
  }

  .status-badge {
    padding: 8px 16px;
    border-radius: 100px;
    font-size: var(--md-sys-typescale-label-medium-size);
    font-weight: 600;
    white-space: nowrap;
  }

  .status-badge.active {
    background: var(--md-sys-color-secondary-container);
    color: var(--md-sys-color-on-secondary-container);
  }

  .license-badge {
    padding: 6px 12px;
    background: var(--md-sys-color-primary-container);
    color: var(--md-sys-color-on-primary-container);
    border-radius: 8px;
    font-size: var(--md-sys-typescale-label-small-size);
    font-weight: 600;
  }

  /* Features Grid */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
  }

  .feature-card {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 16px;
    background: var(--md-sys-color-surface-container-high);
    border-radius: 12px;
  }

  .feature-card .material-symbols-rounded {
    font-size: 28px;
    color: var(--md-sys-color-primary);
    flex-shrink: 0;
  }

  .feature-name {
    font-size: var(--md-sys-typescale-title-small-size);
    font-weight: 600;
    color: var(--md-sys-color-on-surface);
    margin-bottom: 2px;
  }

  .feature-description {
    font-size: var(--md-sys-typescale-body-small-size);
    color: var(--md-sys-color-on-surface-variant);
  }

  /* Features Compact (for medium cards) */
  .features-compact {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }

  .feature-item .material-symbols-rounded {
    font-size: 20px;
    color: var(--md-sys-color-primary);
    flex-shrink: 0;
  }

  /* Results Stats */
  .results-stats {
    display: flex;
    gap: 32px;
    padding-top: 16px;
    border-top: 1px solid var(--md-sys-color-outline-variant);
  }

  .result-stat {
    text-align: left;
  }

  .stat-value {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 2rem;
    font-weight: 600;
    color: var(--md-sys-color-primary);
    line-height: 1;
    margin-bottom: 4px;
  }

  .stat-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--md-sys-color-on-surface-variant);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Project Links */
  .project-links {
    display: flex;
    gap: 16px;
    margin-top: auto;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background: transparent;
    color: var(--md-sys-color-on-surface);
    border: 1px solid var(--md-sys-color-outline-variant);
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 150ms ease-out, border-color 150ms ease-out;
  }

  .project-link:hover {
    background: var(--md-sys-color-surface-container-high);
    border-color: var(--md-sys-color-outline);
  }

  .project-link .material-symbols-rounded {
    font-size: 16px;
    opacity: 0.7;
  }


  /* Tablet & Mobile Responsive */
  @media (max-width: 1024px) {
    .bento-grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }

    .project-card.featured {
      grid-column: 1 / 2;
      grid-row: auto;
    }
  }

  @media (max-width: 768px) {
    section {
      padding: 40px 0;
    }

    .project-card {
      padding: 24px;
      gap: 20px;
    }

    .project-header {
      flex-direction: column;
    }

    .project-badges {
      align-items: flex-start;
    }

    .features-grid {
      grid-template-columns: 1fr;
    }

    .results-stats {
      grid-template-columns: 1fr;
    }

    .project-links {
      flex-direction: column;
    }
  }

</style>

<style is:global>
  /* Projects Section Dark Mode */
  html[data-theme="dark"] #projects {
    background: var(--casys-warm-background);
  }

  html[data-theme="dark"] #projects h2 {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #projects .section-subtitle {
    color: var(--casys-warm-text-secondary);
  }

  html[data-theme="dark"] #projects .project-card {
    background: var(--casys-warm-surface);
    border-color: rgba(255, 184, 111, 0.1);
  }

  html[data-theme="dark"] #projects .project-card:hover {
    border-color: var(--casys-warm-border-accent-hover);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }

  html[data-theme="dark"] #projects .project-card.featured {
    border-left-color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #projects .project-name {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #projects .project-tagline {
    color: var(--casys-warm-text-secondary);
  }

  html[data-theme="dark"] #projects .status-badge.active {
    background: rgba(255, 184, 111, 0.15);
    color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #projects .license-badge {
    background: rgba(255, 184, 111, 0.1);
    color: var(--casys-warm-text-secondary);
  }

  html[data-theme="dark"] #projects .feature-card {
    background: rgba(255, 255, 255, 0.03);
  }

  html[data-theme="dark"] #projects .feature-card .material-symbols-rounded {
    color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #projects .feature-name {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #projects .feature-description {
    color: var(--casys-warm-text-muted);
  }

  html[data-theme="dark"] #projects .results-stats {
    border-top-color: rgba(255, 255, 255, 0.08);
  }

  html[data-theme="dark"] #projects .stat-value {
    color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #projects .stat-label {
    color: var(--casys-warm-text-muted);
  }

  html[data-theme="dark"] #projects .project-link {
    color: var(--casys-warm-text-secondary);
    border-color: rgba(255, 255, 255, 0.12);
  }

  html[data-theme="dark"] #projects .project-link:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.2);
  }

  html[data-theme="dark"] #projects .feature-item .material-symbols-rounded {
    color: var(--casys-warm-accent);
  }
</style>

