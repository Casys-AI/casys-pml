const content = translations[locale] ?? translations.en;
---

<section id="why-casys">
  <div class="container">
    <div class="section-header">
      <h2>{content.title}</h2>
      <p class="section-subtitle">{content.subtitle}</p>
    </div>

    <!-- Bento Grid: Asymmetric 5-card layout -->
    <div class="bento-grid">

      <!-- Multi-Domain - Large Featured (Top Left, 2 cols) -->
      <div class="diff-card multi-domain">
        <span class="material-symbols-rounded icon">{content.differentiation[0].icon}</span>
        <h3>{content.differentiation[0].title}</h3>
        <p class="description">{content.differentiation[0].description}</p>
        <div class="highlights">
          {content.differentiation[0].highlights.map((h) => (
            <div class="highlight-item">
              <span class="material-symbols-rounded">check_circle</span>
              <span>{h}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Continuity - Top Right -->
      <div class="diff-card continuity">
        <span class="material-symbols-rounded icon">{content.differentiation[1].icon}</span>
        <h3>{content.differentiation[1].title}</h3>
        <p class="description">{content.differentiation[1].description}</p>
        <div class="highlights">
          {content.differentiation[1].highlights.map((h) => (
            <div class="highlight-item">
              <span class="material-symbols-rounded">check_circle</span>
              <span>{h}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Open Source - Middle Left -->
      <div class="diff-card opensource">
        <span class="material-symbols-rounded icon">{content.differentiation[2].icon}</span>
        <h3>{content.differentiation[2].title}</h3>
        <p class="description">{content.differentiation[2].description}</p>
        <div class="highlights">
          {content.differentiation[2].highlights.map((h) => (
            <div class="highlight-item">
              <span class="material-symbols-rounded">check_circle</span>
              <span>{h}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Practical - Middle Right (Tall, 2 rows) -->
      <div class="diff-card practical">
        <span class="material-symbols-rounded icon">{content.differentiation[3].icon}</span>
        <h3>{content.differentiation[3].title}</h3>
        <p class="description">{content.differentiation[3].description}</p>
        <div class="highlights">
          {content.differentiation[3].highlights.map((h) => (
            <div class="highlight-item">
              <span class="material-symbols-rounded">check_circle</span>
              <span>{h}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Accessible - Bottom Left (Wide, 2 cols) -->
      <div class="diff-card accessible">
        <span class="material-symbols-rounded icon">{content.differentiation[4].icon}</span>
        <h3>{content.differentiation[4].title}</h3>
        <p class="description">{content.differentiation[4].description}</p>
        <div class="highlights">
          {content.differentiation[4].highlights.map((h) => (
            <div class="highlight-item">
              <span class="material-symbols-rounded">check_circle</span>
              <span>{h}</span>
            </div>
          ))}
        </div>
      </div>

    </div>

    <!-- Bottom Line -->
    <div class="bottom-line">
      <p class="bottom-line-text">{content.bottomLine.text}</p>
      <div class="bottom-line-ctas">
        <a href={content.bottomLine.cta.primary.url} class="bottom-line-cta primary" target="_blank" rel="noopener noreferrer">
          <span class="material-symbols-rounded">{content.bottomLine.cta.primary.icon}</span>
          <span>{content.bottomLine.cta.primary.text}</span>
        </a>
        <a href={content.bottomLine.cta.secondary.url} class="bottom-line-cta secondary">
          <span class="material-symbols-rounded">{content.bottomLine.cta.secondary.icon}</span>
          <span>{content.bottomLine.cta.secondary.text}</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  /* ========================================
     WHY CASYS - Editorial/Refined Aesthetic
     Font: Fraunces for headlines
     Palette: Warm orange for dark mode
     ======================================== */

  section {
    padding: 80px 0;
    background: var(--md-sys-color-surface-container-low);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Left-aligned header - editorial style */
  .section-header {
    text-align: left;
    margin-bottom: 48px;
    max-width: 600px;
  }

  h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 2.5rem;
    font-weight: 600;
    font-optical-sizing: auto;
    color: var(--md-sys-color-on-surface);
    margin: 0 0 12px;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
    line-height: 1.6;
  }

  /* BENTO GRID - Asymmetric 5-card layout */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(3, auto);
    gap: 24px;
    margin-bottom: 48px;
    align-items: start;
  }

  /* Multi-Domain - Large Featured (Top, 2 cols wide) */
  .diff-card.multi-domain {
    grid-column: 1 / 3;
    grid-row: 1 / 2;
  }

  /* Continuity - Top Right */
  .diff-card.continuity {
    grid-column: 3 / 4;
    grid-row: 1 / 2;
  }

  /* Open Source - Middle Left */
  .diff-card.opensource {
    grid-column: 1 / 2;
    grid-row: 2 / 3;
  }

  /* Practical - Middle Right (Tall, 2 rows) */
  .diff-card.practical {
    grid-column: 2 / 4;
    grid-row: 2 / 3;
  }

  /* Accessible - Bottom (Wide, 2 cols) */
  .diff-card.accessible {
    grid-column: 1 / 3;
    grid-row: 3 / 4;
  }

  /* Base Card - Clean editorial style */
  .diff-card {
    padding: 32px;
    background: var(--md-sys-color-surface-container-lowest);
    border-radius: 16px;
    border: 1px solid var(--md-sys-color-outline-variant);
    transition: border-color 200ms ease-out, box-shadow 200ms ease-out;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .diff-card:hover {
    border-color: var(--md-sys-color-primary);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  /* Featured cards with left accent */
  .diff-card.multi-domain {
    border-left: 4px solid var(--md-sys-color-primary);
  }

  .icon {
    font-size: 32px;
    color: var(--md-sys-color-primary);
  }

  h3 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.35rem;
    font-weight: 600;
    font-optical-sizing: auto;
    color: var(--md-sys-color-on-surface);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .description {
    font-size: var(--md-sys-typescale-body-large-size);
    color: var(--md-sys-color-on-surface-variant);
    line-height: 1.6;
    margin: 0;
  }

  .highlights {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: auto;
  }

  .highlight-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: var(--md-sys-typescale-body-medium-size);
    color: var(--md-sys-color-on-surface-variant);
  }

  .highlight-item .material-symbols-rounded {
    font-size: 20px;
    color: var(--md-sys-color-secondary);
    flex-shrink: 0;
  }

  /* Bottom Line - Clean editorial CTA */
  .bottom-line {
    padding: 32px;
    background: var(--md-sys-color-surface-container);
    border-radius: 16px;
    border: 1px solid var(--md-sys-color-outline-variant);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .bottom-line-text {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--md-sys-color-on-surface);
    line-height: 1.6;
    margin: 0;
    max-width: 700px;
  }

  .bottom-line-ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .bottom-line-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 200ms ease-out, border-color 200ms ease-out;
  }

  .bottom-line-cta.primary {
    background: var(--md-sys-color-primary);
    color: var(--md-sys-color-on-primary);
  }

  .bottom-line-cta.primary:hover {
    background: var(--md-sys-color-primary-container);
    color: var(--md-sys-color-on-primary-container);
  }

  .bottom-line-cta.secondary {
    background: transparent;
    color: var(--md-sys-color-primary);
    border: 1px solid var(--md-sys-color-outline-variant);
  }

  .bottom-line-cta.secondary:hover {
    border-color: var(--md-sys-color-primary);
    background: var(--md-sys-color-surface-container-high);
  }

  .bottom-line-cta .material-symbols-rounded {
    font-size: 20px;
  }

  /* Tablet: 2-column grid */
  @media (max-width: 1024px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: auto;
    }

    .diff-card.multi-domain {
      grid-column: 1 / 3;
      grid-row: auto;
    }

    .diff-card.continuity,
    .diff-card.opensource,
    .diff-card.practical {
      grid-column: auto;
      grid-row: auto;
    }

    .diff-card.accessible {
      grid-column: 1 / 3;
      grid-row: auto;
    }
  }

  /* Mobile: Single column */
  @media (max-width: 768px) {
    section {
      padding: 40px 0;
    }

    .bento-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .diff-card.multi-domain,
    .diff-card.continuity,
    .diff-card.opensource,
    .diff-card.practical,
    .diff-card.accessible {
      grid-column: 1 / 2;
      grid-row: auto;
    }

    .diff-card {
      padding: 24px;
      gap: 14px;
    }

    .bottom-line {
      padding: 24px;
      gap: 20px;
    }
  }

</style>

<style is:global>
  /* ========================================
     WHY CASYS - DARK MODE
     Warm orange palette (#FFB86F, #D4A574)
     ======================================== */

  html[data-theme="dark"] #why-casys {
    background: #0a0908;
  }

  html[data-theme="dark"] #why-casys h2 {
    color: #f5f0ea;
  }

  html[data-theme="dark"] #why-casys .section-subtitle {
    color: #d5c3b5;
  }

  /* Cards */
  html[data-theme="dark"] #why-casys .diff-card {
    background: #1a1815;
    border-color: rgba(255, 184, 111, 0.1);
  }

  html[data-theme="dark"] #why-casys .diff-card:hover {
    border-color: rgba(255, 184, 111, 0.3);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
  }

  html[data-theme="dark"] #why-casys .diff-card.multi-domain {
    border-left-color: #FFB86F;
  }

  html[data-theme="dark"] #why-casys .icon {
    color: #FFB86F;
  }

  html[data-theme="dark"] #why-casys h3 {
    color: #f5f0ea;
  }

  html[data-theme="dark"] #why-casys .description {
    color: #d5c3b5;
  }

  html[data-theme="dark"] #why-casys .highlight-item {
    color: #d5c3b5;
  }

  html[data-theme="dark"] #why-casys .highlight-item .material-symbols-rounded {
    color: #FFB86F;
  }

  /* Bottom Line */
  html[data-theme="dark"] #why-casys .bottom-line {
    background: #1a1815;
    border-color: rgba(255, 184, 111, 0.1);
  }

  html[data-theme="dark"] #why-casys .bottom-line-text {
    color: #f5f0ea;
  }

  html[data-theme="dark"] #why-casys .bottom-line-cta.primary {
    background: #FFB86F;
    color: #1a1815;
  }

  html[data-theme="dark"] #why-casys .bottom-line-cta.primary:hover {
    background: #D4A574;
  }

  html[data-theme="dark"] #why-casys .bottom-line-cta.secondary {
    color: #FFB86F;
    border-color: rgba(255, 184, 111, 0.2);
  }

  html[data-theme="dark"] #why-casys .bottom-line-cta.secondary:hover {
    border-color: #FFB86F;
    background: rgba(255, 184, 111, 0.1);
  }
</style>
