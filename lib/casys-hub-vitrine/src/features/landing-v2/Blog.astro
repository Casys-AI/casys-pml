---
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n';

const locale = (Astro as any).currentLocale ?? 'en';
const t = useTranslations(locale).blog;

// Load blog posts from content collection
const allPosts = await getCollection('blog');

// Filter: match locale, exclude drafts, sort by date descending, take 3
const posts = allPosts
  .filter((post) => post.data.language === locale && !post.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

// Build locale-aware blog URLs
const blogPrefix = locale === 'en' ? '/blog' : `/${locale}/blog`;
function getBlogUrl(post: typeof posts[0]): string {
  const slug = post.slug.replace(`${locale}/`, '');
  return `${blogPrefix}/${slug}`;
}

// Date formatter per locale
const dateLocaleMap: Record<string, string> = {
  en: 'en-US',
  fr: 'fr-FR',
  zh: 'zh-CN',
};

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat(dateLocaleMap[locale] ?? 'en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(new Date(date));
}
---

<section id="blog">
  <div class="container">
    <!-- Header -->
    <div class="section-header">
      <h2>{t.title}</h2>
      <p class="section-subtitle">{t.subtitle}</p>
    </div>

    {posts.length > 0 ? (
      <!-- Blog Cards Grid -->
      <div class="blog-grid">
        {posts.map((post) => (
          <a href={getBlogUrl(post)} class="blog-card">
            <div class="blog-card-inner">
              <!-- Meta: date + category -->
              <div class="blog-meta">
                <time datetime={new Date(post.data.date).toISOString()}>
                  {formatDate(post.data.date)}
                </time>
                {post.data.category && (
                  <span class="category-badge">{post.data.category}</span>
                )}
              </div>

              <!-- Title -->
              <h3 class="blog-title">{post.data.title}</h3>

              <!-- Snippet -->
              <p class="blog-snippet">
                {post.data.snippet ?? post.data.description ?? ''}
              </p>

              <!-- Read link -->
              <span class="read-link">
                {t.readMore} <span aria-hidden="true">&rarr;</span>
              </span>
            </div>
          </a>
        ))}
      </div>

      <!-- View all CTA -->
      <div class="view-all-wrapper">
        <a href={blogPrefix} class="view-all-link">
          {t.viewAll} <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    ) : (
      <p class="no-posts">No posts available.</p>
    )}
  </div>
</section>

<style>
  /* ============================================
     BLOG SECTION - Editorial/Refined Aesthetic
     Font: Fraunces for headlines
     Palette: Warm orange for dark mode
     ============================================ */

  section {
    padding: 80px 0;
    background: var(--md-sys-color-surface-container-lowest);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Left-aligned header - editorial style */
  .section-header {
    text-align: left;
    margin-bottom: 48px;
    max-width: 600px;
  }

  h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 2.5rem;
    font-weight: 600;
    font-optical-sizing: auto;
    color: var(--md-sys-color-on-surface);
    margin: 0 0 12px;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
    line-height: 1.6;
  }

  /* Blog Cards Grid */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 48px;
  }

  /* Blog Card */
  .blog-card {
    text-decoration: none;
    display: block;
    border-radius: 16px;
    border: 1px solid var(--md-sys-color-outline-variant);
    background: var(--md-sys-color-surface-container-lowest);
    transition: border-color 200ms ease-out, box-shadow 200ms ease-out;
    overflow: hidden;
  }

  .blog-card:hover {
    border-color: var(--md-sys-color-primary);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .blog-card:focus-visible {
    outline: 3px solid var(--md-sys-color-primary);
    outline-offset: 4px;
  }

  .blog-card-inner {
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    height: 100%;
  }

  /* Meta row: date + category */
  .blog-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .blog-meta time {
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--md-sys-color-on-surface-variant);
    letter-spacing: 0.01em;
  }

  .category-badge {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    background: var(--md-sys-color-secondary-container);
    color: var(--md-sys-color-on-secondary-container);
    white-space: nowrap;
  }

  /* Title */
  .blog-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.125rem;
    font-weight: 600;
    font-optical-sizing: auto;
    color: var(--md-sys-color-on-surface);
    margin: 0;
    letter-spacing: -0.01em;
    line-height: 1.4;
  }

  /* Snippet: 2-line clamp */
  .blog-snippet {
    font-size: 0.875rem;
    color: var(--md-sys-color-on-surface-variant);
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Read link */
  .read-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--md-sys-color-primary);
    text-decoration: none;
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: text-decoration 200ms ease-out;
  }

  .blog-card:hover .read-link {
    text-decoration: underline;
  }

  /* View all CTA */
  .view-all-wrapper {
    text-align: center;
  }

  .view-all-link {
    font-size: 1rem;
    font-weight: 600;
    color: var(--md-sys-color-primary);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 12px 24px;
    border: 1px solid var(--md-sys-color-outline-variant);
    border-radius: 8px;
    transition: background 200ms ease-out, border-color 200ms ease-out;
  }

  .view-all-link:hover {
    border-color: var(--md-sys-color-primary);
    background: var(--md-sys-color-surface-container-high);
  }

  .view-all-link:focus-visible {
    outline: 3px solid var(--md-sys-color-primary);
    outline-offset: 4px;
  }

  /* No posts fallback */
  .no-posts {
    text-align: center;
    font-size: 1rem;
    color: var(--md-sys-color-on-surface-variant);
    padding: 48px 0;
  }

  /* ============================================
     RESPONSIVE - Tablet
     ============================================ */
  @media (max-width: 1024px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    /* Hide third card on tablet to keep layout balanced */
    .blog-card:nth-child(3) {
      display: none;
    }
  }

  /* ============================================
     RESPONSIVE - Mobile
     ============================================ */
  @media (max-width: 768px) {
    section {
      padding: 40px 0;
    }

    h2 {
      font-size: 2rem;
    }

    .blog-grid {
      grid-template-columns: 1fr;
      gap: 20px;
      margin-bottom: 32px;
    }

    /* Show all cards on mobile (single column) */
    .blog-card:nth-child(3) {
      display: block;
    }

    .blog-card-inner {
      padding: 24px;
      gap: 12px;
    }

    .view-all-link {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<style is:global>
  /* ============================================
     BLOG SECTION - DARK MODE
     Warm orange palette (#FFB86F, #D4A574)
     ============================================ */

  html[data-theme="dark"] #blog {
    background: #0f0e0c;
  }

  html[data-theme="dark"] #blog h2 {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #blog .section-subtitle {
    color: var(--casys-warm-text-secondary);
  }

  /* Blog Cards */
  html[data-theme="dark"] #blog .blog-card {
    background: var(--casys-warm-surface);
    border-color: rgba(255, 184, 111, 0.1);
  }

  html[data-theme="dark"] #blog .blog-card:hover {
    border-color: var(--casys-warm-border-accent-hover);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
  }

  /* Meta */
  html[data-theme="dark"] #blog .blog-meta time {
    color: var(--casys-warm-text-muted);
  }

  html[data-theme="dark"] #blog .category-badge {
    background: rgba(255, 184, 111, 0.15);
    color: var(--casys-warm-accent);
  }

  /* Title */
  html[data-theme="dark"] #blog .blog-title {
    color: var(--casys-warm-text-primary);
  }

  /* Snippet */
  html[data-theme="dark"] #blog .blog-snippet {
    color: var(--casys-warm-text-secondary);
  }

  /* Read link */
  html[data-theme="dark"] #blog .read-link {
    color: var(--casys-warm-accent);
  }

  /* View all link */
  html[data-theme="dark"] #blog .view-all-link {
    color: var(--casys-warm-accent);
    border-color: rgba(255, 184, 111, 0.2);
  }

  html[data-theme="dark"] #blog .view-all-link:hover {
    border-color: var(--casys-warm-accent);
    background: rgba(255, 184, 111, 0.1);
  }

  /* No posts */
  html[data-theme="dark"] #blog .no-posts {
    color: var(--casys-warm-text-muted);
  }
</style>
