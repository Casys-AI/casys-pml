---
/**
 * UseCasesPreview — Compact use cases section for the homepage
 *
 * Shows the 3 case studies with thumbnail diagrams to drive clicks
 * to the full case study pages. Replaces the Blog section on the homepage.
 */
import { useTranslations } from '../../i18n';
import { useCases } from '../../content/use-cases';

const locale = (Astro as any).currentLocale ?? 'en';
const t = useTranslations(locale).useCases;
const localePath = locale === 'en' ? '' : `/${locale}`;
---

<section id="use-cases-preview">
  <div class="container">
    <!-- Header -->
    <div class="section-header">
      <h2>{t.heroTitle}</h2>
      <p class="section-subtitle">{t.heroSubtitle}</p>
    </div>

    <!-- Cards Grid -->
    <div class="uc-grid">
      {useCases.map((uc) => (
        <a href={`${localePath}/use-cases/${uc.id}`} class="uc-card">
          {(uc.diagram || uc.visual) && (
            <div class="card-thumb">
              <img
                src={uc.visual || `/diagrams/${uc.diagram}.svg`}
                alt={uc.title[locale] || uc.title.en}
                loading="lazy"
                class="thumb-img"
              />
            </div>
          )}
          <div class="card-inner">
            <span class="case-tag">
              <span class="material-symbols-rounded tag-icon">{uc.icon}</span>
              {uc.tag}
            </span>
            <h3>{uc.title[locale] || uc.title.en}</h3>
            <p class="card-excerpt">
              {(uc.punchline[locale] || uc.punchline.en)}
            </p>
            <span class="read-link">
              {locale === 'fr' ? 'Lire le cas' : locale === 'zh' ? '阅读案例' : locale === 'zh-TW' ? '閱讀案例' : 'Read case study'}
              <span aria-hidden="true">&rarr;</span>
            </span>
          </div>
        </a>
      ))}
    </div>

    <!-- View all CTA -->
    <div class="view-all-wrapper">
      <a href={`${localePath}/use-cases`} class="view-all-link">
        {locale === 'fr' ? 'Tous les cas' : locale === 'zh' ? '所有案例' : locale === 'zh-TW' ? '所有案例' : 'All case studies'}
        <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </div>
</section>

<style>
  section {
    padding: 56px 0;
    background: var(--md-sys-color-surface-container-lowest);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .section-header {
    text-align: left;
    margin-bottom: 48px;
    max-width: 600px;
  }

  h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 2.5rem;
    font-weight: 600;
    font-optical-sizing: auto;
    color: var(--md-sys-color-on-surface);
    margin: 0 0 12px;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
    line-height: 1.6;
  }

  /* Grid */
  .uc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 48px;
  }

  /* Card */
  .uc-card {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    border-radius: 16px;
    border: 1px solid var(--md-sys-color-outline-variant);
    background: var(--md-sys-color-surface-container-lowest);
    overflow: hidden;
    transition:
      border-color 200ms ease-out,
      box-shadow 200ms ease-out,
      transform 300ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .uc-card:hover {
    border-color: var(--md-sys-color-primary);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    transform: translateY(-3px);
  }

  .uc-card:focus-visible {
    outline: 3px solid var(--md-sys-color-primary);
    outline-offset: 4px;
  }

  /* Thumbnail */
  .card-thumb {
    width: 100%;
    height: 220px;
    overflow: hidden;
    background: #0a0908;
    border-bottom: 1px solid var(--md-sys-color-outline-variant);
  }

  .thumb-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 12px 16px;
    transition: transform 500ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .uc-card:hover .thumb-img {
    transform: scale(1.04);
  }

  /* Card content */
  .card-inner {
    padding: 24px 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }

  .case-tag {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--md-sys-color-primary);
    background: var(--md-sys-color-primary-container);
    padding: 4px 10px;
    border-radius: 5px;
    align-self: flex-start;
  }

  .tag-icon {
    font-size: 13px;
  }

  h3 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--md-sys-color-on-surface);
    margin: 0;
    letter-spacing: -0.01em;
    line-height: 1.35;
  }

  .card-excerpt {
    font-size: 0.875rem;
    color: var(--md-sys-color-on-surface-variant);
    line-height: 1.6;
    margin: 0;
    font-style: italic;
  }

  .read-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--md-sys-color-primary);
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .uc-card:hover .read-link {
    text-decoration: underline;
  }

  /* View all CTA */
  .view-all-wrapper {
    text-align: center;
  }

  .view-all-link {
    font-size: 1rem;
    font-weight: 600;
    color: var(--md-sys-color-primary);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 12px 24px;
    border: 1px solid var(--md-sys-color-outline-variant);
    border-radius: 8px;
    transition: background 200ms ease-out, border-color 200ms ease-out;
  }

  .view-all-link:hover {
    border-color: var(--md-sys-color-primary);
    background: var(--md-sys-color-surface-container-high);
  }

  /* ---- RESPONSIVE ---- */
  @media (max-width: 1024px) {
    .uc-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .uc-card:nth-child(3) {
      display: none;
    }
  }

  @media (max-width: 768px) {
    section {
      padding: 32px 0;
    }

    h2 {
      font-size: 2rem;
    }

    .uc-grid {
      grid-template-columns: 1fr;
      gap: 20px;
      margin-bottom: 32px;
    }

    .uc-card:nth-child(3) {
      display: flex;
    }

    .card-thumb {
      height: 180px;
    }

    .card-inner {
      padding: 20px 24px;
      gap: 10px;
    }

    .view-all-link {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<style is:global>
  /* ---- DARK MODE ---- */
  html[data-theme="dark"] #use-cases-preview {
    background: #0f0e0c;
  }

  html[data-theme="dark"] #use-cases-preview h2 {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #use-cases-preview .section-subtitle {
    color: var(--casys-warm-text-secondary);
  }

  html[data-theme="dark"] #use-cases-preview .uc-card {
    background: var(--casys-warm-surface);
    border-color: rgba(255, 184, 111, 0.1);
  }

  html[data-theme="dark"] #use-cases-preview .uc-card:hover {
    border-color: var(--casys-warm-border-accent-hover);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
  }

  html[data-theme="dark"] #use-cases-preview .card-thumb {
    background: #08080a;
    border-bottom-color: rgba(255, 184, 111, 0.08);
  }

  html[data-theme="dark"] #use-cases-preview .case-tag {
    color: var(--casys-warm-accent);
    background: rgba(255, 184, 111, 0.15);
  }

  html[data-theme="dark"] #use-cases-preview h3 {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #use-cases-preview .card-excerpt {
    color: var(--casys-warm-text-secondary);
  }

  html[data-theme="dark"] #use-cases-preview .read-link {
    color: var(--casys-warm-accent);
  }

  html[data-theme="dark"] #use-cases-preview .view-all-link {
    color: var(--casys-warm-accent);
    border-color: rgba(255, 184, 111, 0.2);
  }

  html[data-theme="dark"] #use-cases-preview .view-all-link:hover {
    border-color: var(--casys-warm-accent);
    background: rgba(255, 184, 111, 0.1);
  }
</style>
