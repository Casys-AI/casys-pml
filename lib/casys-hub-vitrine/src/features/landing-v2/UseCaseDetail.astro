<style is:global>
  /* Dark mode link colors for use case narrative text.
     Must be is:global because set:html content has no Astro scope attributes,
     so scoped selectors never match. */
  html[data-theme="dark"] #use-case-detail .narrative-text a,
  html[data-theme="dark"] #use-case-detail .narrative-text a:link,
  html[data-theme="dark"] #use-case-detail .narrative-text a:visited {
    color: #FFB86F !important;
    text-decoration: underline;
    text-decoration-color: rgba(255, 184, 111, 0.3);
    text-underline-offset: 3px;
  }

  html[data-theme="dark"] #use-case-detail .narrative-text a:hover {
    color: #FFB86F !important;
    text-decoration-color: #FFB86F;
  }

  /* Light mode links too — consistent accent color */
  #use-case-detail .narrative-text a,
  #use-case-detail .narrative-text a:link,
  #use-case-detail .narrative-text a:visited {
    color: var(--md-sys-color-primary);
    text-decoration: underline;
    text-decoration-color: rgba(0, 0, 0, 0.15);
    text-underline-offset: 3px;
  }

  #use-case-detail .narrative-text a:hover {
    text-decoration-color: var(--md-sys-color-primary);
  }
</style>

<script>
  const section = document.getElementById('use-case-detail');
  const bar = section?.querySelector('.reading-progress') as HTMLElement | null;

  if (section && bar) {
    const update = () => {
      const rect = section.getBoundingClientRect();
      const total = section.scrollHeight - window.innerHeight;
      const scrolled = -rect.top;
      const pct = Math.min(100, Math.max(0, (scrolled / total) * 100));
      bar.style.width = `${pct}%`;
    };

    window.addEventListener('scroll', update, { passive: true });
    update();
  }
</script>
