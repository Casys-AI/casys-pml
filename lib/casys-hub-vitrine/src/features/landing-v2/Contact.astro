---
import { useTranslations } from '../../i18n';
const locale = (Astro as any).currentLocale ?? 'en';
const t = useTranslations(locale).contact;
---

<section id="contact">
  <div class="container">
    <div class="section-header">
      <h2>{t.title}</h2>
      <p class="section-subtitle">{t.subtitle}</p>
    </div>

    <form
      id="contact-form"
      class="contact-form"
      action="https://formspree.io/f/movnynen"
      method="POST"
    >
      <div class="form-grid">
        <div class="form-group">
          <label for="contact-name" class="label">
            <span class="material-symbols-rounded">person</span>
            {t.namePlaceholder}
          </label>
          <input
            id="contact-name"
            type="text"
            name="name"
            placeholder={t.namePlaceholder}
            class="input"
            required
          />
        </div>

        <div class="form-group">
          <label for="contact-email" class="label">
            <span class="material-symbols-rounded">email</span>
            {t.emailPlaceholder}
          </label>
          <input
            id="contact-email"
            type="email"
            name="email"
            placeholder={t.emailPlaceholder}
            class="input"
            required
          />
        </div>
      </div>

      <!-- Hidden subject field with default value -->
      <input
        type="hidden"
        name="_subject"
        value={t.hiddenSubject}
      />

      <div class="form-group">
        <label for="contact-message" class="label">
          <span class="material-symbols-rounded">chat</span>
          {t.messagePlaceholder}
        </label>
        <textarea
          id="contact-message"
          name="message"
          placeholder={t.messagePlaceholder}
          class="textarea"
          rows="6"
          required
        ></textarea>
      </div>

      <button type="submit" class="submit-btn">
        <span class="btn-text">{t.submitButton}</span>
        <span class="btn-loading">{t.sending}</span>
        <span class="material-symbols-rounded">send</span>
      </button>

      <p id="contact-feedback" class="feedback" role="status"></p>
    </form>
  </div>
</section>

<style>
  /* ========================================
     CONTACT - Editorial/Refined Aesthetic
     Font: Fraunces for headlines
     Palette: Warm orange for dark mode
     ======================================== */

  section {
    padding: 56px 0;
    background: var(--md-sys-color-surface);
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Left-aligned header - editorial style */
  .section-header {
    text-align: left;
    margin-bottom: 48px;
    max-width: 600px;
  }

  h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 2.5rem;
    font-weight: 600;
    font-optical-sizing: auto;
    color: var(--md-sys-color-on-surface);
    margin: 0 0 12px;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
    line-height: 1.6;
  }

  /* Form */
  .contact-form {
    background: var(--md-sys-color-surface-container-lowest);
    border: 1px solid var(--md-sys-color-outline-variant);
    border-radius: 16px;
    padding: 40px;
  }

  @media (max-width: 640px) {
    .contact-form {
      padding: 24px;
    }
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 24px;
  }

  @media (max-width: 640px) {
    .form-grid {
      grid-template-columns: 1fr;
    }
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--md-sys-color-on-surface);
  }

  .label .material-symbols-rounded {
    font-size: 18px;
    color: var(--md-sys-color-primary);
  }

  /* Input Styles */
  .input,
  .textarea {
    width: 100%;
    padding: 14px 16px;
    font-size: 1rem;
    font-family: inherit;
    color: var(--md-sys-color-on-surface);
    background: var(--md-sys-color-surface-container-high);
    border: 1px solid var(--md-sys-color-outline-variant);
    border-radius: 12px;
    outline: none;
    transition: border-color 200ms ease-out, box-shadow 200ms ease-out;
  }

  .input:focus,
  .textarea:focus {
    border-color: var(--md-sys-color-primary);
    box-shadow: 0 0 0 3px rgba(255, 153, 0, 0.1);
  }

  .input::placeholder,
  .textarea::placeholder {
    color: var(--md-sys-color-on-surface-variant);
    opacity: 0.6;
  }

  .textarea {
    resize: vertical;
    min-height: 140px;
  }

  /* Submit Button */
  .submit-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 16px 32px;
    margin-top: 24px;
    font-size: 1rem;
    font-weight: 600;
    color: var(--md-sys-color-on-primary);
    background: var(--md-sys-color-primary);
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: background 200ms ease-out;
  }

  .submit-btn:hover:not(:disabled) {
    background: var(--md-sys-color-primary-container);
    color: var(--md-sys-color-on-primary-container);
  }

  .submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .btn-loading {
    display: none;
  }

  .submit-btn.loading .btn-text {
    display: none;
  }

  .submit-btn.loading .btn-loading {
    display: inline;
  }

  .submit-btn .material-symbols-rounded {
    font-size: 20px;
  }

  /* Feedback Message */
  .feedback {
    margin-top: 16px;
    padding: 12px 16px;
    font-size: 0.95rem;
    text-align: center;
    border-radius: 8px;
    opacity: 0;
    transition: opacity 200ms ease-out;
  }

  .feedback.visible {
    opacity: 1;
  }

  .feedback.success {
    color: var(--md-sys-color-on-tertiary-container);
    background: var(--md-sys-color-tertiary-container);
  }

  .feedback.error {
    color: var(--md-sys-color-on-error-container);
    background: var(--md-sys-color-error-container);
  }

  /* Mobile Responsiveness */
  @media (max-width: 768px) {
    section {
      padding: 32px 0;
    }

    h2 {
      font-size: 2rem;
    }
  }
</style>

<style is:global>
  /* ========================================
     CONTACT - DARK MODE
     Warm orange palette (#FFB86F, #D4A574)
     ======================================== */

  html[data-theme="dark"] #contact {
    background: var(--casys-warm-background);
  }

  html[data-theme="dark"] #contact h2 {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #contact .section-subtitle {
    color: var(--casys-warm-text-secondary);
  }

  /* Form */
  html[data-theme="dark"] #contact .contact-form {
    background: var(--casys-warm-surface);
    border-color: rgba(255, 184, 111, 0.1);
  }

  html[data-theme="dark"] #contact .label {
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #contact .label .material-symbols-rounded {
    color: var(--casys-warm-accent);
  }

  /* Inputs */
  html[data-theme="dark"] #contact .input,
  html[data-theme="dark"] #contact .textarea {
    background: rgba(255, 184, 111, 0.05);
    border-color: rgba(255, 184, 111, 0.15);
    color: var(--casys-warm-text-primary);
  }

  html[data-theme="dark"] #contact .input:focus,
  html[data-theme="dark"] #contact .textarea:focus {
    border-color: var(--casys-warm-accent);
    box-shadow: 0 0 0 3px rgba(255, 184, 111, 0.1);
  }

  html[data-theme="dark"] #contact .input::placeholder,
  html[data-theme="dark"] #contact .textarea::placeholder {
    color: var(--casys-warm-text-secondary);
  }

  /* Submit Button */
  html[data-theme="dark"] #contact .submit-btn {
    background: var(--casys-warm-accent);
    color: var(--casys-warm-surface);
  }

  html[data-theme="dark"] #contact .submit-btn:hover:not(:disabled) {
    background: var(--casys-warm-accent-hover);
  }

  /* Feedback */
  html[data-theme="dark"] #contact .feedback.success {
    background: rgba(255, 184, 111, 0.15);
    color: var(--casys-warm-text-primary);
    border: 1px solid rgba(255, 184, 111, 0.2);
  }

  html[data-theme="dark"] #contact .feedback.error {
    background: rgba(255, 100, 100, 0.15);
    color: #ffcccc;
    border: 1px solid rgba(255, 100, 100, 0.2);
  }
</style>

<script>
  const contactForm = document.getElementById('contact-form') as HTMLFormElement | null;
  const contactFeedback = document.getElementById('contact-feedback') as HTMLParagraphElement | null;

  contactForm?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!contactForm || !contactFeedback) return;

    const formData = new FormData(contactForm);
    const name = formData.get('name') as string;
    const email = formData.get('email') as string;
    const message = formData.get('message') as string;
    const subject = formData.get('_subject') as string;

    // Validation
    if (!name || !email || !message) return;

    const submitBtn = contactForm.querySelector('.submit-btn') as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.classList.add('loading');

    contactFeedback.classList.remove('visible', 'success', 'error');
    const lang = document.documentElement.lang;

    try {
      const response = await fetch('https://formspree.io/f/movnynen', {
        method: 'POST',
        body: JSON.stringify({ name, email, message, _subject: subject }),
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        }
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.error || 'Submission failed');
      }

      // Success
      contactFeedback.textContent = lang === 'fr'
        ? 'Message envoyé ! Nous vous répondrons rapidement.'
        : lang === 'zh'
        ? '消息已发送！我们会尽快回复。'
        : 'Message sent! We\'ll reply soon.';
      contactFeedback.classList.add('visible', 'success');

      // Reset form
      contactForm.reset();

      // Hide success message after 5 seconds
      setTimeout(() => {
        contactFeedback.classList.remove('visible');
      }, 5000);

    } catch (error) {
      // Error
      contactFeedback.textContent = lang === 'fr'
        ? 'Erreur lors de l\'envoi. Veuillez réessayer.'
        : lang === 'zh'
        ? '发送失败，请重试。'
        : 'Error sending message. Please try again.';
      contactFeedback.classList.add('visible', 'error');

      setTimeout(() => {
        contactFeedback.classList.remove('visible');
      }, 5000);
    } finally {
      submitBtn.disabled = false;
      submitBtn.classList.remove('loading');
    }
  });
</script>
