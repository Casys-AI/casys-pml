---
import SubsiteHeader from '../../components/SubsiteHeader.astro';
import { useTranslations } from '../../i18n';

const locale = (Astro as any).currentLocale ?? 'en';
const t = useTranslations(locale).mcpServerHeader;
---

<SubsiteHeader
  logo={{ prefix: '@casys/', name: 'mcp-server', version: 'v0.7' }}
  navLinks={[
    { href: '#features', label: t.features },
    { href: '#quickstart', label: t.quickstart },
    { href: '#pipeline', label: t.pipeline },
    { href: '#install', label: t.install },
    { href: '/docs/getting-started/introduction/', label: t.docs, icon: 'description' },
  ]}
  githubUrl="https://github.com/Casys-AI/casys-pml/tree/main/lib/server"
  jsrUrl="https://jsr.io/@casys/mcp-server"
  consultingLabel={t.workWithUs}
  heroAnchor="#mcp-hero"
/>
