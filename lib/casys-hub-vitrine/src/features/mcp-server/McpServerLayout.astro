---
import SubsiteLayout from '../../components/SubsiteLayout.astro';
import McpServerHeader from './McpServerHeader.astro';

export interface Props {
  title: string;
}

const { title } = Astro.props;
const locale = (Astro as any).currentLocale ?? 'en';

const metaDescriptions: Record<string, string> = {
  fr: 'Framework MCP production-grade avec middleware composable, auth OAuth2, double transport. Le Hono pour MCP.',
  zh: '生产级 MCP 服务器框架，具有可组合中间件、OAuth2 认证、双传输。MCP 的 Hono。',
  en: 'Production-grade MCP server framework with composable middleware, OAuth2 auth, dual transport. The Hono for MCP.',
};
const metaDescription = metaDescriptions[locale] ?? metaDescriptions.en;
---

<SubsiteLayout title={title} metaDescription={metaDescription} jsonLd={{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "@casys/mcp-server",
  "description": metaDescription,
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Cross-platform",
  "url": "https://mcp-server.casys.ai",
  "softwareVersion": "0.8.0",
  "author": { "@type": "Organization", "name": "Casys AI", "url": "https://casys.ai" },
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "license": "https://opensource.org/licenses/MIT",
  "programmingLanguage": "TypeScript",
  "runtimePlatform": ["Deno", "Node.js"],
  "codeRepository": "https://github.com/Casys-AI/mcp-server",
  "downloadUrl": "https://jsr.io/@casys/mcp-server"
}}>
  <McpServerHeader slot="header" />
  <slot />
</SubsiteLayout>
