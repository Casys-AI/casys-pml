---
const locale = (Astro as any).currentLocale ?? 'en';

const translations = {
  en: {
    tagline: 'The MCP Standard Toolbox',
    heroTitle1: '508 Tools.',
    heroTitle2: 'One Import.',
    heroSubtitle: 'Database, git, docker, crypto, text, network, AI agents \u2014 every utility you\'d write yourself, already tested and typed.',
    statTools: 'Tools',
    statCategories: 'Categories',
    statRelease: 'Latest',
    ctaPrimary: 'Browse Catalog',
    ctaSecondary1: 'Quick Start',
    ctaSecondary2: 'View on JSR',
  },
  fr: {
    tagline: 'La Boite a Outils MCP',
    heroTitle1: '508 Outils.',
    heroTitle2: 'Un Seul Import.',
    heroSubtitle: 'Base de donnees, git, docker, crypto, texte, reseau, agents IA \u2014 chaque utilitaire que vous ecririez, deja teste et type.',
    statTools: 'Outils',
    statCategories: 'Categories',
    statRelease: 'Derniere',
    ctaPrimary: 'Parcourir le Catalogue',
    ctaSecondary1: 'Demarrage Rapide',
    ctaSecondary2: 'Voir sur JSR',
  },
  zh: {
    tagline: 'MCP 标准工具箱',
    heroTitle1: '508 个工具。',
    heroTitle2: '一次导入。',
    heroSubtitle: '数据库、Git、Docker、加密、文本、网络、AI 代理\u2014\u2014你自己会写的每个工具，已测试且类型化。',
    statTools: '工具',
    statCategories: '分类',
    statRelease: '最新',
    ctaPrimary: '浏览目录',
    ctaSecondary1: '快速开始',
    ctaSecondary2: '在 JSR 上查看',
  },
} as const;
const t = translations[locale as keyof typeof translations] ?? translations.en;

const terminalLines = `<code class="terminal-line"><span class="t-prompt">$</span> deno run -A server.ts</code>
<code class="terminal-line t-dim" style="margin-top:4px">  @casys/mcp-std v0.4.0</code>
<code class="terminal-line t-dim">&nbsp;</code>
<code class="terminal-line t-check"><span class="t-ok">✓</span> <span class="t-key">Transport</span>   STDIO + Streamable HTTP</code>
<code class="terminal-line t-check"><span class="t-ok">✓</span> <span class="t-key">Tools</span>       508 registered</code>
<code class="terminal-line t-check"><span class="t-ok">✓</span> <span class="t-key">Categories</span>  git, docker, database, crypto...</code>
<code class="terminal-line t-check"><span class="t-ok">✓</span> <span class="t-key">Schema</span>      JSON Schema validated</code>
<code class="terminal-line t-check"><span class="t-ok">✓</span> <span class="t-key">UI</span>          47 tools with MCP Apps</code>
<code class="terminal-line t-dim">&nbsp;</code>
<code class="terminal-line t-ready"><span class="t-ok">●</span> Ready in <span class="t-accent">12ms</span></code>`;
---

<section id="mcp-std-hero">
  <div class="gradient-orb" aria-hidden="true"></div>
  <div class="container hero-grid">
    <div class="hero-content">
      <span class="hero-tagline">{t.tagline}</span>
      <h1 class="hero-title">
        <span class="title-line">{t.heroTitle1}</span>
        <span class="title-line accent">{t.heroTitle2}</span>
      </h1>
      <p class="hero-subtitle">{t.heroSubtitle}</p>
      <div class="cta-group">
        <a href="/mcp-std/catalog" class="cta-primary">
          <span class="material-symbols-rounded">search</span>
          <span>{t.ctaPrimary}</span>
        </a>
        <a href="#quickstart" class="cta-secondary">
          <span class="material-symbols-rounded">rocket_launch</span>
          <span>{t.ctaSecondary1}</span>
        </a>
        <a href="https://jsr.io/@casys/mcp-std" class="cta-secondary" target="_blank" rel="noopener noreferrer">
          <span>{t.ctaSecondary2}</span>
          <span class="material-symbols-rounded">arrow_outward</span>
        </a>
      </div>
      <div class="stats-row">
        <div class="stat-item">
          <span class="stat-value">508</span>
          <span class="stat-label">{t.statTools}</span>
        </div>
        <div class="stat-item">
          <span class="stat-value">29</span>
          <span class="stat-label">{t.statCategories}</span>
        </div>
        <div class="stat-item">
          <span class="stat-value">v0.4.0</span>
          <span class="stat-label">{t.statRelease}</span>
        </div>
      </div>
    </div>
    <div class="hero-visual" aria-hidden="true">
      <div class="terminal-window">
        <div class="terminal-header">
          <span class="terminal-dot red"></span>
          <span class="terminal-dot yellow"></span>
          <span class="terminal-dot green"></span>
          <span class="terminal-title">mcp-std-server</span>
        </div>
        <div class="terminal-body" set:html={terminalLines} />
      </div>
    </div>
  </div>
</section>

<style>
  #mcp-std-hero {
    position: relative;
    overflow: hidden;
    padding: 56px 0 40px;
  }

  .container { max-width: 1200px; margin: 0 auto; padding: 0 48px; }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding-top: 8px;
  }

  .hero-tagline {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--md-sys-color-primary);
    padding: 5px 12px;
    background: var(--md-sys-color-primary-container);
    border-radius: 100px;
    width: fit-content;
  }

  .hero-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2.25rem, 4.5vw, 3.5rem);
    font-weight: 500;
    font-optical-sizing: auto;
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin: 0;
    color: var(--md-sys-color-on-surface);
  }

  .title-line { display: block; }
  .title-line.accent { font-family: 'Instrument Serif', Georgia, serif; font-style: italic; color: var(--md-sys-color-primary); }

  .hero-subtitle {
    font-size: clamp(1rem, 1.4vw, 1.125rem);
    font-weight: 400;
    line-height: 1.65;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
    max-width: 480px;
  }

  .cta-group { display: flex; flex-wrap: wrap; gap: 12px; }

  .cta-primary {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: var(--md-sys-color-primary);
    color: var(--md-sys-color-on-primary);
    border-radius: 8px;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 200ms ease-out, transform 100ms ease-out;
  }
  .cta-primary:hover { background: var(--md-sys-color-primary-container); color: var(--md-sys-color-on-primary-container); }
  .cta-primary:active { transform: scale(0.98); }
  .cta-primary:focus-visible { outline: 3px solid var(--md-sys-color-primary); outline-offset: 4px; }
  .cta-primary .material-symbols-rounded { font-size: 18px; }

  .cta-secondary {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 12px 20px;
    background: transparent;
    color: var(--md-sys-color-on-surface);
    border-radius: 8px;
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    border: 1px solid var(--md-sys-color-outline-variant);
    transition: background 200ms ease-out, border-color 200ms ease-out;
  }
  .cta-secondary:hover { background: var(--md-sys-color-surface-container); border-color: var(--md-sys-color-primary); }
  .cta-secondary:focus-visible { outline: 3px solid var(--md-sys-color-primary); outline-offset: 4px; }
  .cta-secondary .material-symbols-rounded { font-size: 16px; }

  .stats-row {
    display: flex;
    gap: 28px;
    padding: 14px 0 0;
    border-top: 1px solid var(--md-sys-color-outline-variant);
  }

  .stat-item { display: flex; flex-direction: column; gap: 2px; }

  .stat-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--md-sys-color-primary);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--md-sys-color-on-surface-variant);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* Terminal mockup */
  .hero-visual { display: flex; justify-content: flex-end; }

  .terminal-window {
    width: 100%;
    max-width: 500px;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--md-sys-color-outline-variant);
    background: var(--md-sys-color-surface-container-lowest);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
  }

  .terminal-header {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 10px 14px;
    background: var(--md-sys-color-surface-container-high);
    border-bottom: 1px solid var(--md-sys-color-outline-variant);
  }

  .terminal-dot { width: 9px; height: 9px; border-radius: 50%; }
  .terminal-dot.red { background: #ff5f57; }
  .terminal-dot.yellow { background: #febc2e; }
  .terminal-dot.green { background: #28c840; }

  .terminal-title {
    margin-left: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6875rem;
    color: var(--md-sys-color-on-surface-variant);
    font-weight: 500;
  }

  .terminal-body { padding: 16px 18px; display: flex; flex-direction: column; gap: 2px; }

  .terminal-line {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    line-height: 1.7;
    color: var(--md-sys-color-on-surface);
    display: flex;
    align-items: center;
    gap: 6px;
    white-space: pre;
  }

  /* Terminal text colors are in <style is:global> because set:html content has no Astro scoped hash */

  /* Gradient orb */
  .gradient-orb {
    position: absolute;
    top: 40%;
    left: 65%;
    transform: translate(-50%, -50%);
    width: min(800px, 60vw);
    height: min(600px, 50vh);
    background:
      radial-gradient(circle at 30% 40%, rgba(180, 83, 9, 0.08) 0%, transparent 50%),
      radial-gradient(circle at 70% 60%, rgba(20, 184, 166, 0.05) 0%, transparent 50%);
    filter: blur(80px);
    opacity: 0.6;
    z-index: 0;
    pointer-events: none;
  }

  @media (max-width: 1024px) {
    .container { padding: 0 32px; }
    .hero-grid { grid-template-columns: 1fr; gap: 32px; }
    .hero-content { align-items: center; text-align: center; padding-top: 0; }
    .hero-subtitle { max-width: 560px; }
    .stats-row { justify-content: center; }
    .cta-group { justify-content: center; }
    .hero-visual { justify-content: center; }
    .terminal-window { max-width: 480px; }
  }

  @media (max-width: 768px) {
    #mcp-std-hero { padding: 48px 0 32px; }
    .container { padding: 0 20px; }
    .hero-grid { gap: 24px; }
    .hero-title { font-size: clamp(1.75rem, 7vw, 2.5rem); }
    .hero-subtitle { font-size: 0.9375rem; }
    .stats-row { gap: 20px; flex-wrap: wrap; }
    .cta-group { flex-direction: column; width: 100%; }
    .cta-primary, .cta-secondary { width: 100%; justify-content: center; }
    .terminal-window { max-width: 100%; }
    .terminal-body { padding: 14px; }
    .terminal-line { font-size: 0.6875rem; }
  }

  @media (max-width: 380px) {
    .container { padding: 0 14px; }
    .hero-title { font-size: 1.5rem; }
    .hero-tagline { font-size: 0.75rem; }
  }
</style>

<style is:global>
  /* Terminal text colors - global because set:html content has no Astro scoped hash */
  #mcp-std-hero .t-prompt { color: var(--md-sys-color-primary); font-weight: 700; }
  #mcp-std-hero .t-dim { color: var(--md-sys-color-on-surface-variant); opacity: 0.6; }
  #mcp-std-hero .t-ok { color: #22c55e; font-weight: 700; }
  #mcp-std-hero .t-key { color: var(--md-sys-color-on-surface); font-weight: 600; }
  #mcp-std-hero .t-check { color: var(--md-sys-color-on-surface-variant); }
  #mcp-std-hero .t-ready { color: var(--md-sys-color-on-surface); font-weight: 600; }
  #mcp-std-hero .t-accent { color: var(--md-sys-color-primary); font-weight: 700; }

  #mcp-std-hero { background: var(--md-sys-color-surface); }
  html[data-theme="dark"] #mcp-std-hero { background: #0a0908; }

  html[data-theme="dark"] #mcp-std-hero .hero-tagline { background: rgba(255, 184, 111, 0.12); color: #FFB86F; }
  html[data-theme="dark"] #mcp-std-hero .hero-title { color: #f5f0ea; }
  html[data-theme="dark"] #mcp-std-hero .title-line.accent { color: #FFB86F; }
  html[data-theme="dark"] #mcp-std-hero .hero-subtitle { color: #d5c3b5; }
  html[data-theme="dark"] #mcp-std-hero .stats-row { border-color: rgba(255, 184, 111, 0.15); }
  html[data-theme="dark"] #mcp-std-hero .stat-value { color: #FFB86F; }
  html[data-theme="dark"] #mcp-std-hero .stat-label { color: #a89a8c; }
  html[data-theme="dark"] #mcp-std-hero .cta-primary { background: #FFB86F; color: #1a1815; }
  html[data-theme="dark"] #mcp-std-hero .cta-primary:hover { background: #D4A574; }
  html[data-theme="dark"] #mcp-std-hero .cta-secondary { color: #f5f0ea; border-color: rgba(255, 184, 111, 0.2); }
  html[data-theme="dark"] #mcp-std-hero .cta-secondary:hover { background: rgba(255, 184, 111, 0.1); border-color: #FFB86F; }

  html[data-theme="dark"] #mcp-std-hero .terminal-window { background: #111110; border-color: rgba(255, 184, 111, 0.1); box-shadow: 0 4px 32px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(255, 184, 111, 0.05); }
  html[data-theme="dark"] #mcp-std-hero .terminal-header { background: #1a1815; border-bottom-color: rgba(255, 184, 111, 0.08); }
  html[data-theme="dark"] #mcp-std-hero .terminal-title { color: #6b6560; }
  html[data-theme="dark"] #mcp-std-hero .terminal-line { color: #d5c3b5; }
  html[data-theme="dark"] #mcp-std-hero .t-prompt { color: #FFB86F; }
  html[data-theme="dark"] #mcp-std-hero .t-dim { color: #6b6560; }
  html[data-theme="dark"] #mcp-std-hero .t-ok { color: #6ee7b7; }
  html[data-theme="dark"] #mcp-std-hero .t-key { color: #f5f0ea; }
  html[data-theme="dark"] #mcp-std-hero .t-check { color: #a89a8c; }
  html[data-theme="dark"] #mcp-std-hero .t-ready { color: #f5f0ea; }
  html[data-theme="dark"] #mcp-std-hero .t-accent { color: #FFB86F; }

  html[data-theme="dark"] #mcp-std-hero .gradient-orb {
    background: radial-gradient(circle at 25% 35%, rgba(255, 184, 111, 0.06) 0%, transparent 50%), radial-gradient(circle at 75% 65%, rgba(212, 165, 116, 0.04) 0%, transparent 50%);
    filter: blur(100px);
    opacity: 0.4;
  }
</style>
