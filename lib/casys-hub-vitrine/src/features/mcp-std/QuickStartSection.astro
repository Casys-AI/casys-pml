---
const locale = (Astro as any).currentLocale ?? 'en';

const translations = {
  en: {
    title: '3 Lines to',
    titleAccent: 'Production',
    subtitle: 'Use it as a standalone MCP server or import individual tools as a library. Your call.',
    tabServer: 'As MCP Server',
    tabLibrary: 'As Library',
    tabCategory: 'By Category',
  },
  fr: {
    title: '3 Lignes vers la',
    titleAccent: 'Prod',
    subtitle: 'Utilisez-le comme serveur MCP autonome ou importez les outils individuellement comme librairie. A vous de choisir.',
    tabServer: 'Serveur MCP',
    tabLibrary: 'Librairie',
    tabCategory: 'Par Catégorie',
  },
  zh: {
    title: '3 行代码到',
    titleAccent: '生产',
    subtitle: '作为独立 MCP 服务器使用，或作为库导入单个工具。由您决定。',
    tabServer: 'MCP 服务器',
    tabLibrary: '库模式',
    tabCategory: '按类别',
  },
} as const;
const t = translations[locale as keyof typeof translations] ?? translations.en;

const codeServer = `<span class="c-keyword">import</span> { serve } <span class="c-keyword">from</span> <span class="c-string">"@casys/mcp-std/server"</span>;

<span class="c-comment">// Start with all 508 tools</span>
<span class="c-keyword">await</span> <span class="c-fn">serve</span>();
<span class="c-comment">// That's it. STDIO + HTTP on :3000</span>`;

const codeLibrary = `<span class="c-keyword">import</span> { getToolByName } <span class="c-keyword">from</span> <span class="c-string">"@casys/mcp-std"</span>;

<span class="c-keyword">const</span> tool = <span class="c-fn">getToolByName</span>(<span class="c-string">"git_status"</span>);
<span class="c-keyword">const</span> result = <span class="c-keyword">await</span> tool.<span class="c-fn">handler</span>({ path: <span class="c-string">"."</span> });
console.<span class="c-fn">log</span>(result);`;

const codeCategory = `<span class="c-keyword">import</span> { getToolsByCategory } <span class="c-keyword">from</span> <span class="c-string">"@casys/mcp-std"</span>;

<span class="c-comment">// Load only what you need — not all 508 tools</span>
<span class="c-keyword">const</span> dbTools = <span class="c-fn">getToolsByCategory</span>(<span class="c-string">"database"</span>);   <span class="c-comment">// 18 tools</span>
<span class="c-keyword">const</span> gitTools = <span class="c-fn">getToolsByCategory</span>(<span class="c-string">"git"</span>);        <span class="c-comment">// 15 tools</span>

<span class="c-comment">// Or filter categories on the MCP server</span>
<span class="c-keyword">import</span> { serve } <span class="c-keyword">from</span> <span class="c-string">"@casys/mcp-std/server"</span>;
<span class="c-keyword">await</span> <span class="c-fn">serve</span>({ categories: [<span class="c-string">"database"</span>, <span class="c-string">"git"</span>, <span class="c-string">"text"</span>] });`;
---

<section id="quickstart">
  <div class="container">
    <div class="section-header">
      <h2>{t.title} <span class="accent-text">{t.titleAccent}</span></h2>
      <p class="section-subtitle">{t.subtitle}</p>
    </div>
    <div class="code-tabs-container">
      <div class="tabs-header" role="tablist" aria-label="Code examples">
        <button class="tab-btn active" role="tab" aria-selected="true" aria-controls="std-tab-panel-server" id="std-tab-server" data-tab="server">
          <span class="material-symbols-rounded">dns</span>
          {t.tabServer}
        </button>
        <button class="tab-btn" role="tab" aria-selected="false" aria-controls="std-tab-panel-library" id="std-tab-library" data-tab="library">
          <span class="material-symbols-rounded">integration_instructions</span>
          {t.tabLibrary}
        </button>
        <button class="tab-btn" role="tab" aria-selected="false" aria-controls="std-tab-panel-category" id="std-tab-category" data-tab="category">
          <span class="material-symbols-rounded">category</span>
          {t.tabCategory}
        </button>
      </div>
      <div class="tabs-content">
        <div class="tab-panel active" role="tabpanel" id="std-tab-panel-server" aria-labelledby="std-tab-server" data-tab="server">
          <div class="code-block-wrapper">
            <pre class="code-block"><code set:html={codeServer} /></pre>
            <button class="copy-btn" aria-label="Copy server code" data-copy={`import { serve } from "@casys/mcp-std/server";\n\n// Start with all 508 tools\nawait serve();\n// That's it. STDIO + HTTP on :3000`}>
              <span class="material-symbols-rounded">content_copy</span>
            </button>
          </div>
        </div>
        <div class="tab-panel" role="tabpanel" id="std-tab-panel-library" aria-labelledby="std-tab-library" data-tab="library" hidden>
          <div class="code-block-wrapper">
            <pre class="code-block"><code set:html={codeLibrary} /></pre>
            <button class="copy-btn" aria-label="Copy library code" data-copy={`import { getToolByName } from "@casys/mcp-std";\n\nconst tool = getToolByName("git_status");\nconst result = await tool.handler({ path: "." });\nconsole.log(result);`}>
              <span class="material-symbols-rounded">content_copy</span>
            </button>
          </div>
        </div>
        <div class="tab-panel" role="tabpanel" id="std-tab-panel-category" aria-labelledby="std-tab-category" data-tab="category" hidden>
          <div class="code-block-wrapper">
            <pre class="code-block"><code set:html={codeCategory} /></pre>
            <button class="copy-btn" aria-label="Copy category code" data-copy={`import { getToolsByCategory } from "@casys/mcp-std";\n\n// Load only what you need — not all 508 tools\nconst dbTools = getToolsByCategory("database");   // 18 tools\nconst gitTools = getToolsByCategory("git");        // 15 tools\n\n// Or filter categories on the MCP server\nimport { serve } from "@casys/mcp-std/server";\nawait serve({ categories: ["database", "git", "text"] });`}>
              <span class="material-symbols-rounded">content_copy</span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #quickstart {
    position: relative;
    padding: 56px 0 64px;
    background: var(--md-sys-color-surface-container-lowest);
    overflow: hidden;
  }

  .container { max-width: 1200px; margin: 0 auto; padding: 0 48px; }
  .section-header { margin-bottom: 32px; max-width: 600px; }
  .section-header h2 { font-family: 'Fraunces', Georgia, serif; font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 600; font-optical-sizing: auto; color: var(--md-sys-color-on-surface); margin: 0 0 12px; letter-spacing: -0.02em; }
  .section-subtitle { font-size: 1.1rem; color: var(--md-sys-color-on-surface-variant); margin: 0; line-height: 1.6; }

  .code-tabs-container { border-radius: 16px; overflow: hidden; border: 1px solid var(--md-sys-color-outline-variant); background: var(--md-sys-color-surface-container-lowest); }

  .tabs-header { display: flex; background: var(--md-sys-color-surface-container-high); border-bottom: 1px solid var(--md-sys-color-outline-variant); overflow-x: auto; -webkit-overflow-scrolling: touch; }

  .tab-btn { display: flex; align-items: center; gap: 8px; padding: 14px 24px; border: none; background: transparent; color: var(--md-sys-color-on-surface-variant); font-family: 'Inter', sans-serif; font-size: 0.875rem; font-weight: 500; cursor: pointer; white-space: nowrap; position: relative; transition: color 200ms ease-out, background 200ms ease-out; }
  .tab-btn:hover { color: var(--md-sys-color-on-surface); background: var(--md-sys-color-surface-container); }
  .tab-btn:focus-visible { outline: 3px solid var(--md-sys-color-primary); outline-offset: -3px; }
  .tab-btn .material-symbols-rounded { font-size: 18px; }
  .tab-btn.active { color: var(--md-sys-color-primary); font-weight: 600; }
  .tab-btn.active::after { content: ''; position: absolute; bottom: 0; left: 16px; right: 16px; height: 2px; background: var(--md-sys-color-primary); border-radius: 1px 1px 0 0; }

  .tabs-content { padding: 0; }
  .tab-panel { display: none; padding: 0; }
  .tab-panel.active { display: block; }

  .code-block-wrapper { position: relative; }

  .code-block { margin: 0; padding: 24px 28px; font-family: 'JetBrains Mono', monospace; font-size: 0.8125rem; line-height: 1.75; overflow-x: auto; -webkit-overflow-scrolling: touch; color: var(--md-sys-color-on-surface); }
  .code-block code { display: block; white-space: pre; }

  .copy-btn { position: absolute; top: 12px; right: 12px; display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; border: none; background: var(--md-sys-color-surface-container-high); border-radius: 6px; cursor: pointer; color: var(--md-sys-color-on-surface-variant); transition: background 150ms ease-out, color 150ms ease-out; opacity: 0; }
  .code-block-wrapper:hover .copy-btn { opacity: 1; }
  .copy-btn:hover { background: var(--md-sys-color-surface-container); color: var(--md-sys-color-primary); }
  .copy-btn:focus-visible { outline: 3px solid var(--md-sys-color-primary); outline-offset: 2px; opacity: 1; }
  .copy-btn .material-symbols-rounded { font-size: 18px; }

  @media (max-width: 1024px) { .container { padding: 0 32px; } }
  @media (max-width: 768px) {
    #quickstart { padding: 60px 0; }
    .container { padding: 0 20px; }
    .tabs-header { gap: 0; }
    .tab-btn { padding: 12px 16px; font-size: 0.8125rem; }
    .tab-btn .material-symbols-rounded { display: none; }
    .code-block { padding: 16px; font-size: 0.6875rem; line-height: 1.7; }
    .copy-btn { opacity: 1; }
  }
  @media (max-width: 380px) { .container { padding: 0 14px; } }
</style>

<style is:global>
  /* Syntax highlighting - global because set:html content has no Astro scoped hash */
  #quickstart .c-keyword { color: #92400e; font-weight: 600; }
  #quickstart .c-string { color: #047857; }
  #quickstart .c-type { color: #1d4ed8; }
  #quickstart .c-fn { color: #b45309; }
  #quickstart .c-num { color: #dc2626; }
  #quickstart .c-comment { color: #9ca3af; font-style: italic; }

  html[data-theme="dark"] #quickstart { background: #0a0908; }
  html[data-theme="dark"] #quickstart .section-header h2 { color: #f5f0ea; }
  html[data-theme="dark"] #quickstart .section-subtitle { color: #d5c3b5; }
  html[data-theme="dark"] #quickstart .code-tabs-container { background: #111110; border-color: rgba(255, 184, 111, 0.1); }
  html[data-theme="dark"] #quickstart .tabs-header { background: #1a1815; border-bottom-color: rgba(255, 184, 111, 0.08); }
  html[data-theme="dark"] #quickstart .tab-btn { color: #a89a8c; }
  html[data-theme="dark"] #quickstart .tab-btn:hover { color: #f5f0ea; background: rgba(255, 255, 255, 0.03); }
  html[data-theme="dark"] #quickstart .tab-btn.active { color: #FFB86F; }
  html[data-theme="dark"] #quickstart .tab-btn.active::after { background: #FFB86F; }
  html[data-theme="dark"] #quickstart .code-block { color: #f5f0ea; }
  html[data-theme="dark"] #quickstart .copy-btn { background: rgba(255, 184, 111, 0.08); color: #a89a8c; }
  html[data-theme="dark"] #quickstart .copy-btn:hover { background: rgba(255, 184, 111, 0.15); color: #FFB86F; }

  /* Dark mode syntax */
  html[data-theme="dark"] #quickstart .c-keyword { color: #c4b5fd; }
  html[data-theme="dark"] #quickstart .c-string { color: #6ee7b7; }
  html[data-theme="dark"] #quickstart .c-type { color: #93c5fd; }
  html[data-theme="dark"] #quickstart .c-fn { color: #FFB86F; }
  html[data-theme="dark"] #quickstart .c-num { color: #fca5a5; }
  html[data-theme="dark"] #quickstart .c-comment { color: #6b7280; font-style: italic; }
</style>

<script is:inline>
  // Code tabs switching (scoped to #quickstart to avoid collision with mcp-server tabs)
  (function() {
    var section = document.getElementById('quickstart');
    if (!section) return;
    var tabBtns = section.querySelectorAll('.tab-btn');
    var tabPanels = section.querySelectorAll('.tab-panel');

    tabBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var target = btn.dataset.tab;
        if (!target) return;
        tabBtns.forEach(function(b) { b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); });
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');
        tabPanels.forEach(function(panel) {
          if (panel.dataset.tab === target) { panel.classList.add('active'); panel.removeAttribute('hidden'); }
          else { panel.classList.remove('active'); panel.setAttribute('hidden', ''); }
        });
      });

      btn.addEventListener('keydown', function(e) {
        var tabs = Array.from(tabBtns);
        var idx = tabs.indexOf(btn);
        var nextIdx = idx;
        if (e.key === 'ArrowRight') nextIdx = (idx + 1) % tabs.length;
        else if (e.key === 'ArrowLeft') nextIdx = (idx - 1 + tabs.length) % tabs.length;
        else if (e.key === 'Home') nextIdx = 0;
        else if (e.key === 'End') nextIdx = tabs.length - 1;
        else return;
        e.preventDefault();
        tabs[nextIdx].focus();
        tabs[nextIdx].click();
      });
    });

    // Copy to clipboard (scoped)
    section.querySelectorAll('.copy-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var text = btn.dataset.copy;
        if (!text) return;
        navigator.clipboard.writeText(text).then(function() {
          var icon = btn.querySelector('.material-symbols-rounded');
          if (icon) {
            var original = icon.textContent;
            icon.textContent = 'check';
            btn.style.color = '#6ee7b7';
            setTimeout(function() { icon.textContent = original; btn.style.color = ''; }, 2000);
          }
        }).catch(function() {});
      });
    });
  })();
</script>
