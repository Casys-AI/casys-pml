---
const locale = (Astro as any).currentLocale ?? 'en';
const translations: Record<string, Record<string, string>> = {
  en: {
    categories: 'Categories',
    catalog: 'Catalog',
    quickstart: 'Quick Start',
    install: 'Install',
    viewJSR: 'JSR',
    github: 'GitHub',
  },
  fr: {
    categories: 'Categories',
    catalog: 'Catalogue',
    quickstart: 'Demarrage',
    install: 'Installer',
    viewJSR: 'JSR',
    github: 'GitHub',
  },
  zh: {
    categories: '分类',
    catalog: '目录',
    quickstart: '快速开始',
    install: '安装',
    viewJSR: 'JSR',
    github: 'GitHub',
  },
};
const t = translations[locale] ?? translations.en;
---

<header class="mcp-header">
  <div class="mcp-header-container">
    <a href="#mcp-hero" class="mcp-logo">
      <span class="mcp-logo-pkg">@casys/</span><span class="mcp-logo-name">mcp-std</span>
      <span class="mcp-logo-version">v0.4.0</span>
    </a>

    <nav class="mcp-nav-desktop">
      <div class="mcp-nav-links">
        <a href="#categories" class="mcp-nav-link">{t.categories}</a>
        <a href="/mcp-std/catalog" class="mcp-nav-link">{t.catalog}</a>
        <a href="#quickstart" class="mcp-nav-link">{t.quickstart}</a>
        <a href="#install" class="mcp-nav-link">{t.install}</a>
      </div>
      <div class="mcp-nav-actions">
        <a href="https://github.com/Casys-AI/casys-pml/tree/main/lib/std" class="mcp-gh-link" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
        </a>
        <a href="https://jsr.io/@casys/mcp-std" class="mcp-jsr-btn" target="_blank" rel="noopener noreferrer">
          <span class="mcp-jsr-text">JSR</span>
          <span class="material-symbols-rounded">arrow_outward</span>
        </a>
      </div>
    </nav>

    <button id="mcp-mobile-menu-btn" class="mcp-menu-btn" aria-label="Toggle menu" aria-expanded="false">
      <span class="mcp-menu-bar"></span>
      <span class="mcp-menu-bar"></span>
    </button>
  </div>
</header>

<div id="mcp-mobile-menu" class="mcp-mobile-menu">
  <nav class="mcp-mobile-nav">
    <a href="#categories" class="mcp-nav-link">{t.categories}</a>
    <a href="/mcp-std/catalog" class="mcp-nav-link">{t.catalog}</a>
    <a href="#quickstart" class="mcp-nav-link">{t.quickstart}</a>
    <a href="#install" class="mcp-nav-link">{t.install}</a>
    <div class="mcp-mobile-cta">
      <a href="https://github.com/Casys-AI/casys-pml/tree/main/lib/std" class="mcp-mobile-gh" target="_blank" rel="noopener noreferrer">
        GitHub
        <span class="material-symbols-rounded">arrow_outward</span>
      </a>
      <a href="https://jsr.io/@casys/mcp-std" class="mcp-jsr-btn" target="_blank" rel="noopener noreferrer">
        <span class="mcp-jsr-text">JSR</span>
        <span class="material-symbols-rounded">arrow_outward</span>
      </a>
    </div>
  </nav>
</div>

<style>
  .mcp-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    transition: transform 250ms ease-out;
  }

  .mcp-header.header-hidden {
    transform: translateY(-100%);
  }

  .mcp-header-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* Logo */
  .mcp-logo {
    display: flex;
    align-items: baseline;
    gap: 0;
    text-decoration: none;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .mcp-logo-pkg {
    color: var(--md-sys-color-on-surface-variant);
  }

  .mcp-logo-name {
    color: var(--md-sys-color-on-surface);
    font-weight: 700;
  }

  .mcp-logo-version {
    margin-left: 8px;
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--md-sys-color-primary);
    background: var(--md-sys-color-primary-container);
    padding: 2px 7px;
    border-radius: 100px;
  }

  /* Desktop Nav */
  .mcp-nav-desktop {
    display: none;
    align-items: center;
    gap: 24px;
  }

  @media (min-width: 768px) {
    .mcp-nav-desktop { display: flex; }
  }

  .mcp-nav-links {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .mcp-nav-link {
    position: relative;
    padding: 6px 12px;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--md-sys-color-on-surface-variant);
    text-decoration: none;
    border-radius: 6px;
    transition: color 150ms ease-out;
  }

  .mcp-nav-link::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 12px;
    right: 12px;
    height: 2px;
    background: var(--md-sys-color-primary);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 200ms ease-out;
  }

  .mcp-nav-link:hover { color: var(--md-sys-color-on-surface); }
  .mcp-nav-link:hover::after,
  .mcp-nav-link.active::after { transform: scaleX(1); transform-origin: left; }
  .mcp-nav-link.active { color: var(--md-sys-color-primary); font-weight: 600; }

  .mcp-nav-actions {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-left: 8px;
    padding-left: 16px;
    border-left: 1px solid var(--md-sys-color-outline-variant);
  }

  .mcp-gh-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    color: var(--md-sys-color-on-surface-variant);
    border-radius: 8px;
    transition: background 150ms ease-out, color 150ms ease-out;
  }

  .mcp-gh-link:hover {
    background: var(--md-sys-color-surface-container);
    color: var(--md-sys-color-on-surface);
  }

  .mcp-jsr-btn {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 6px 14px;
    background: var(--md-sys-color-primary);
    color: var(--md-sys-color-on-primary);
    font-size: 0.8125rem;
    font-weight: 700;
    text-decoration: none;
    border-radius: 8px;
    transition: background 150ms ease-out;
  }

  .mcp-jsr-btn:hover { background: var(--md-sys-color-primary-container); color: var(--md-sys-color-on-primary-container); }
  .mcp-jsr-btn .material-symbols-rounded { font-size: 16px; }

  .mcp-jsr-text {
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.04em;
  }

  /* Mobile button */
  .mcp-menu-btn {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 10px;
    border: 1px solid rgba(0, 0, 0, 0.1);
    background: transparent;
    cursor: pointer;
    border-radius: 8px;
  }

  .mcp-menu-bar {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--md-sys-color-on-surface);
    border-radius: 1px;
    transition: transform 200ms ease-out;
  }

  .mcp-menu-btn[aria-expanded="true"] .mcp-menu-bar:first-child { transform: rotate(45deg) translateY(5px); }
  .mcp-menu-btn[aria-expanded="true"] .mcp-menu-bar:last-child { transform: rotate(-45deg) translateY(-5px); }

  @media (min-width: 768px) {
    .mcp-menu-btn { display: none; }
  }

  /* Mobile menu */
  .mcp-mobile-menu {
    position: fixed;
    top: 56px;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(20px);
    transform: translateX(100%);
    transition: transform 250ms ease-out;
    z-index: 99;
    overflow-y: auto;
  }

  .mcp-mobile-menu.open { transform: translateX(0); }

  @media (min-width: 768px) {
    .mcp-mobile-menu { display: none; }
  }

  .mcp-mobile-nav {
    display: flex;
    flex-direction: column;
    padding: 24px;
    gap: 4px;
  }

  .mcp-mobile-nav .mcp-nav-link {
    padding: 14px 0;
    font-size: 1.125rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 0;
  }

  .mcp-mobile-nav .mcp-nav-link::after { display: none; }

  .mcp-mobile-cta {
    display: flex;
    gap: 12px;
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .mcp-mobile-gh {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 12px;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--md-sys-color-on-surface);
    border: 1px solid var(--md-sys-color-outline-variant);
    border-radius: 8px;
  }

  .mcp-mobile-gh .material-symbols-rounded { font-size: 16px; }

  .mcp-mobile-cta .mcp-jsr-btn {
    flex: 1;
    justify-content: center;
    padding: 12px;
  }
</style>

<style is:global>
  /* MCP Header - Dark Mode */
  html[data-theme="dark"] .mcp-header {
    background: rgba(0, 0, 0, 0.85) !important;
    border-bottom-color: rgba(255, 184, 111, 0.08);
  }

  html[data-theme="dark"] .mcp-logo-pkg { color: #a89a8c; }
  html[data-theme="dark"] .mcp-logo-name { color: #f5f0ea; }
  html[data-theme="dark"] .mcp-logo-version { background: rgba(255, 184, 111, 0.12); color: #FFB86F; }

  html[data-theme="dark"] .mcp-nav-link { color: #d5c3b5; }
  html[data-theme="dark"] .mcp-nav-link:hover { color: #f5f0ea; }
  html[data-theme="dark"] .mcp-nav-link::after { background: #FFB86F; }
  html[data-theme="dark"] .mcp-nav-link.active { color: #FFB86F; }

  html[data-theme="dark"] .mcp-nav-actions { border-left-color: rgba(255, 184, 111, 0.12); }
  html[data-theme="dark"] .mcp-gh-link { color: #d5c3b5; }
  html[data-theme="dark"] .mcp-gh-link:hover { background: rgba(255, 184, 111, 0.1); color: #FFB86F; }

  html[data-theme="dark"] .mcp-jsr-btn { background: #FFB86F; color: #1a1815; }
  html[data-theme="dark"] .mcp-jsr-btn:hover { background: #D4A574; }

  html[data-theme="dark"] .mcp-menu-btn { border-color: rgba(255, 184, 111, 0.08); }
  html[data-theme="dark"] .mcp-menu-bar { background: #f5f0ea; }

  html[data-theme="dark"] .mcp-mobile-menu { background: rgba(26, 24, 21, 0.98) !important; }
  html[data-theme="dark"] .mcp-mobile-nav .mcp-nav-link { border-bottom-color: rgba(255, 184, 111, 0.06); }
  html[data-theme="dark"] .mcp-mobile-cta { border-top-color: rgba(255, 184, 111, 0.08); }
  html[data-theme="dark"] .mcp-mobile-gh { color: #d5c3b5; border-color: rgba(255, 184, 111, 0.15); }
  html[data-theme="dark"] .mcp-mobile-gh:hover { background: rgba(255, 184, 111, 0.08); color: #f5f0ea; }
</style>

<script>
  // Scroll hide/show
  const mcpHeader = document.querySelector('.mcp-header');
  let mcpLastScrollY = window.scrollY;

  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    if (y < 80) {
      mcpHeader?.classList.remove('header-hidden');
    } else if (y > mcpLastScrollY && y > 80) {
      mcpHeader?.classList.add('header-hidden');
    } else if (y < mcpLastScrollY) {
      mcpHeader?.classList.remove('header-hidden');
    }
    mcpLastScrollY = y;
  });

  // Mobile menu toggle
  const mcpMenuBtn = document.getElementById('mcp-mobile-menu-btn');
  const mcpMobileMenu = document.getElementById('mcp-mobile-menu');

  mcpMenuBtn?.addEventListener('click', () => {
    const isOpen = mcpMobileMenu?.classList.toggle('open');
    mcpMenuBtn?.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  });

  mcpMobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mcpMobileMenu.classList.remove('open');
      mcpMenuBtn?.setAttribute('aria-expanded', 'false');
    });
  });

  document.addEventListener('click', (e) => {
    const target = e.target as Node;
    if (!mcpMobileMenu?.contains(target) && !mcpMenuBtn?.contains(target) && mcpMobileMenu?.classList.contains('open')) {
      mcpMobileMenu.classList.remove('open');
      mcpMenuBtn?.setAttribute('aria-expanded', 'false');
    }
  });

  // Active section highlight
  const mcpSections = document.querySelectorAll('section[id]');
  const mcpNavLinks = document.querySelectorAll('.mcp-nav-link[href^="#"]');

  const mcpObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        mcpNavLinks.forEach((link) => {
          link.classList.toggle('active', link.getAttribute('href') === `#${id}`);
        });
      }
    });
  }, { threshold: 0.3, rootMargin: '-80px 0px -60% 0px' });

  mcpSections.forEach((s) => mcpObserver.observe(s));
</script>
