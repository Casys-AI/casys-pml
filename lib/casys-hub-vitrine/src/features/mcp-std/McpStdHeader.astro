---
import SubsiteHeader from '../../components/SubsiteHeader.astro';
import { useTranslations } from '../../i18n';

const locale = (Astro as any).currentLocale ?? 'en';
const t = useTranslations(locale).mcpStdHeader;
---

<SubsiteHeader
  logo={{ prefix: '@casys/', name: 'mcp-std', version: 'v0.4.0' }}
  navLinks={[
    { href: '#categories', label: t.categories },
    { href: '/mcp-std/catalog', label: t.catalog },
    { href: '#quickstart', label: t.quickstart },
    { href: '#install', label: t.install },
  ]}
  githubUrl="https://github.com/Casys-AI/casys-pml/tree/main/lib/std"
  jsrUrl="https://jsr.io/@casys/mcp-std"
  consultingLabel={t.workWithUs}
  heroAnchor="#mcp-std-hero"
/>
