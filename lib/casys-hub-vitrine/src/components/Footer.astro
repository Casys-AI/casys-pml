          </svg>
        </a>
        <a href="https://www.linkedin.com/company/casys-ai" target="_blank" rel="noopener" aria-label="LinkedIn" class="social-icon">
          <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  /* ========================================
     FOOTER - Editorial/Refined Aesthetic
     Font: Fraunces for brand
     Clean, minimal, sophisticated
     ======================================== */

  footer {
    padding: 64px 0 32px;
    background: var(--md-sys-color-surface-container-low);
    border-top: 1px solid var(--md-sys-color-outline-variant);
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Main Grid */
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 2fr;
    gap: 64px;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--md-sys-color-outline-variant);
  }

  /* Brand Section */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .brand-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: 8px;
  }

  .brand-logo {
    width: 22px;
    height: 22px;
  }

  .brand-name {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.75rem;
    font-weight: 600;
    font-optical-sizing: auto;
    color: var(--md-sys-color-on-surface);
    letter-spacing: -0.02em;
  }

  .brand-description {
    font-size: 0.95rem;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
    line-height: 1.5;
  }

  .brand-tagline {
    font-size: 0.85rem;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
    opacity: 0.7;
  }

  /* Navigation */
  .footer-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .nav-column {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .nav-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--md-sys-color-on-surface);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .nav-links {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .nav-links a {
    font-size: 0.9rem;
    color: var(--md-sys-color-on-surface-variant);
    text-decoration: none;
    transition: color 200ms ease-out;
  }

  .nav-links a:hover {
    color: var(--md-sys-color-primary);
  }

  .jsr-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .jsr-icon {
    flex-shrink: 0;
    border-radius: 3px;
  }

  /* Bottom Bar */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 24px;
  }

  .copyright {
    font-size: 0.85rem;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
    opacity: 0.8;
  }

  .social-icons {
    display: flex;
    gap: 12px;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: var(--md-sys-color-on-surface-variant);
    border-radius: 8px;
    transition: color 200ms ease-out, background 200ms ease-out;
  }

  .social-icon:hover {
    color: var(--md-sys-color-primary);
    background: var(--md-sys-color-surface-container-high);
  }

  .social-icon svg {
    width: 20px;
    height: 20px;
  }

  /* Tablet */
  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .footer-nav {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
  }

  /* Mobile */
  @media (max-width: 600px) {
    footer {
      padding: 48px 0 24px;
    }

    .footer-grid {
      gap: 32px;
    }

    .footer-nav {
      grid-template-columns: 1fr 1fr;
      gap: 24px 16px;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 16px;
      text-align: center;
    }
  }

  /* Very small screens (390px and below) */
  @media (max-width: 420px) {
    .footer-nav {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }
</style>

<style is:global>
  /* ========================================
     FOOTER - DARK MODE
     Warm orange palette (#FFB86F, #D4A574)
     ======================================== */

  html[data-theme="dark"] #footer {
    background: #0a0908;
    border-top-color: rgba(255, 184, 111, 0.1);
  }

  html[data-theme="dark"] #footer .footer-grid {
    border-bottom-color: rgba(255, 184, 111, 0.1);
  }


  html[data-theme="dark"] #footer .brand-name {
    color: #f5f0ea;
  }

  html[data-theme="dark"] #footer .brand-description {
    color: #d5c3b5;
  }

  html[data-theme="dark"] #footer .brand-tagline {
    color: #d5c3b5;
  }

  html[data-theme="dark"] #footer .nav-title {
    color: #f5f0ea;
  }

  html[data-theme="dark"] #footer .nav-links a {
    color: #d5c3b5;
  }

  html[data-theme="dark"] #footer .nav-links a:hover {
    color: #FFB86F;
  }

  html[data-theme="dark"] #footer .copyright {
    color: #d5c3b5;
  }

  html[data-theme="dark"] #footer .social-icon {
    color: #d5c3b5;
  }

  html[data-theme="dark"] #footer .social-icon:hover {
    color: #FFB86F;
    background: rgba(255, 184, 111, 0.1);
  }
</style>
