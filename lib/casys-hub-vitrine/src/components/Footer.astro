---
import { useTranslations } from '../i18n';
const locale = (Astro as any).currentLocale ?? 'en';
const currentYear = new Date().getFullYear();
const t = useTranslations(locale).footer;
---

<footer id="footer">
  <div class="footer-container">
    <!-- Main Grid -->
    <div class="footer-grid">
      <!-- Brand Column -->
      <div class="footer-brand">
        <a href="/" class="brand-link">
          <img src="/icons/logo.svg" alt="Casys" class="brand-logo" />
          <span class="brand-name">Casys</span>
        </a>
        <p class="brand-description">{t.description}</p>
        <p class="brand-tagline">{t.tagline}</p>
      </div>

      <!-- Navigation Columns -->
      <div class="footer-nav">
        <div class="nav-column">
          <h3 class="nav-title">{t.product}</h3>
          <nav class="nav-links">
            <a href="#projects">{t.projects}</a>
            <a href="#contact">{t.consulting}</a>
            <a href="#contact">{t.training}</a>
          </nav>
        </div>

        <div class="nav-column">
          <h3 class="nav-title">{t.openSource}</h3>
          <nav class="nav-links">
            <a href="https://mcp-std.casys.ai" target="_blank" rel="noopener">@casys/mcp-std</a>
            <a href="https://mcp-server.casys.ai" target="_blank" rel="noopener">@casys/mcp-server</a>
            <a href="https://mcp-bridge.casys.ai" target="_blank" rel="noopener">@casys/mcp-bridge</a>
            <a href="https://pml.casys.ai" target="_blank" rel="noopener">PML</a>
            <a href="https://jsr.io/@casys" target="_blank" rel="noopener" class="jsr-link">
              <svg class="jsr-icon" width="16" height="16" viewBox="0 -3 64 64" fill="none" aria-hidden="true">
                <path d="M 0,21.846 H 9.846 V 12 h 34.462 v 4.923 H 64 V 36.616 H 54.155 V 46.462 H 19.693 V 41.539 H 0" fill="#083344"/>
                <g fill="#f7df1e" transform="matrix(4.923,0,0,4.923,0,12)">
                  <path d="M 1,3 H 2 V 4 H 3 V 1 H 4 V 5 H 1"/>
                  <path d="M 5,1 H 8 V 2 H 6 V 3 H 8 V 6 H 5 V 5 H 7 V 4 H 5"/>
                  <path d="m 9,2 h 3 V 4 H 11 V 3 H 10 V 6 H 9"/>
                </g>
              </svg>
              JSR Packages
            </a>
          </nav>
        </div>

        <div class="nav-column">
          <h3 class="nav-title">{t.connect}</h3>
          <nav class="nav-links">
            <a href="#contact">{t.contact}</a>
            <a href="https://discord.gg/fuPg8drR" target="_blank" rel="noopener">{t.discord}</a>
            <a href="https://github.com/Casys-AI" target="_blank" rel="noopener">GitHub</a>
            <a href="https://www.linkedin.com/company/casys-ai" target="_blank" rel="noopener">LinkedIn</a>
          </nav>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <p class="copyright">&copy; {currentYear} Casys AI. {locale === 'fr' ? 'Tous droits réservés.' : locale === 'zh' ? '保留所有权利。' : 'All rights reserved.'}</p>
      <div class="social-icons">
        <a href="https://discord.gg/fuPg8drR" target="_blank" rel="noopener" aria-label="Discord" class="social-icon">
          <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
