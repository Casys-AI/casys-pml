---
export interface InstallCommand {
  runtime: string;
  command: string;
}

export interface InstallLink {
  icon: string;
  label: string;
  href: string;
  external?: boolean;
}

export interface BuiltWithBadge {
  label: string;
  href: string;
  svg?: string;
  text?: string;
}

export interface Props {
  sectionId: string;
  title: string;
  titleAccent: string;
  subtitle: string;
  commands: InstallCommand[];
  links: InstallLink[];
  builtWithLabel: string;
  builtWithBadges: BuiltWithBadge[];
  runtimeLabelWidth?: string;
}

const {
  sectionId,
  title,
  titleAccent,
  subtitle,
  commands,
  links,
  builtWithLabel,
  builtWithBadges,
  runtimeLabelWidth = '48px',
} = Astro.props;
---

<section id={sectionId}>
  <div class="si-container">
    <div class="si-content">
      <h2>{title} <span class="accent-text">{titleAccent}</span></h2>
      <p class="si-subtitle">{subtitle}</p>

      <div class="si-commands">
        {commands.map((cmd) => (
          <div class="si-row">
            <span class="si-runtime" style={`width: ${runtimeLabelWidth}`}>{cmd.runtime}</span>
            <div class="si-cmd">
              <code>{cmd.command}</code>
              <button class="si-copy-btn" aria-label={`Copy ${cmd.runtime} command`} data-copy={cmd.command}>
                <span class="material-symbols-rounded">content_copy</span>
              </button>
            </div>
          </div>
        ))}
      </div>

      <div class="si-links">
        {links.map((link) => (
          <a
            href={link.href}
            class="si-link"
            {...(link.external !== false && link.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            <span class="material-symbols-rounded">{link.icon}</span>
            <span>{link.label}</span>
            <span class="material-symbols-rounded si-link-arrow">arrow_outward</span>
          </a>
        ))}
      </div>

      <div class="si-built-with">
        <span class="si-built-label">{builtWithLabel}</span>
        {builtWithBadges.map((badge, i) => (
          <>
            {i > 0 && <span class="si-separator" aria-hidden="true">/</span>}
            <a href={badge.href} class="si-badge" target="_blank" rel="noopener noreferrer">
              {badge.svg && <Fragment set:html={badge.svg} />}
              {badge.text && <span class={badge.text === 'JSR' || badge.text === 'TensorFlow' ? 'si-mono-text' : ''}>{badge.text}</span>}
              {badge.label && !badge.text && <span>{badge.label}</span>}
            </a>
          </>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* ========================================
     SUBSITE INSTALL/LINKS SECTION - Shared
     ======================================== */

  section {
    position: relative;
    padding: 56px 0 72px;
    overflow: hidden;
  }

  .si-container { max-width: 1200px; margin: 0 auto; padding: 0 48px; }
  .si-subtitle { font-size: 1.1rem; color: var(--md-sys-color-on-surface-variant); margin: 0; line-height: 1.6; }

  .si-content { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 24px; }

  .si-content h2 { font-family: 'Fraunces', Georgia, serif; font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 600; color: var(--md-sys-color-on-surface); margin: 0; letter-spacing: -0.02em; }
  .si-content .si-subtitle { max-width: 500px; }

  .si-commands { display: flex; flex-direction: column; gap: 12px; width: 100%; max-width: 560px; margin-top: 8px; }

  .si-row { display: flex; align-items: center; gap: 12px; }

  .si-runtime { font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--md-sys-color-on-surface-variant); text-align: right; flex-shrink: 0; }

  .si-cmd { flex: 1; display: flex; align-items: center; gap: 8px; padding: 12px 16px; background: var(--md-sys-color-surface-container-lowest); border: 1px solid var(--md-sys-color-outline-variant); border-radius: 10px; transition: border-color 200ms ease-out; }
  .si-cmd:hover { border-color: var(--md-sys-color-primary); }

  .si-cmd code { flex: 1; font-family: 'JetBrains Mono', monospace; font-size: 0.8125rem; color: var(--md-sys-color-on-surface); user-select: all; }

  .si-copy-btn { display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; border: none; background: transparent; border-radius: 6px; cursor: pointer; color: var(--md-sys-color-on-surface-variant); transition: background 150ms ease-out, color 150ms ease-out; flex-shrink: 0; }
  .si-copy-btn:hover { background: var(--md-sys-color-surface-container-high); color: var(--md-sys-color-primary); }
  .si-copy-btn:focus-visible { outline: 3px solid var(--md-sys-color-primary); outline-offset: 2px; }
  .si-copy-btn .material-symbols-rounded { font-size: 18px; }

  .si-links { display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; margin-top: 8px; }

  .si-link { display: flex; align-items: center; gap: 8px; padding: 10px 20px; background: transparent; color: var(--md-sys-color-on-surface); border: 1px solid var(--md-sys-color-outline-variant); border-radius: 8px; font-size: 0.875rem; font-weight: 500; text-decoration: none; transition: background 200ms ease-out, border-color 200ms ease-out; }
  .si-link:hover { background: var(--md-sys-color-surface-container); border-color: var(--md-sys-color-primary); }
  .si-link:focus-visible { outline: 3px solid var(--md-sys-color-primary); outline-offset: 4px; }
  .si-link .material-symbols-rounded { font-size: 18px; color: var(--md-sys-color-on-surface-variant); }
  .si-link .si-link-arrow { font-size: 16px; opacity: 0; transition: opacity 150ms ease-out; }
  .si-link:hover .si-link-arrow { opacity: 1; }

  .si-built-with { display: flex; align-items: center; gap: 12px; margin-top: 16px; font-size: 0.8125rem; flex-wrap: wrap; justify-content: center; }
  .si-built-label { color: var(--md-sys-color-on-surface-variant); font-weight: 500; }

  .si-badge { display: flex; align-items: center; gap: 6px; color: var(--md-sys-color-on-surface); text-decoration: none; font-weight: 600; padding: 4px 10px; border-radius: 6px; transition: background 150ms ease-out; }
  .si-badge:hover { background: var(--md-sys-color-surface-container-high); }
  .si-badge :global(svg) { width: 18px; height: 18px; }
  .si-mono-text { font-family: 'JetBrains Mono', monospace; font-weight: 700; font-size: 0.8125rem; letter-spacing: 0.04em; }
  .si-separator { color: var(--md-sys-color-outline-variant); }

  @media (max-width: 1024px) { .si-container { padding: 0 32px; } }
  @media (max-width: 768px) {
    section { padding: 60px 0 80px; }
    .si-container { padding: 0 20px; }
    .si-row { flex-direction: column; align-items: stretch; gap: 6px; }
    .si-runtime { text-align: left; width: auto !important; }
    .si-links { flex-direction: column; align-items: center; }
    .si-link { width: 100%; justify-content: center; max-width: 300px; }
  }
  @media (max-width: 380px) { .si-container { padding: 0 14px; } }
</style>

<style is:global>
  /* ========================================
     SUBSITE INSTALL - DARK MODE
     ======================================== */

  html[data-theme="dark"] .si-content h2 { color: #f5f0ea; }
  html[data-theme="dark"] .si-subtitle { color: #d5c3b5; }
  html[data-theme="dark"] .si-runtime { color: #a89a8c; }
  html[data-theme="dark"] .si-cmd { background: #111110; border-color: rgba(255, 184, 111, 0.1); }
  html[data-theme="dark"] .si-cmd:hover { border-color: rgba(255, 184, 111, 0.3); }
  html[data-theme="dark"] .si-cmd code { color: #f5f0ea; }
  html[data-theme="dark"] .si-copy-btn { color: #a89a8c; }
  html[data-theme="dark"] .si-copy-btn:hover { background: rgba(255, 184, 111, 0.1); color: #FFB86F; }
  html[data-theme="dark"] .si-link { color: #d5c3b5; border-color: rgba(255, 184, 111, 0.12); }
  html[data-theme="dark"] .si-link:hover { background: rgba(255, 184, 111, 0.08); border-color: rgba(255, 184, 111, 0.3); color: #f5f0ea; }
  html[data-theme="dark"] .si-link .material-symbols-rounded { color: #a89a8c; }
  html[data-theme="dark"] .si-link:hover .material-symbols-rounded { color: #FFB86F; }
  html[data-theme="dark"] .si-built-label { color: #a89a8c; }
  html[data-theme="dark"] .si-badge { color: #d5c3b5; }
  html[data-theme="dark"] .si-badge:hover { background: rgba(255, 184, 111, 0.08); color: #FFB86F; }
  html[data-theme="dark"] .si-separator { color: rgba(255, 184, 111, 0.15); }

  /* Section background */
  html[data-theme="dark"] #install,
  html[data-theme="dark"] #links {
    background: #0a0908;
  }
</style>

<script is:inline>
  // Copy to clipboard
  (function() {
    document.querySelectorAll('.si-copy-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var text = btn.dataset.copy;
        if (!text) return;
        navigator.clipboard.writeText(text).then(function() {
          var icon = btn.querySelector('.material-symbols-rounded');
          if (icon) {
            var original = icon.textContent;
            icon.textContent = 'check';
            btn.style.color = '#6ee7b7';
            setTimeout(function() { icon.textContent = original; btn.style.color = ''; }, 2000);
          }
        }).catch(function() {});
      });
    });

    // Smooth scroll for all anchor links (respects reduced motion)
    var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    document.querySelectorAll('.si-link[href^="#"]').forEach(function(link) {
      link.addEventListener('click', function(e) {
        var targetId = link.getAttribute('href');
        if (!targetId || targetId === '#') return;
        var target = document.querySelector(targetId);
        if (!target) return;
        e.preventDefault();
        target.scrollIntoView({ behavior: prefersReducedMotion ? 'auto' : 'smooth', block: 'start' });
        history.pushState(null, '', targetId);
      });
    });
  })();
</script>
