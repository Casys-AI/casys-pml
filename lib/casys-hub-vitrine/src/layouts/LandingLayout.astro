---
import '../styles.css';
import Analytics from '@vercel/analytics/astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
}

const { title } = Astro.props;
const locale = (Astro as any).currentLocale ?? 'en';
const pathname = Astro.url.pathname;
const siteUrl = import.meta.env.PUBLIC_SITE_URL as string | undefined;
const canonicalUrl = siteUrl ? new URL(pathname, siteUrl).toString() : undefined;
const ogLocaleMap = { en: 'en_US', fr: 'fr_FR', zh: 'zh_CN' } as const;
const ogLocale = ogLocaleMap[locale as keyof typeof ogLocaleMap] ?? 'en_US';

// Meta tags based on business positioning
const metaTitles = {
  en: 'Casys - Applied AI Research | Open Source Tools & Consulting',
  fr: 'Casys - Applied AI Research | Outils Open Source & Consulting',
  zh: 'Casys - 应用 AI 研究 | 开源工具与咨询',
} as const;
const metaTitle = metaTitles[locale as keyof typeof metaTitles] ?? metaTitles.en;

const metaDescriptions = {
  en: 'Applied AI research lab. We explore AI architectures, build open-source tools (MCP Gateway, CasysDB), and share what we learn. 10+ years expertise: KM → Graph → Agents. Consulting available.',
  fr: 'Lab de recherche AI appliquée. On explore architectures AI, build des outils open-source (MCP Gateway, CasysDB), et partage ce qu\'on apprend. 10+ ans expertise KM → Graph → Agents. Consulting disponible.',
  zh: '应用 AI 研究实验室。我们探索 AI 架构，构建开源工具（MCP Gateway、CasysDB），并分享所学。10+ 年经验：KM → Graph → Agents。提供咨询服务。',
} as const;
const metaDescription = metaDescriptions[locale as keyof typeof metaDescriptions] ?? metaDescriptions.en;
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={metaDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/icons/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="manifest" href="/icons/site.webmanifest" />

    <!-- Google Fonts - Fraunces (Display) + Inter Variable (Body) + JetBrains Mono + Material Symbols -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,100..900;1,9..144,100..900&family=Instrument+Serif:ital@0;1&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />

    <script>
      // Auto language redirect (client-only): redirect to /fr or /zh based on browser language
      (function () {
        try {
          var path = location.pathname;
          if (!path.startsWith('/fr') && !path.startsWith('/zh')) {
            var lang = (navigator.languages && navigator.languages[0]) || navigator.language || '';
            lang = String(lang || '').toLowerCase();
            var prefix = '';
            if (lang.startsWith('fr')) prefix = '/fr';
            else if (lang.startsWith('zh')) prefix = '/zh';
            if (prefix) {
              var target = path === '/' ? prefix + '/' : (prefix + path);
              location.replace(target + location.search + location.hash);
            }
          }
        } catch (_) { /* no-op */ }
      })();

      // Auto theme sync with system preference (Material Design 3)
      (function () {
        try {
          var root = document.documentElement;
          var mql = window.matchMedia('(prefers-color-scheme: dark)');
          var apply = function () {
            root.dataset.theme = mql.matches ? 'dark' : 'light';
          };
          apply();
          mql.addEventListener('change', apply);
        } catch (_) { /* no-op */ }
      })();
    </script>
    <title>{metaTitle}</title>
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <style is:inline>
      /* ============================================
         LAYOUT ESSENTIALS
         Minimal global styles - Component dark mode
         handled in each component's <style is:global>
         ============================================ */

      /* Fix mobile header overlap - scroll-padding compensates for fixed header */
      html {
        scroll-padding-top: 80px;
      }

      /* Body padding to prevent fixed header from covering content */
      body {
        padding-top: 72px;
      }

      /* Dark mode base background */
      html[data-theme="dark"],
      html[data-theme="dark"] body {
        background: #0a0908;
      }

      /* Footer dark mode (shared component) */
      html[data-theme="dark"] .footer {
        background: #0a0908;
        border-top-color: rgba(255, 184, 111, 0.1);
      }

      html[data-theme="dark"] .footer .title {
        color: #f5f0ea;
      }

      html[data-theme="dark"] .footer .title .material-symbols-rounded {
        color: #FFB86F;
      }

      html[data-theme="dark"] .footer .links a {
        color: #d5c3b5;
      }

      html[data-theme="dark"] .footer .links a:hover {
        background: rgba(255, 184, 111, 0.1);
        color: #FFB86F;
      }

      html[data-theme="dark"] .footer .logo .material-symbols-rounded {
        color: #FFB86F;
      }

      html[data-theme="dark"] .footer .brand-name {
        color: #FFB86F;
      }

      html[data-theme="dark"] .footer .description,
      html[data-theme="dark"] .footer .tagline,
      html[data-theme="dark"] .footer .copyright {
        color: #d5c3b5;
      }

      html[data-theme="dark"] .footer .divider {
        background: rgba(255, 184, 111, 0.1);
      }

      html[data-theme="dark"] .footer .social-link {
        background: rgba(255, 184, 111, 0.1);
        color: #f5f0ea;
        border: 1px solid rgba(255, 184, 111, 0.2);
      }

      html[data-theme="dark"] .footer .social-link:hover {
        background: #FFB86F;
        color: #1a1815;
        border-color: #FFB86F;
      }
    </style>
    <meta property="og:type" content="website" />
    <meta property="og:title" content={metaTitle} />
    <meta property="og:description" content={metaDescription} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:locale" content={ogLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={metaTitle} />
    <meta name="twitter:description" content={metaDescription} />

    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-FR86NHGK8Y"></script>
    <script is:inline>
      // @ts-nocheck
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-FR86NHGK8Y');
    </script>
  </head>

  <body class="landing-container">
    <!-- Header Component -->
    <Header />

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <Footer />

    <!-- Scripts pour les boutons -->
    <script>
      // Gestion du bouton de connexion (mock pour l'instant)
      document.getElementById('login-btn')?.addEventListener('click', () => {
        // Pour l'instant, redirection directe vers l'app
        // Plus tard : modal de connexion ou redirection vers auth
        window.location.href = '/app';
      });

      // Beta signup button handler
      document.getElementById('beta-signup-btn')?.addEventListener('click', () => {
        // For now: simple alert
        // Later: modal with form or API integration
        alert('Beta access request — coming soon!');
      });

      // Theme follows system preference only (no manual toggle)
    </script>


    <Analytics />
  </body>
</html>