---
import '../styles.css';
import Analytics from '@vercel/analytics/astro';
import { getCollection } from 'astro:content';
import HrefLang from '../components/HrefLang.astro';

export interface Props {
  title: string;
  locale?: 'en' | 'fr' | 'zh';
  description?: string;
  slug?: string;
  ogTitle?: string;
  ogDescription?: string;
  datePublished?: string;
  dateModified?: string;
  author?: string;
  tags?: string[];
  category?: string;
}

const { title, locale = 'en', description, slug, ogTitle, ogDescription, datePublished, dateModified, author, tags, category } = Astro.props;
const effectiveOgTitle = ogTitle || title;
const effectiveOgDescription = ogDescription || description;
const siteUrl = (import.meta.env.PUBLIC_SITE_URL as string | undefined)?.trim();
const ogImage = slug
  ? `${siteUrl || ''}/og/blog/${slug}.png`
  : `${siteUrl || ''}/og/home.png`;
const localePrefix = locale === 'en' ? '' : `/${locale}`;
const pathname = Astro.url.pathname;
const canonicalUrl = siteUrl ? new URL(pathname, siteUrl).toString() : undefined;
const blogBaseUrl = siteUrl ? `${siteUrl}${localePrefix}/blog` : undefined;

const labels = {
  en: {
    blogTitle: 'CASYS Blog',
    blogSubtitle: 'Articles and insights on CASYS development.',
    allArticles: 'All articles',
    recentArticles: 'Recent articles',
    byCategory: 'By category',
    popularTags: 'Popular tags',
    search: 'Search',
    subscribe: 'Subscribe to updates',
    home: 'Home',
    others: 'others',
    general: 'General',
  },
  fr: {
    blogTitle: 'Blog CASYS',
    blogSubtitle: 'Articles et actualités sur le développement de CASYS.',
    allArticles: 'Tous les articles',
    recentArticles: 'Articles récents',
    byCategory: 'Par catégorie',
    popularTags: 'Tags populaires',
    search: 'Rechercher',
    subscribe: "S'abonner aux nouveautés",
    home: 'Accueil',
    others: 'autres',
    general: 'Général',
  },
  zh: {
    blogTitle: 'CASYS 博客',
    blogSubtitle: 'CASYS 开发相关文章与动态。',
    allArticles: '所有文章',
    recentArticles: '最新文章',
    byCategory: '按类别',
    popularTags: '热门标签',
    search: '搜索',
    subscribe: '订阅更新',
    home: '首页',
    others: '更多',
    general: '通用',
  },
};

const t = labels[locale];
const blogBase = locale === 'en' ? '/blog' : `/${locale}/blog`;
const homeBase = locale === 'en' ? '/' : `/${locale}`;

// Récupérer les articles de blog pour la navigation (filtrés par locale)
const blogPosts = await getCollection('blog', ({ data, id }) => {
  return !data.draft && id.startsWith(`${locale}/`);
});

// Trier par date de publication (plus récent en premier)
const sortedPosts = blogPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Articles récents (5 derniers)
const recentPosts = sortedPosts.slice(0, 5);

// Grouper par catégorie
const postsByCategory = sortedPosts.reduce((acc, post) => {
  const category = post.data.category || t.general;
  if (!acc[category]) acc[category] = [];
  acc[category].push(post);
  return acc;
}, {} as Record<string, typeof sortedPosts>);

// Tags populaires
const allTags = sortedPosts.flatMap(post => post.data.tags);
const tagCounts = allTags.reduce((acc, tag) => {
  acc[tag] = (acc[tag] || 0) + 1;
  return acc;
}, {} as Record<string, number>);
const popularTags = Object.entries(tagCounts)
  .sort(([,a], [,b]) => b - a)
  .slice(0, 10)
  .map(([tag]) => tag);

const currentPath = Astro.url.pathname;

// Helper to get slug without locale prefix
function getPostSlug(post: typeof sortedPosts[0]) {
  return post.slug.replace(`${locale}/`, '');
}
---

<!DOCTYPE html>
<html lang={locale === 'zh' ? 'zh-CN' : locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description || t.blogSubtitle} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/icons/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="manifest" href="/icons/site.webmanifest" />

    <!-- Google Fonts - Fraunces (Display) + Inter (Body) + JetBrains Mono + Material Symbols -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,100..900;1,9..144,100..900&family=Instrument+Serif:ital@0;1&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />

    <script>
      // Auto theme sync with system preference
      (function() {
        try {
          var root = document.documentElement;
          var mql = window.matchMedia('(prefers-color-scheme: dark)');
          var apply = function() {
            root.dataset.theme = mql.matches ? 'dark' : 'light';
          };
          apply();
          mql.addEventListener('change', apply);
        } catch(_) {}
      })();
    </script>

    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-FR86NHGK8Y"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-FR86NHGK8Y', {
        cookie_domain: 'casys.ai',
        linker: { accept_incoming: false, decorate: false }
      });
    </script>

    <title>{title}</title>
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <HrefLang />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="Casys AI" />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:title" content={effectiveOgTitle} />
    {effectiveOgDescription && <meta property="og:description" content={effectiveOgDescription} />}
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={effectiveOgTitle} />
    {effectiveOgDescription && <meta name="twitter:description" content={effectiveOgDescription} />}
    <meta name="twitter:image" content={ogImage} />
    <script defer src="/u/script.js" data-website-id="41fe387f-874e-4c5b-8a69-1364587b77f5"></script>
    {slug && blogBaseUrl && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": title,
        "description": description || t.blogSubtitle,
        ...(siteUrl && { "image": ogImage }),
        ...(datePublished && { "datePublished": datePublished }),
        ...(dateModified && { "dateModified": dateModified }),
        "author": author
          ? { "@type": "Person", "name": author }
          : { "@type": "Organization", "name": "Casys AI", "url": "https://casys.ai" },
        "publisher": {
          "@type": "Organization",
          "name": "Casys AI",
          "logo": {
            "@type": "ImageObject",
            "url": "https://casys.ai/icons/logo.svg"
          }
        },
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": `${blogBaseUrl}/${slug}`
        },
        ...(tags?.length && { "keywords": tags.join(", ") }),
        ...(category && { "articleSection": category }),
        "inLanguage": locale
      }).replace(/</g, '\\u003c')} />
    )}
  </head>

  <body class="blog-body">
    <!-- Nav bar -->
    <nav class="blog-topnav">
      <div class="blog-topnav-inner">
        <!-- Mobile sidebar toggle -->
        <button class="blog-sidebar-toggle" aria-label="Toggle sidebar" id="sidebarToggle">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
            <line x1="3" y1="5" x2="17" y2="5" />
            <line x1="3" y1="10" x2="17" y2="10" />
            <line x1="3" y1="15" x2="17" y2="15" />
          </svg>
        </button>

        <!-- Logo + title -->
        <div class="blog-topnav-brand">
          <img src="/icons/favicon-32x32.png" alt="CASYS" class="blog-topnav-logo" />
          <span class="blog-topnav-name">CASYS</span>
          <span class="blog-topnav-label">Blog</span>
        </div>

        <!-- Navigation links -->
        <div class="blog-topnav-links">
          <a href={homeBase} class="blog-topnav-link">&larr; {t.home}</a>
        </div>
      </div>
    </nav>

    <!-- Main layout: sidebar + content -->
    <div class="blog-shell">
      <!-- Sidebar overlay (mobile) -->
      <div class="blog-sidebar-overlay" id="sidebarOverlay"></div>

      <!-- Sidebar -->
      <aside class="blog-sidebar" id="blogSidebar">
        <button class="blog-sidebar-close" id="sidebarClose" aria-label="Close sidebar">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="4" y1="4" x2="14" y2="14" />
            <line x1="14" y1="4" x2="4" y2="14" />
          </svg>
        </button>
        <div class="blog-sidebar-header">
          <h2 class="blog-sidebar-title">{t.blogTitle}</h2>
          <p class="blog-sidebar-subtitle">{t.blogSubtitle}</p>
        </div>

        <nav class="blog-sidebar-nav">
          <!-- All articles link -->
          <div class="blog-nav-section">
            <a
              href={blogBase}
              class:list={[
                'blog-nav-link',
                { 'blog-nav-link--active': currentPath === blogBase || currentPath === `${blogBase}/` }
              ]}
            >
              {t.allArticles}
            </a>
          </div>

          <!-- Recent articles -->
          <div class="blog-nav-section">
            <h3 class="blog-nav-heading">{t.recentArticles}</h3>
            <ul class="blog-nav-list">
              {recentPosts.map((post) => (
                <li>
                  <a
                    href={`${blogBase}/${getPostSlug(post)}`}
                    class:list={[
                      'blog-nav-link blog-nav-link--article',
                      { 'blog-nav-link--active': currentPath === `${blogBase}/${getPostSlug(post)}` }
                    ]}
                  >
                    <span class="blog-nav-link-title">{post.data.title}</span>
                    <span class="blog-nav-link-meta">
                      <span>{post.data.date.toLocaleDateString(locale === 'zh' ? 'zh-CN' : locale)}</span>
                      {post.data.category && (
                        <>
                          <span class="blog-nav-link-dot">&middot;</span>
                          <span>{post.data.category}</span>
                        </>
                      )}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Categories -->
          <div class="blog-nav-section">
            <h3 class="blog-nav-heading">{t.byCategory}</h3>
            <ul class="blog-nav-list">
              {Object.entries(postsByCategory).map(([categoryName, posts]) => (
                <li>
                  <div class="blog-category-row">
                    <span class="blog-category-name">{categoryName}</span>
                    <span class="blog-category-count">{posts.length}</span>
                  </div>
                  <ul class="blog-category-posts">
                    {posts.slice(0, 3).map((post) => (
                      <li>
                        <a
                          href={`${blogBase}/${getPostSlug(post)}`}
                          class:list={[
                            'blog-nav-link blog-nav-link--sub',
                            { 'blog-nav-link--active': currentPath === `${blogBase}/${getPostSlug(post)}` }
                          ]}
                        >
                          <span class="blog-nav-link-title">{post.data.title}</span>
                        </a>
                      </li>
                    ))}
                    {posts.length > 3 && (
                      <li>
                        <span class="blog-category-more">
                          +{posts.length - 3} {t.others}
                        </span>
                      </li>
                    )}
                  </ul>
                </li>
              ))}
            </ul>
          </div>

          <!-- Popular tags -->
          <div class="blog-nav-section">
            <h3 class="blog-nav-heading">{t.popularTags}</h3>
            <div class="blog-tags">
              {popularTags.map((tag) => (
                <span class="blog-tag">#{tag}</span>
              ))}
            </div>
          </div>

          <!-- Actions -->
          <div class="blog-sidebar-actions">
            <button class="blog-sidebar-action-btn">{t.search}</button>
            <button class="blog-sidebar-action-btn">{t.subscribe}</button>
          </div>
        </nav>
      </aside>

      <!-- Main content -->
      <main class="blog-main">
        <div class="blog-content">
          <slot />
        </div>
      </main>
    </div>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const toggle = document.getElementById('sidebarToggle');
        const close = document.getElementById('sidebarClose');
        const sidebar = document.getElementById('blogSidebar');
        const overlay = document.getElementById('sidebarOverlay');
        if (!toggle || !close || !sidebar || !overlay) return;

        function open() {
          sidebar.classList.add('blog-sidebar--open');
          overlay.classList.add('blog-sidebar-overlay--visible');
          document.body.style.overflow = 'hidden';
        }
        function shut() {
          sidebar.classList.remove('blog-sidebar--open');
          overlay.classList.remove('blog-sidebar-overlay--visible');
          document.body.style.overflow = '';
        }
        toggle.addEventListener('click', open);
        close.addEventListener('click', shut);
        overlay.addEventListener('click', shut);
      });
    </script>
    <Analytics />
  </body>
</html>

<style>
  /* =========================================
     BLOG LAYOUT - Scoped Styles (Light Mode)
     ========================================= */

  /* --- Body --- */
  .blog-body {
    margin: 0;
    min-height: 100vh;
    overflow: hidden;
    background-color: var(--md-sys-color-surface, #fafaf9);
    color: var(--md-sys-color-on-surface, #1c1917);
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    line-height: 1.6;
  }

  /* --- Top Navigation Bar --- */
  .blog-topnav {
    position: sticky;
    top: 0;
    z-index: 40;
    height: 60px;
    display: flex;
    align-items: center;
    padding: 0 1.25rem;
    background-color: var(--md-sys-color-surface, #ffffff);
    border-bottom: 1px solid var(--md-sys-color-outline-variant, #e7e5e4);
  }

  .blog-topnav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .blog-topnav-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .blog-topnav-logo {
    width: 28px;
    height: 28px;
    border-radius: 6px;
  }

  .blog-topnav-name {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--md-sys-color-on-surface, #1c1917);
    letter-spacing: -0.01em;
  }

  .blog-topnav-label {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--md-sys-color-on-surface-variant, #78716c);
    margin-left: 0.25rem;
    padding: 0.1em 0.5em;
    background: var(--md-sys-color-surface-variant, #f5f5f4);
    border-radius: 4px;
  }

  .blog-topnav-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .blog-topnav-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--md-sys-color-on-surface-variant, #57534e);
    text-decoration: none;
    padding: 0.35em 0.7em;
    border-radius: 6px;
    transition: color 0.15s, background-color 0.15s;
  }

  .blog-topnav-link:hover {
    color: var(--md-sys-color-on-surface, #1c1917);
    background-color: var(--md-sys-color-surface-variant, #f5f5f4);
  }

  .blog-topnav-sep {
    display: block;
    width: 1px;
    height: 1.25rem;
    background-color: var(--md-sys-color-outline-variant, #d6d3d1);
  }

  /* --- Shell (sidebar + content) --- */
  .blog-shell {
    display: flex;
    height: calc(100vh - 60px);
  }

  /* --- Sidebar --- */
  .blog-sidebar {
    width: 300px;
    min-width: 300px;
    display: flex;
    flex-direction: column;
    background-color: var(--md-sys-color-surface, #ffffff);
    border-right: 1px solid var(--md-sys-color-outline-variant, #e7e5e4);
  }

  .blog-sidebar-header {
    padding: 1.25rem 1.25rem 1rem;
    border-bottom: 1px solid var(--md-sys-color-outline-variant, #e7e5e4);
  }

  .blog-sidebar-title {
    margin: 0;
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--md-sys-color-on-surface, #1c1917);
    letter-spacing: -0.01em;
  }

  .blog-sidebar-subtitle {
    margin: 0.35rem 0 0;
    font-size: 0.8rem;
    color: var(--md-sys-color-on-surface-variant, #78716c);
    line-height: 1.4;
  }

  .blog-sidebar-nav {
    flex: 1;
    overflow-y: auto;
    padding: 0.75rem 0;
  }

  /* --- Navigation Sections --- */
  .blog-nav-section {
    padding: 0.5rem 1rem;
  }

  .blog-nav-section + .blog-nav-section {
    margin-top: 0.25rem;
  }

  .blog-nav-heading {
    margin: 0 0 0.4rem;
    padding: 0 0.35rem;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--md-sys-color-on-surface-variant, #a8a29e);
  }

  .blog-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .blog-nav-list > li + li {
    margin-top: 1px;
  }

  /* --- Nav Links --- */
  .blog-nav-link {
    display: block;
    padding: 0.4rem 0.6rem;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--md-sys-color-on-surface, #1c1917);
    text-decoration: none;
    transition: background-color 0.15s, color 0.15s;
    border-left: 2px solid transparent;
  }

  .blog-nav-link:hover {
    background-color: var(--md-sys-color-surface-variant, #f5f5f4);
  }

  .blog-nav-link--article {
    font-weight: 400;
    color: var(--md-sys-color-on-surface-variant, #57534e);
    font-size: 0.82rem;
  }

  .blog-nav-link--sub {
    font-weight: 400;
    font-size: 0.78rem;
    color: var(--md-sys-color-on-surface-variant, #78716c);
    padding: 0.3rem 0.5rem;
  }

  .blog-nav-link--active {
    background-color: var(--md-sys-color-secondary-container, #ede9fe);
    color: var(--md-sys-color-on-secondary-container, #4338ca);
    border-left-color: var(--md-sys-color-primary, #6366f1);
    font-weight: 600;
  }

  .blog-nav-link--active:hover {
    background-color: var(--md-sys-color-secondary-container, #ede9fe);
  }

  .blog-nav-link-title {
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .blog-nav-link-meta {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-top: 0.15rem;
    font-size: 0.72rem;
    color: var(--md-sys-color-on-surface-variant, #a8a29e);
  }

  .blog-nav-link-dot {
    opacity: 0.5;
  }

  /* --- Categories --- */
  .blog-category-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.35rem 0.6rem;
  }

  .blog-category-name {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--md-sys-color-on-surface, #1c1917);
  }

  .blog-category-count {
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--md-sys-color-on-surface-variant, #78716c);
    background-color: var(--md-sys-color-surface-variant, #f5f5f4);
    padding: 0.1em 0.55em;
    border-radius: 999px;
    line-height: 1.4;
  }

  .blog-category-posts {
    list-style: none;
    margin: 0;
    padding: 0 0 0 0.75rem;
  }

  .blog-category-posts > li + li {
    margin-top: 1px;
  }

  .blog-category-more {
    display: block;
    padding: 0.2rem 0.5rem;
    font-size: 0.72rem;
    color: var(--md-sys-color-on-surface-variant, #a8a29e);
    font-style: italic;
  }

  /* --- Tags --- */
  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    padding: 0 0.35rem;
  }

  .blog-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.2em 0.6em;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 500;
    background-color: var(--md-sys-color-surface-variant, #f5f5f4);
    color: var(--md-sys-color-on-surface-variant, #57534e);
    cursor: pointer;
    transition: background-color 0.15s, color 0.15s;
    user-select: none;
  }

  .blog-tag:hover {
    background-color: var(--md-sys-color-outline-variant, #e7e5e4);
    color: var(--md-sys-color-on-surface, #1c1917);
  }

  /* --- Sidebar Actions --- */
  .blog-sidebar-actions {
    border-top: 1px solid var(--md-sys-color-outline-variant, #e7e5e4);
    padding: 0.75rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .blog-sidebar-action-btn {
    display: block;
    width: 100%;
    text-align: left;
    padding: 0.45rem 0.6rem;
    font-family: inherit;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--md-sys-color-on-surface-variant, #57534e);
    background: none;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: background-color 0.15s, color 0.15s;
  }

  .blog-sidebar-action-btn:hover {
    background-color: var(--md-sys-color-surface-variant, #f5f5f4);
    color: var(--md-sys-color-on-surface, #1c1917);
  }

  /* --- Main Content Area --- */
  .blog-main {
    flex: 1;
    overflow-y: auto;
    background-color: var(--md-sys-color-surface, #fafaf9);
  }

  .blog-content {
    max-width: 56rem;
    margin: 0 auto;
    padding: 2.5rem 2rem;
  }

  /* --- Mobile Sidebar Toggle Button --- */
  .blog-sidebar-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    padding: 0;
    border: none;
    border-radius: 8px;
    background: none;
    color: var(--md-sys-color-on-surface, #1c1917);
    cursor: pointer;
    transition: background-color 0.15s;
  }

  .blog-sidebar-toggle:hover {
    background-color: var(--md-sys-color-surface-variant, #f5f5f4);
  }

  /* --- Sidebar Close Button (mobile only) --- */
  .blog-sidebar-close {
    display: none;
    position: absolute;
    top: 14px;
    right: 12px;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    padding: 0;
    border: none;
    border-radius: 8px;
    background: none;
    color: var(--md-sys-color-on-surface-variant, #78716c);
    cursor: pointer;
    transition: background-color 0.15s, color 0.15s;
    z-index: 1;
  }

  .blog-sidebar-close:hover {
    background-color: var(--md-sys-color-surface-variant, #f5f5f4);
    color: var(--md-sys-color-on-surface, #1c1917);
  }

  /* --- Sidebar Overlay (mobile) --- */
  .blog-sidebar-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 49;
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .blog-sidebar-overlay--visible {
    opacity: 1;
  }

  /* --- Responsive: Mobile (< 768px) --- */
  @media (max-width: 767px) {
    .blog-sidebar-toggle {
      display: flex;
    }

    .blog-sidebar-close {
      display: flex;
    }

    .blog-sidebar-overlay {
      display: block;
      pointer-events: none;
    }

    .blog-sidebar-overlay--visible {
      pointer-events: auto;
    }

    .blog-sidebar {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      z-index: 50;
      transform: translateX(-100%);
      transition: transform 0.3s ease;
      box-shadow: none;
    }

    .blog-sidebar--open {
      transform: translateX(0);
      box-shadow: 4px 0 24px rgba(0, 0, 0, 0.15);
    }

    .blog-content {
      padding: 1.5rem 1rem;
    }

    .blog-body {
      overflow: auto;
    }

    .blog-shell {
      flex-direction: column;
      height: auto;
      min-height: calc(100vh - 60px);
    }

    .blog-main {
      overflow: visible;
    }
  }
</style>

