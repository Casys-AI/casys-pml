---
import '../styles.css';
import '../styles/fonts.css';
import Analytics from '@vercel/analytics/astro';
import { getCollection } from 'astro:content';
import HrefLang from '../components/HrefLang.astro';
import { DEFAULT_SITE_URL, resolvePublicUrl } from '../lib/public-url';

export interface Props {
  title: string;
  locale?: 'en' | 'fr' | 'zh' | 'zh-TW';
  description?: string;
  slug?: string;
  ogTitle?: string;
  ogDescription?: string;
  datePublished?: string;
  dateModified?: string;
  author?: string;
  tags?: string[];
  category?: string;
}

const { title, locale = 'en', description, slug, ogTitle, ogDescription, datePublished, dateModified, author, tags, category } = Astro.props;
const effectiveOgTitle = ogTitle || title;
const effectiveOgDescription = ogDescription || description;
const siteUrl = (import.meta.env.PUBLIC_SITE_URL as string | undefined)?.trim();
const rootSiteUrl = (siteUrl || DEFAULT_SITE_URL).replace(/\/+$/, '');
const pathname = Astro.url.pathname;
const publicUrl = resolvePublicUrl(pathname, siteUrl);
const ogImage = slug
  ? new URL(`/og/blog/${slug}.png`, publicUrl.origin).toString()
  : new URL('/og/home.png', publicUrl.origin).toString();
const localePrefix = locale === 'en' ? '' : `/${locale}`;
const canonicalUrl = publicUrl.canonicalUrl;
const blogBaseUrl = `${rootSiteUrl}${localePrefix}/blog`;

const labels = {
  en: {
    blogTitle: 'CASYS Blog',
    blogSubtitle: 'Articles and insights on CASYS development.',
    allArticles: 'All articles',
    recentArticles: 'Recent articles',
    byCategory: 'By category',
    popularTags: 'Popular tags',
    search: 'Search',
    subscribe: 'Subscribe to updates',
    home: 'Home',
    others: 'others',
    general: 'General',
    toc: 'On this page',
  },
  fr: {
    blogTitle: 'Blog CASYS',
    blogSubtitle: 'Articles et actualités sur le développement de CASYS.',
    allArticles: 'Tous les articles',
    recentArticles: 'Articles récents',
    byCategory: 'Par catégorie',
    popularTags: 'Tags populaires',
    search: 'Rechercher',
    subscribe: "S'abonner aux nouveautés",
    home: 'Accueil',
    others: 'autres',
    general: 'Général',
    toc: 'Sur cette page',
  },
  zh: {
    blogTitle: 'CASYS 博客',
    blogSubtitle: 'CASYS 开发相关文章与动态。',
    allArticles: '所有文章',
    recentArticles: '最新文章',
    byCategory: '按类别',
    popularTags: '热门标签',
    search: '搜索',
    subscribe: '订阅更新',
    home: '首页',
    others: '更多',
    general: '通用',
    toc: '本页目录',
  },
  'zh-TW': {
    blogTitle: 'CASYS 部落格',
    blogSubtitle: 'CASYS 開發相關文章與動態。',
    allArticles: '所有文章',
    recentArticles: '最新文章',
    byCategory: '按類別',
    popularTags: '熱門標籤',
    search: '搜尋',
    subscribe: '訂閱更新',
    home: '首頁',
    others: '更多',
    general: '通用',
    toc: '本頁目錄',
  },
};

const t = labels[locale];
const blogBase = locale === 'en' ? '/blog' : `/${locale}/blog`;
const homeBase = locale === 'en' ? '/' : `/${locale}`;

// Récupérer les articles de blog pour la navigation (filtrés par locale)
const blogPosts = await getCollection('blog', ({ data, id }) => {
  return !data.draft && id.startsWith(`${locale}/`);
});

// Trier par date de publication (plus récent en premier)
const sortedPosts = blogPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Articles récents (5 derniers)
const recentPosts = sortedPosts.slice(0, 5);

// Grouper par catégorie
const postsByCategory = sortedPosts.reduce((acc, post) => {
  const category = post.data.category || t.general;
  if (!acc[category]) acc[category] = [];
  acc[category].push(post);
  return acc;
}, {} as Record<string, typeof sortedPosts>);

// Tags populaires
const allTags = sortedPosts.flatMap(post => post.data.tags);
const tagCounts = allTags.reduce((acc, tag) => {
  acc[tag] = (acc[tag] || 0) + 1;
  return acc;
}, {} as Record<string, number>);
const popularTags = Object.entries(tagCounts)
  .sort(([,a], [,b]) => b - a)
  .slice(0, 10)
  .map(([tag]) => tag);

const currentPath = Astro.url.pathname;

// Helper to get slug without locale prefix
function getPostSlug(post: typeof sortedPosts[0]) {
  return post.slug.replace(`${locale}/`, '');
}
---

<!DOCTYPE html>
<html lang={locale === 'zh' ? 'zh-CN' : locale === 'zh-TW' ? 'zh-TW' : locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description || t.blogSubtitle} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/icons/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="manifest" href="/icons/site.webmanifest" />

    <!-- Self-hosted fonts (Vercel CDN) — preload critical display font -->
    <link rel="preload" href="/fonts/fraunces-latin-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-latin-normal.woff2" as="font" type="font/woff2" crossorigin />
    <!-- Material Symbols — icon font, kept external (not critical path) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" />

    <script>
      // Auto theme sync with system preference
      (function() {
        try {
          var root = document.documentElement;
          var mql = window.matchMedia('(prefers-color-scheme: dark)');
          var apply = function() {
            root.dataset.theme = mql.matches ? 'dark' : 'light';
          };
          apply();
          mql.addEventListener('change', apply);
        } catch(_) {}
      })();
    </script>

    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-FR86NHGK8Y"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-FR86NHGK8Y', {
        cookie_domain: 'casys.ai',
        linker: { accept_incoming: false, decorate: false }
      });
    </script>

    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <HrefLang siteUrl={siteUrl} />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="Casys AI" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={effectiveOgTitle} />
    {effectiveOgDescription && <meta property="og:description" content={effectiveOgDescription} />}
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={effectiveOgTitle} />
    {effectiveOgDescription && <meta name="twitter:description" content={effectiveOgDescription} />}
    <meta name="twitter:image" content={ogImage} />
    <script defer src="/u/script.js" data-website-id="41fe387f-874e-4c5b-8a69-1364587b77f5"></script>
    {slug && blogBaseUrl && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": title,
        "description": description || t.blogSubtitle,
        ...(siteUrl && { "image": ogImage }),
        ...(datePublished && { "datePublished": datePublished }),
        ...(dateModified && { "dateModified": dateModified }),
        "author": author
          ? { "@type": "Person", "name": author, "url": `${rootSiteUrl}/about` }
          : { "@type": "Organization", "name": "Casys AI", "url": rootSiteUrl },
        "publisher": {
          "@type": "Organization",
          "name": "Casys AI",
          "url": rootSiteUrl,
          "logo": {
            "@type": "ImageObject",
            "url": `${rootSiteUrl}/icons/logo.svg`
          }
        },
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": canonicalUrl || `${blogBaseUrl}/${slug}`
        },
        ...(tags?.length && { "keywords": tags.join(", ") }),
        ...(category && { "articleSection": category }),
        "inLanguage": locale === 'zh' ? 'zh-CN' : locale
      }).replace(/</g, '\\u003c')} />
    )}
    {slug && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": t.home, "item": `${rootSiteUrl}${localePrefix || '/'}` },
          { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${rootSiteUrl}${localePrefix}/blog` },
          { "@type": "ListItem", "position": 3, "name": title }
        ]
      }).replace(/</g, '\\u003c')} />
    )}
  </head>

  <body class="blog-body">
    <!-- Nav bar -->
    <nav class="blog-topnav">
      <div class="blog-topnav-inner">
        <!-- Mobile sidebar toggle -->
        <button class="blog-sidebar-toggle" aria-label="Toggle sidebar" id="sidebarToggle">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
            <line x1="3" y1="5" x2="17" y2="5" />
            <line x1="3" y1="10" x2="17" y2="10" />
            <line x1="3" y1="15" x2="17" y2="15" />
          </svg>
        </button>

        <!-- Logo + title -->
        <div class="blog-topnav-brand">
          <img src="/icons/favicon-32x32.png" alt="CASYS" class="blog-topnav-logo" />
          <span class="blog-topnav-name">CASYS</span>
          <span class="blog-topnav-label">Blog</span>
        </div>

        <!-- Navigation links -->
        <div class="blog-topnav-links">
          <a href={homeBase} class="blog-topnav-link">&larr; {t.home}</a>
        </div>
      </div>
    </nav>

    <!-- Main layout: sidebar + content -->
    <div class:list={['blog-shell', { 'blog-shell--collapsed': !!slug }]}>
      <!-- Sidebar overlay (mobile) -->
      <div class="blog-sidebar-overlay" id="sidebarOverlay"></div>

      <!-- Sidebar -->
      <aside class="blog-sidebar" id="blogSidebar">
        <!-- Collapsed strip (40px, shown when sidebar collapsed) -->
        <div class="blog-sidebar-strip" id="sidebarStrip">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 18l6-6-6-6" />
          </svg>
        </div>
        <!-- Mobile close -->
        <button class="blog-sidebar-close" id="sidebarClose" aria-label="Close sidebar">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="4" y1="4" x2="14" y2="14" />
            <line x1="14" y1="4" x2="4" y2="14" />
          </svg>
        </button>
        <!-- Sidebar content (hidden when collapsed) -->
        <div class="blog-sidebar-content">
        <div class="blog-sidebar-header">
          <div class="blog-sidebar-header-top">
            <h2 class="blog-sidebar-title">{t.blogTitle}</h2>
            <button class="blog-sidebar-collapse" id="sidebarCollapse" aria-label="Hide sidebar">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1.5" y="2.5" width="13" height="11" rx="1.5"/>
                <line x1="6" y1="2.5" x2="6" y2="13.5"/>
                <polyline points="10.5,6.5 8.5,8 10.5,9.5"/>
              </svg>
            </button>
          </div>
          <p class="blog-sidebar-subtitle">{t.blogSubtitle}</p>
        </div>

        <nav class="blog-sidebar-nav">
          <!-- All articles link -->
          <div class="blog-nav-section">
            <a
              href={blogBase}
              class:list={[
                'blog-nav-link',
                { 'blog-nav-link--active': currentPath === blogBase || currentPath === `${blogBase}/` }
              ]}
            >
              {t.allArticles}
            </a>
          </div>

          <!-- Recent articles -->
          <div class="blog-nav-section">
            <h3 class="blog-nav-heading">{t.recentArticles}</h3>
            <ul class="blog-nav-list">
              {recentPosts.map((post) => (
                <li>
                  <a
                    href={`${blogBase}/${getPostSlug(post)}`}
                    class:list={[
                      'blog-nav-link blog-nav-link--article',
                      { 'blog-nav-link--active': currentPath === `${blogBase}/${getPostSlug(post)}` }
                    ]}
                  >
                    <span class="blog-nav-link-title">{post.data.title}</span>
                    <span class="blog-nav-link-meta">
                      <span>{post.data.date.toLocaleDateString(locale === 'zh' ? 'zh-CN' : locale === 'zh-TW' ? 'zh-TW' : locale)}</span>
                      {post.data.category && (
                        <>
                          <span class="blog-nav-link-dot">&middot;</span>
                          <span>{post.data.category}</span>
                        </>
                      )}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Categories -->
          <div class="blog-nav-section">
            <h3 class="blog-nav-heading">{t.byCategory}</h3>
            <ul class="blog-nav-list">
              {Object.entries(postsByCategory).map(([categoryName, posts]) => (
                <li>
                  <div class="blog-category-row">
                    <span class="blog-category-name">{categoryName}</span>
                    <span class="blog-category-count">{posts.length}</span>
                  </div>
                  <ul class="blog-category-posts">
                    {posts.slice(0, 3).map((post) => (
                      <li>
                        <a
                          href={`${blogBase}/${getPostSlug(post)}`}
                          class:list={[
                            'blog-nav-link blog-nav-link--sub',
                            { 'blog-nav-link--active': currentPath === `${blogBase}/${getPostSlug(post)}` }
                          ]}
                        >
                          <span class="blog-nav-link-title">{post.data.title}</span>
                        </a>
                      </li>
                    ))}
                    {posts.length > 3 && (
                      <li>
                        <span class="blog-category-more">
                          +{posts.length - 3} {t.others}
                        </span>
                      </li>
                    )}
                  </ul>
                </li>
              ))}
            </ul>
          </div>

          <!-- Popular tags -->
          <div class="blog-nav-section">
            <h3 class="blog-nav-heading">{t.popularTags}</h3>
            <div class="blog-tags">
              {popularTags.map((tag) => (
                <span class="blog-tag">#{tag}</span>
              ))}
            </div>
          </div>

          <!-- Actions -->
          <div class="blog-sidebar-actions">
            <button class="blog-sidebar-action-btn">{t.search}</button>
            <button class="blog-sidebar-action-btn">{t.subscribe}</button>
          </div>
        </nav>
        </div><!-- /.blog-sidebar-content -->
      </aside>

      <!-- Main content -->
      <main class="blog-main" id="blogMain">
        <div class="blog-content">
          <slot />
        </div>
      </main>

      <!-- Table of Contents (visible when sidebar collapsed) -->
      <aside class="blog-toc" id="blogToc">
        <div class="blog-toc-inner">
          <div class="blog-toc-header">
            <span class="blog-toc-label">{t.toc}</span>
          </div>
          <nav class="blog-toc-nav" id="blogTocNav"></nav>
        </div>
      </aside>
    </div>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const toggle = document.getElementById('sidebarToggle');
        const close = document.getElementById('sidebarClose');
        const collapse = document.getElementById('sidebarCollapse');
        const strip = document.getElementById('sidebarStrip');
        const sidebar = document.getElementById('blogSidebar');
        const overlay = document.getElementById('sidebarOverlay');
        const shell = document.querySelector('.blog-shell');
        if (!toggle || !close || !sidebar || !overlay || !collapse || !strip || !shell) return;

        // Mobile drawer
        function open() {
          sidebar.classList.add('blog-sidebar--open');
          overlay.classList.add('blog-sidebar-overlay--visible');
          document.body.style.overflow = 'hidden';
        }
        function shut() {
          sidebar.classList.remove('blog-sidebar--open');
          overlay.classList.remove('blog-sidebar-overlay--visible');
          document.body.style.overflow = '';
        }
        toggle.addEventListener('click', open);
        close.addEventListener('click', shut);
        overlay.addEventListener('click', shut);

        // Desktop collapse/expand (ExplorerSidebar pattern)
        // Blog index: sidebar open, no TOC, no collapse/strip
        // Article pages: sidebar collapsed, TOC visible
        const path = window.location.pathname.replace(/\/$/, '');
        const isBlogIndex = /^\/(fr|zh|zh-TW)?\/?(blog)?$/.test(path) || path.endsWith('/blog');
        const tocEl = document.getElementById('blogToc');

        if (isBlogIndex) {
          // Hide TOC, strip, and collapse button on index
          if (tocEl) tocEl.style.display = 'none';
          strip.style.display = 'none';
          collapse.style.display = 'none';
        } else {
          // Article: already collapsed via server-rendered class
          collapse.addEventListener('click', () => {
            shell.classList.add('blog-shell--collapsed');
          });

          strip.addEventListener('click', () => {
            shell.classList.remove('blog-shell--collapsed');
          });
        }

        // Build Table of Contents
        const tocNav = document.getElementById('blogTocNav');
        const content = document.querySelector('.blog-content');
        const mainEl = document.getElementById('blogMain');
        if (!tocNav || !content || !mainEl) return;

        // Collect headings, stop at "related articles" boundary
        const stopWords = ['articles similaires', 'related articles', 'see also', '相关文章', '相關文章'];
        const allHeadings = content.querySelectorAll('h2, h3');
        const headings = [];
        for (const h of allHeadings) {
          const text = h.textContent.trim().toLowerCase();
          if (stopWords.some(sw => text.includes(sw))) break;
          headings.push(h);
        }
        if (headings.length === 0) return;

        headings.forEach((heading, i) => {
          if (!heading.id) heading.id = 'toc-' + i;
          const link = document.createElement('a');
          link.href = '#' + heading.id;
          link.textContent = heading.textContent.trim();
          const isH3 = heading.tagName === 'H3';
          let cls = 'blog-toc-link';
          if (isH3) cls += ' blog-toc-link--h3';
          // Add section separator before h2 (except first)
          if (!isH3 && i > 0) cls += ' blog-toc-link--section';
          link.className = cls;
          link.addEventListener('click', (e) => {
            e.preventDefault();
            heading.scrollIntoView({ behavior: 'smooth', block: 'start' });
          });
          tocNav.appendChild(link);
        });

        // Scroll spy with IntersectionObserver
        let currentActive = null;
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              if (currentActive) currentActive.classList.remove('blog-toc-link--active');
              const link = tocNav.querySelector('a[href="#' + entry.target.id + '"]');
              if (link) {
                link.classList.add('blog-toc-link--active');
                currentActive = link;
                // Scroll active link into view within TOC
                link.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
              }
            }
          });
        }, { root: mainEl, rootMargin: '0px 0px -80% 0px', threshold: 0 });

        headings.forEach(h => observer.observe(h));
      });
    </script>
    <Analytics />
  </body>
</html>

<style>
  /* =========================================
     BLOG LAYOUT - Scoped Styles (Light Mode)
     ========================================= */

  /* --- Body --- */
  .blog-body {
    margin: 0;
    min-height: 100vh;
    overflow: hidden;
    background-color: var(--md-sys-color-surface, #fafaf9);
    color: var(--md-sys-color-on-surface, #1c1917);
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    line-height: 1.6;
  }

  /* --- Top Navigation Bar --- */
  .blog-topnav {
    position: sticky;
    top: 0;
    z-index: 40;
    height: 60px;
    display: flex;
    align-items: center;
    padding: 0 1.25rem;
    background-color: var(--md-sys-color-surface, #ffffff);
    border-bottom: 1px solid var(--md-sys-color-outline-variant, #e7e5e4);
  }

  .blog-topnav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .blog-topnav-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .blog-topnav-logo {
    width: 28px;
    height: 28px;
    border-radius: 6px;
  }

  .blog-topnav-name {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--md-sys-color-on-surface, #1c1917);
    letter-spacing: -0.01em;
  }

  .blog-topnav-label {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--md-sys-color-on-surface-variant, #78716c);
    margin-left: 0.25rem;
    padding: 0.1em 0.5em;
    background: var(--md-sys-color-surface-variant, #f5f5f4);
    border-radius: 4px;
  }

  .blog-topnav-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .blog-topnav-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--md-sys-color-on-surface-variant, #57534e);
    text-decoration: none;
    padding: 0.35em 0.7em;
    border-radius: 6px;
    transition: color 0.15s, background-color 0.15s;
  }

  .blog-topnav-link:hover {
    color: var(--md-sys-color-on-surface, #1c1917);
    background-color: var(--md-sys-color-surface-variant, #f5f5f4);
  }

  .blog-topnav-sep {
    display: block;
    width: 1px;
    height: 1.25rem;
    background-color: var(--md-sys-color-outline-variant, #d6d3d1);
  }

  /* --- Shell (sidebar + content) --- */
  .blog-shell {
    position: relative;
    display: flex;
    height: calc(100vh - 60px);
  }

  /* --- Sidebar --- */
  .blog-sidebar {
    position: relative;
    width: 300px;
    min-width: 300px;
    display: flex;
    flex-direction: column;
    background-color: var(--md-sys-color-surface, #ffffff);
    border-right: 1px solid var(--md-sys-color-outline-variant, #e7e5e4);
    transition: width 0.25s ease, min-width 0.25s ease, opacity 0.2s ease;
    overflow: hidden;
  }

  /* --- Collapsed strip (hidden by default, shown when collapsed) --- */
  .blog-sidebar-strip {
    display: none;
    align-items: center;
    justify-content: center;
    width: 40px;
    min-height: 100%;
    cursor: pointer;
    color: var(--md-sys-color-on-surface-variant, #a8a29e);
    transition: background-color 0.15s, color 0.15s;
  }

  .blog-sidebar-strip:hover {
