---
import { getCollection } from 'astro:content';
import BlogLayout from '../../../layouts/BlogLayout.astro';

const locale = 'zh';

const labels = {
  backToBlog: '返回博客',
  updatedOn: '更新于',
  relatedArticles: '相关文章',
  readArticle: '阅读文章',
  allArticles: '所有文章',
  shareNote: '在社交媒体上分享这篇文章',
};

export const prerender = true;

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog', ({ data, id }) => {
    return !data.draft && id.startsWith('zh/');
  });

  return blogPosts.map(entry => ({
    params: { slug: entry.slug.replace('zh/', '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;

if (!entry) {
  return Astro.redirect('/zh/blog');
}

const { Content } = await entry.render();

// Articles similaires
const allPosts = await getCollection('blog', ({ data, id }) => !data.draft && id.startsWith('zh/'));
const relatedPosts = allPosts
  .filter(post =>
    post.slug !== entry.slug && (
      post.data.category === entry.data.category ||
      post.data.tags.some(tag => entry.data.tags.includes(tag))
    )
  )
  .slice(0, 3);

function getPostSlug(post: typeof allPosts[0]) {
  return post.slug.replace('zh/', '');
}
---

<BlogLayout title={entry.data.title} locale={locale} description={entry.data.description} slug={entry.slug.replace('zh/', '')}>
  <!-- Navigation retour -->
  <nav class="back-nav">
    <a href="/zh/blog" class="back-link">
      <span class="back-arrow">&larr;</span> {labels.backToBlog}
    </a>
  </nav>

  <!-- En-tête de l'article -->
  <header class="article-header">
    {entry.data.category && (
      <div class="category-wrapper">
        <span class="category-badge">
          {entry.data.category}
        </span>
      </div>
    )}

    <h1 class="article-title">
      {entry.data.title}
    </h1>

    {entry.data.description && (
      <p class="article-description">
        {entry.data.description}
      </p>
    )}

    <!-- Métadonnées -->
    <div class="article-meta">
      <div class="meta-item">
        <time datetime={entry.data.date.toISOString()}>
          {entry.data.date.toLocaleDateString('zh-CN', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          })}
        </time>
      </div>

      <span class="meta-separator">&middot;</span>

      <div class="meta-item">
        <span>{entry.data.author}</span>
      </div>

      {entry.data.updatedAt && (
        <>
          <span class="meta-separator">&middot;</span>
          <div class="meta-item">
            <span>
              {labels.updatedOn} {entry.data.updatedAt.toLocaleDateString('zh-CN')}
            </span>
          </div>
        </>
      )}
    </div>

    <!-- Tags -->
    {entry.data.tags.length > 0 && (
      <div class="tags-wrapper">
        {entry.data.tags.map((tag) => (
          <span class="tag">#{tag}</span>
        ))}
      </div>
    )}
  </header>

  <!-- Contenu de l'article -->
  <article class="prose">
    <Content />
  </article>

  <!-- Articles similaires -->
  {relatedPosts.length > 0 && (
    <section class="related-section">
      <h2 class="related-title">{labels.relatedArticles}</h2>

      <div class="related-grid">
        {relatedPosts.map((post) => (
          <article class="related-card">
            <div class="related-card-body">
              <h3 class="related-card-title">
                <a href={`/zh/blog/${getPostSlug(post)}`}>
                  {post.data.title}
                </a>
              </h3>

              <div class="related-card-date">
                {post.data.date.toLocaleDateString('zh-CN')}
              </div>

              {post.data.description && (
                <p class="related-card-desc">
                  {post.data.description}
                </p>
              )}

              <div class="related-card-tags">
                {post.data.tags.slice(0, 2).map((tag) => (
                  <span class="related-tag">{tag}</span>
                ))}
              </div>
            </div>

            <a href={`/zh/blog/${getPostSlug(post)}`} class="related-card-link">
              {labels.readArticle} &rarr;
            </a>
          </article>
        ))}
      </div>
    </section>
  )}

  <!-- Navigation -->
  <nav class="bottom-nav">
    <div class="bottom-nav-inner">
      <div class="bottom-nav-back">
        <a href="/zh/blog">
          &larr; {labels.allArticles}
        </a>
      </div>

      <div class="bottom-nav-share">
        {labels.shareNote}
      </div>
    </div>
  </nav>
</BlogLayout>

<style>
  /* ============================================
     BLOG ARTICLE PAGE - Scoped Styles
     Material 3 tokens + Editorial magazine feel
     ============================================ */

  /* --- Back Navigation --- */
  .back-nav {
    margin-bottom: 2rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--md-sys-color-on-surface-variant, #5f6368);
    text-decoration: none;
    transition: color 0.2s ease;
    letter-spacing: 0.01em;
  }

  .back-link:hover {
    color: var(--md-sys-color-primary, #6750a4);
  }

  .back-arrow {
    font-size: 1rem;
    transition: transform 0.2s ease;
  }

  .back-link:hover .back-arrow {
    transform: translateX(-2px);
  }

  /* --- Article Header --- */
  .article-header {
    margin-bottom: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--md-sys-color-outline-variant, #c4c7c5);
  }

  .category-wrapper {
    margin-bottom: 1.25rem;
  }

  .category-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.875rem;
    border-radius: 100px;
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    background-color: var(--md-sys-color-primary-container, #eaddff);
    color: var(--md-sys-color-on-primary-container, #21005d);
  }

  .article-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--md-sys-color-on-surface, #1c1b1f);
    margin: 0 0 1.25rem 0;
    letter-spacing: -0.02em;
    font-optical-sizing: auto;
  }

  .article-description {
    font-family: 'Inter', sans-serif;
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--md-sys-color-on-surface-variant, #49454f);
    margin: 0 0 1.75rem 0;
    max-width: 42em;
  }

  /* --- Meta --- */
  .article-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    color: var(--md-sys-color-on-surface-variant, #5f6368);
  }

  .meta-item {
    display: flex;
    align-items: center;
  }

  .meta-separator {
    color: var(--md-sys-color-outline, #79747e);
    user-select: none;
  }

  /* --- Tags --- */
  .tags-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    padding: 0.1875rem 0.625rem;
    border-radius: 100px;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    background-color: var(--md-sys-color-surface-container, #f3edf7);
    color: var(--md-sys-color-on-surface-variant, #49454f);
    letter-spacing: 0.02em;
  }

  /* --- Prose / Article Content --- */
  .prose {
    font-family: 'Inter', sans-serif;
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--md-sys-color-on-surface, #1c1b1f);
    max-width: 72ch;
    margin-bottom: 4rem;
  }

  /* --- Related Articles Section --- */
  .related-section {
    border-top: 1px solid var(--md-sys-color-outline-variant, #c4c7c5);
    padding-top: 3rem;
  }

  .related-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--md-sys-color-on-surface, #1c1b1f);
    margin: 0 0 2rem 0;
    letter-spacing: -0.01em;
  }

  .related-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .related-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .related-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background-color: var(--md-sys-color-surface-container-low, #f7f2fa);
    border-radius: 12px;
    border: 1px solid var(--md-sys-color-outline-variant, #c4c7c5);
    padding: 1.5rem;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .related-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  .related-card-body {
    margin-bottom: 1rem;
  }

  .related-card-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.35;
    margin: 0 0 0.5rem 0;
    color: var(--md-sys-color-on-surface, #1c1b1f);
  }

  .related-card-title a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .related-card-title a:hover {
    color: var(--md-sys-color-primary, #6750a4);
  }

  .related-card-date {
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    color: var(--md-sys-color-on-surface-variant, #5f6368);
    margin-bottom: 0.625rem;
  }

  .related-card-desc {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--md-sys-color-on-surface-variant, #49454f);
    margin: 0 0 0.75rem 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .related-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.125rem 0.5rem;
    border-radius: 6px;
    font-family: 'Inter', sans-serif;
    font-size: 0.6875rem;
    font-weight: 500;
    background-color: var(--md-sys-color-surface-container, #f3edf7);
    color: var(--md-sys-color-on-surface-variant, #49454f);
  }

  .related-card-link {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--md-sys-color-primary, #6750a4);
    text-decoration: none;
    transition: color 0.2s ease, gap 0.2s ease;
  }

  .related-card-link:hover {
    color: var(--md-sys-color-primary, #4a3a8a);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* --- Bottom Navigation --- */
  .bottom-nav {
    border-top: 1px solid var(--md-sys-color-outline-variant, #c4c7c5);
    padding-top: 2.5rem;
    margin-top: 3rem;
  }

  .bottom-nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .bottom-nav-back a {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--md-sys-color-on-surface-variant, #5f6368);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .bottom-nav-back a:hover {
    color: var(--md-sys-color-primary, #6750a4);
  }

  .bottom-nav-share {
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    color: var(--md-sys-color-on-surface-variant, #79747e);
    font-style: italic;
  }
</style>

<style is:global>
  /* ============================================
     PROSE STYLES - Global (for MDX content)
     ============================================ */

  .prose h1,
  .prose h2,
  .prose h3,
  .prose h4,
  .prose h5,
  .prose h6 {
    font-family: 'Fraunces', Georgia, serif;
    color: var(--md-sys-color-on-surface, #1c1b1f);
    line-height: 1.25;
    margin-top: 2.5em;
    margin-bottom: 0.75em;
    letter-spacing: -0.015em;
    font-optical-sizing: auto;
  }

  .prose h1 { font-size: 2.25rem; font-weight: 700; }
  .prose h2 { font-size: 1.75rem; font-weight: 600; border-bottom: 1px solid var(--md-sys-color-outline-variant, #c4c7c5); padding-bottom: 0.5em; }
  .prose h3 { font-size: 1.375rem; font-weight: 600; }
  .prose h4 { font-size: 1.125rem; font-weight: 600; }

  .prose p {
    margin-bottom: 1.5em;
    line-height: 1.8;
  }

  .prose a {
    color: var(--md-sys-color-primary, #6750a4);
    text-decoration: underline;
    text-decoration-color: var(--md-sys-color-primary, #6750a4);
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: color 0.2s ease, text-decoration-color 0.2s ease;
  }

  .prose a:hover {
    color: var(--md-sys-color-primary, #4a3a8a);
    text-decoration-thickness: 2px;
  }

  .prose code {
    font-family: 'JetBrains Mono', monospace;
    background-color: var(--md-sys-color-surface-container, #f3edf7);
    color: var(--md-sys-color-on-surface, #1c1b1f);
    padding: 0.15em 0.35em;
    border-radius: 4px;
    font-size: 0.85em;
    font-weight: 500;
  }

  .prose pre {
    background-color: #1a1815;
    color: #f5f0ea;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875rem;
    line-height: 1.7;
    padding: 1.5rem;
    border-radius: 10px;
    overflow-x: auto;
    margin: 2em 0;
    border: 1px solid rgba(255, 184, 111, 0.08);
  }

  .prose pre code {
    background-color: transparent;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
    color: inherit;
    font-weight: 400;
  }

  .prose blockquote {
    border-left: 3px solid var(--md-sys-color-primary, #6750a4);
    padding: 0.75em 1.25em;
    margin: 2em 0;
    font-style: italic;
    color: var(--md-sys-color-on-surface-variant, #49454f);
    background-color: var(--md-sys-color-surface-container-low, #f7f2fa);
    border-radius: 0 8px 8px 0;
  }

  .prose blockquote p {
    margin-bottom: 0.5em;
  }

  .prose blockquote p:last-child {
    margin-bottom: 0;
  }

  .prose ul,
  .prose ol {
    margin: 1.5em 0;
    padding-left: 1.75em;
  }

  .prose li {
    margin-bottom: 0.5em;
    line-height: 1.7;
  }

  .prose li::marker {
    color: var(--md-sys-color-primary, #6750a4);
  }

  .prose img {
    max-width: 100%;
    height: auto;
    border-radius: 10px;
    margin: 2em 0;
  }

  .prose hr {
    border: none;
    border-top: 1px solid var(--md-sys-color-outline-variant, #c4c7c5);
    margin: 3em 0;
  }

  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 2em 0;
    font-size: 0.9375rem;
  }

  .prose th {
    text-align: left;
    font-weight: 600;
    padding: 0.75em 1em;
    border-bottom: 2px solid var(--md-sys-color-outline-variant, #c4c7c5);
    color: var(--md-sys-color-on-surface, #1c1b1f);
  }

  .prose td {
    padding: 0.75em 1em;
    border-bottom: 1px solid var(--md-sys-color-outline-variant, #e0e0e0);
  }

  .prose strong {
    font-weight: 700;
    color: var(--md-sys-color-on-surface, #1c1b1f);
  }

  .prose em {
    font-style: italic;
  }

  /* ============================================
     DARK MODE OVERRIDES
     Warm orange palette
     ============================================ */

  html[data-theme="dark"] .back-link {
    color: #d5c3b5;
  }
  html[data-theme="dark"] .back-link:hover {
    color: #FFB86F;
  }

