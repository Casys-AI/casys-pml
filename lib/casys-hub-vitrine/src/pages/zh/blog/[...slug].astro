    color: #d5c3b5;
  }

  html[data-theme="dark"] .prose li::marker {
    color: #FFB86F;
  }

  html[data-theme="dark"] .prose strong {
    color: #f5f0ea;
  }

  html[data-theme="dark"] .prose hr {
    border-top-color: rgba(255, 184, 111, 0.1);
  }

  html[data-theme="dark"] .prose th {
    border-bottom-color: rgba(255, 184, 111, 0.15);
