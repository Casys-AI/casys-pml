  }

  html[data-theme="dark"] .prose td {
    border-bottom-color: rgba(255, 184, 111, 0.08);
  }

  html[data-theme="dark"] .related-section {
    border-top-color: rgba(255, 184, 111, 0.1);
  }

  html[data-theme="dark"] .related-title {
    color: #f5f0ea;
  }

  html[data-theme="dark"] .related-card {
    background-color: #1a1815;
    border-color: rgba(255, 184, 111, 0.1);
  }

  html[data-theme="dark"] .related-card:hover {
    box-shadow: 0 4px 20px rgba(255, 184, 111, 0.06);
    border-color: rgba(255, 184, 111, 0.2);
  }

  html[data-theme="dark"] .related-card-title {
    color: #f5f0ea;
  }

  html[data-theme="dark"] .related-card-title a:hover {
    color: #FFB86F;
  }

  html[data-theme="dark"] .related-card-date {
    color: #d5c3b5;
  }

  html[data-theme="dark"] .related-card-desc {
    color: #d5c3b5;
  }

  html[data-theme="dark"] .related-tag {
    background-color: rgba(255, 184, 111, 0.08);
    color: #d5c3b5;
  }

  html[data-theme="dark"] .related-card-link {
    color: #FFB86F;
  }

  html[data-theme="dark"] .related-card-link:hover {
    color: #ffc98f;
  }

  html[data-theme="dark"] .bottom-nav {
    border-top-color: rgba(255, 184, 111, 0.1);
  }

  html[data-theme="dark"] .bottom-nav-back a {
    color: #d5c3b5;
  }

  html[data-theme="dark"] .bottom-nav-back a:hover {
    color: #FFB86F;
  }

  html[data-theme="dark"] .bottom-nav-share {
    color: rgba(213, 195, 181, 0.6);
  }
</style>
