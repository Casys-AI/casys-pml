---
import LandingLayout from '../../../layouts/LandingLayout.astro';
import UseCaseDetail from '../../../features/landing-v2/UseCaseDetail.astro';
import { useCases } from '../../../content/use-cases';

const uc = useCases.find(c => c.id === 'navigable-knowledge-graphs')!;
---

<LandingLayout title={`${uc.title.zh} — Casys AI`} description="工程咨询公司如何将不透明的 Excel 电子表格转化为可导航知识图谱。让跨领域专业知识可见可追踪。">
  <UseCaseDetail useCase={uc} />
</LandingLayout>
