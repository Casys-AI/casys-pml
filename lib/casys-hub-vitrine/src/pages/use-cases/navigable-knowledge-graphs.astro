---
import LandingLayout from '../../layouts/LandingLayout.astro';
import UseCaseDetail from '../../features/landing-v2/UseCaseDetail.astro';
import { useCases } from '../../content/use-cases';

const uc = useCases.find(c => c.id === 'navigable-knowledge-graphs')!;
---

<LandingLayout title={`${uc.title.en} — Casys AI`} description="How an engineering firm turned opaque Excel files into a navigable knowledge graph. Making cross-domain expertise visible and traceable.">
  <UseCaseDetail useCase={uc} />
</LandingLayout>
