---
import LandingLayout from '../../layouts/LandingLayout.astro';
import UseCaseDetail from '../../features/landing-v2/UseCaseDetail.astro';
import { useCases } from '../../content/use-cases';

const uc = useCases.find(c => c.id === 'plannable-mcp-workflows')!;
---

<LandingLayout title={`${uc.title.en} — Casys AI`} description="From LangGraph static pipelines to MCP Engine dynamic workflows with built-in Human-in-the-Loop safety. Industrial AI case study.">
  <UseCaseDetail useCase={uc} />
</LandingLayout>
