---
import LandingLayout from '../../../layouts/LandingLayout.astro';
import UseCaseDetail from '../../../features/landing-v2/UseCaseDetail.astro';
import { useCases } from '../../../content/use-cases';

const uc = useCases.find(c => c.id === 'plannable-mcp-workflows')!;
