---
import LandingLayout from '../../../layouts/LandingLayout.astro';
import UseCaseDetail from '../../../features/landing-v2/UseCaseDetail.astro';
import { useCases } from '../../../content/use-cases';

const uc = useCases.find(c => c.id === 'chat-first-workflows')!;
---

<LandingLayout title={`${uc.title['zh-TW'] ?? uc.title.zh} — Casys AI`} description="教練新創如何用 MCP Apps 將 5 個分散應用替換為一個聊天優先介面。從儀表板疲勞到對話式工作流。">
  <UseCaseDetail useCase={uc} />
</LandingLayout>
