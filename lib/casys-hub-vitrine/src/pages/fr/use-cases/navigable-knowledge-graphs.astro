---
import LandingLayout from '../../../layouts/LandingLayout.astro';
import UseCaseDetail from '../../../features/landing-v2/UseCaseDetail.astro';
import { useCases } from '../../../content/use-cases';

const uc = useCases.find(c => c.id === 'navigable-knowledge-graphs')!;
---

<LandingLayout title={`${uc.title.fr} — Casys AI`} description="Comment un bureau d'études a transformé des tableurs Excel opaques en knowledge graph navigable. Expertise transverse visible et traçable.">
  <UseCaseDetail useCase={uc} />
</LandingLayout>
