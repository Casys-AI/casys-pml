---
import McpBridgeLayout from '../../features/mcp-bridge/McpBridgeLayout.astro';
import McpBridgeContent from '../../features/mcp-bridge/McpBridgeContent.astro';

const locale = (Astro as any).currentLocale ?? 'en';
const pageTitle = locale === 'fr'
  ? '@casys/mcp-bridge - MCP Apps sur Plateformes Messagerie'
  : '@casys/mcp-bridge - MCP Apps to Messaging Platforms';
---

<McpBridgeLayout title={pageTitle}>
  <McpBridgeContent />
</McpBridgeLayout>
