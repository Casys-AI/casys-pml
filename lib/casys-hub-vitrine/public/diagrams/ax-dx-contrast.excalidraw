      "x": 30,
      "y": 145,
      "width": 460,
      "height": 80,
      "strokeColor": "#60a5fa",
      "backgroundColor": "#1a2744",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roughness": 0,
      "roundness": { "type": 3, "value": 10 },
      "label": {
        "text": "$ deploy --help\n\"Deploy your project to the\ntarget environment\"",
        "fontSize": 16,
        "fontFamily": 5,
        "strokeColor": "#f0ede8",
        "textAlign": "center",
        "verticalAlign": "middle"
      }
    },
    {
      "id": "dx-box2",
