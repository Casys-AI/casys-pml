{
  "type": "excalidraw",
  "version": 2,
  "source": "Casys Hub Vitrine",
  "elements": [
    {
      "id": "title",
      "type": "text",
      "x": 200,
      "y": 20,
      "width": 700,
      "height": 44,
      "text": "Same Tool, Different Operator",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "strokeColor": "#f0ede8"
    },
    {
      "id": "subtitle",
      "type": "text",
      "x": 220,
      "y": 68,
      "width": 660,
      "height": 22,
      "text": "What the interface looks like from each side",
      "fontSize": 18,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "strokeColor": "#9ca3af"
    },

    {
      "id": "dx-header",
      "type": "text",
      "x": 50,
      "y": 110,
      "width": 300,
      "height": 24,
      "text": "DEVELOPER EXPERIENCE",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "strokeColor": "#60a5fa"
    },

    {
      "id": "dx-box1",
