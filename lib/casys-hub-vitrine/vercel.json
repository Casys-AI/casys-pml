{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "astro",
  "outputDirectory": ".vercel/output",
  "rewrites": [
    {
      "source": "/u/script.js",
      "destination": "https://analytics.casys.ai/script.js"
    },
    {
      "source": "/u/api/send",
      "destination": "https://analytics.casys.ai/api/send"
    },
    {
      "source": "/:path((?!_astro|_vercel|api|ui|icons|fonts|images|pagefind|docs|fr|zh|mcp-server).*)",
      "has": [{ "type": "host", "value": "mcp-server.casys.ai" }],
      "destination": "/mcp-server/:path"
    },
    {
      "source": "/:path((?!_astro|_vercel|api|ui|icons|fonts|images|pagefind|docs|fr|zh|mcp-std).*)",
      "has": [{ "type": "host", "value": "mcp-std.casys.ai" }],
      "destination": "/mcp-std/:path"
    },
    {
      "source": "/:path((?!_astro|_vercel|api|ui|icons|fonts|images|pagefind|docs|fr|zh|engine).*)",
      "has": [{ "type": "host", "value": "engine.casys.ai" }],
      "destination": "/engine/:path"
    },
    {
      "source": "/:path((?!_astro|_vercel|api|ui|icons|fonts|images|pagefind|docs|fr|zh|mcp-bridge).*)",
      "has": [{ "type": "host", "value": "mcp-bridge.casys.ai" }],
      "destination": "/mcp-bridge/:path"
    }
  ]
}
